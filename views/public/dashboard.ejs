<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NFCKartify — <%= firma.ad %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #1c1c20;
      --bg2: #222227;
      --bg3: #28282e;
      --bg4: #2e2e35;
      --border: rgba(255,255,255,0.07);
      --border-gold: rgba(200,168,75,0.3);
      --gold: #c8a84b;
      --gold-light: #e5c46a;
      --gold-dim: rgba(200,168,75,0.1);
      --text: #f1f0ee;
      --text-muted: #888880;
      --text-faint: #444440;
      --danger: #ef4444;
      --danger-dim: rgba(239,68,68,0.1);
      --success: #22c55e;
      --success-dim: rgba(34,197,94,0.1);
      --fs-xs: 0.72rem;
      --fs-sm: 0.8rem;
      --fs-base: 0.875rem;
      --fw-normal: 400;
      --fw-medium: 500;
      --fw-semibold: 600;
      --fw-bold: 700;
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); font-size: var(--fs-base); line-height: 1.5; -webkit-font-smoothing: antialiased; overflow-x: hidden; }

    /* ── NAV ── */
    .dash-nav {
      position: sticky; top: 0; z-index: 50;
      height: 52px; display: flex; align-items: center; justify-content: space-between;
      padding: 0 24px;
      background: rgba(13,13,15,0.95); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo { font-size: var(--fs-base); font-weight: var(--fw-bold); color: var(--text); text-decoration: none; letter-spacing: -0.02em; }
    .nav-logo em { font-style: normal; color: var(--gold); }
    .nav-center { font-size: var(--fs-sm); color: var(--text-muted); font-weight: var(--fw-medium); }
    .nav-right { display: flex; align-items: center; gap: 8px; }

    /* ── BUTTONS ── */
    .btn { display: inline-flex; align-items: center; gap: 6px; height: 32px; padding: 0 14px; border-radius: 6px; font-size: var(--fs-sm); font-weight: var(--fw-medium); cursor: pointer; border: none; font-family: inherit; text-decoration: none; transition: all 0.15s; white-space: nowrap; }
    .btn-ghost { background: transparent; color: var(--text-muted); }
    .btn-ghost:hover { background: var(--bg3); color: var(--text); }
    .btn-gold { background: var(--gold); color: #000; font-weight: var(--fw-semibold); box-shadow: 0 0 16px rgba(200,168,75,0.2); }
    .btn-gold:hover { background: var(--gold-light); }
    .btn-border { background: transparent; color: var(--text-muted); border: 1px solid var(--border); }
    .btn-border:hover { border-color: var(--border-gold); color: var(--text); }
    .btn-danger-sm { background: var(--danger-dim); color: var(--danger); border: 1px solid rgba(239,68,68,0.2); }
    .btn-danger-sm:hover { background: rgba(239,68,68,0.18); }
    .btn-sm { height: 28px; padding: 0 10px; font-size: var(--fs-xs); }

    /* ── FLASH ── */
    .flash-bar {
      padding: 10px 24px; font-size: var(--fs-sm); font-weight: var(--fw-medium);
      display: flex; align-items: center; gap: 8px;
    }
    .flash-success { background: var(--success-dim); color: var(--success); border-bottom: 1px solid rgba(34,197,94,0.15); }
    .flash-error { background: var(--danger-dim); color: var(--danger); border-bottom: 1px solid rgba(239,68,68,0.15); }

    /* ── MAIN LAYOUT ── */
    .dash-main { max-width: 1100px; margin: 0 auto; padding: 28px 24px 64px; }

    /* ── HEADER ── */
    .dash-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
    .dash-title { font-size: 1.125rem; font-weight: var(--fw-bold); color: var(--text); letter-spacing: -0.02em; }
    .dash-subtitle { font-size: var(--fs-xs); color: var(--text-faint); margin-top: 2px; }

    /* ── STAT CARDS ── */
    .stat-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 24px; }
    .stat-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 16px 18px; }
    .stat-card-n { font-size: 1.5rem; font-weight: var(--fw-bold); color: var(--gold); letter-spacing: -0.04em; }
    .stat-card-l { font-size: var(--fs-xs); color: var(--text-faint); margin-top: 2px; }

    /* ── TABS ── */
    .dash-tabs { display: flex; gap: 2px; background: var(--bg2); border: 1px solid var(--border); border-radius: 8px; padding: 3px; width: fit-content; margin-bottom: 20px; }
    .dash-tab { padding: 6px 16px; border-radius: 6px; font-size: var(--fs-xs); font-weight: var(--fw-medium); color: var(--text-muted); text-decoration: none; border: none; background: transparent; cursor: pointer; font-family: inherit; transition: all 0.15s; white-space: nowrap; }
    .dash-tab.active, .dash-tab:hover { color: var(--text); background: var(--bg3); }
    .dash-tab.active { color: var(--gold); }

    /* ── TABLE ── */
    .table-wrap { border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    thead th { padding: 10px 16px; text-align: left; font-size: var(--fs-xs); font-weight: var(--fw-medium); color: var(--text-faint); background: var(--bg2); border-bottom: 1px solid var(--border); }
    tbody tr { border-bottom: 1px solid var(--border); transition: background 0.1s; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: var(--bg2); }
    tbody td { padding: 12px 16px; font-size: var(--fs-sm); vertical-align: middle; }
    .td-name { font-weight: var(--fw-semibold); color: var(--text); }
    .td-sub { font-size: var(--fs-xs); color: var(--text-faint); margin-top: 1px; }
    .td-url a { font-size: var(--fs-xs); color: var(--text-faint); text-decoration: none; font-family: monospace; }
    .td-url a:hover { color: var(--gold); }
    .td-actions { display: flex; gap: 6px; align-items: center; }

    .badge { display: inline-flex; align-items: center; height: 20px; padding: 0 8px; border-radius: 100px; font-size: 0.65rem; font-weight: var(--fw-semibold); letter-spacing: 0.03em; text-transform: uppercase; }
    .badge-aktif { background: var(--success-dim); color: var(--success); }
    .badge-pasif { background: var(--bg3); color: var(--text-faint); }

    .empty-state { text-align: center; padding: 48px 24px; }
    .empty-state-icon { font-size: 2rem; margin-bottom: 12px; }
    .empty-state-title { font-size: var(--fs-sm); font-weight: var(--fw-semibold); color: var(--text-muted); margin-bottom: 6px; }
    .empty-state-sub { font-size: var(--fs-xs); color: var(--text-faint); margin-bottom: 16px; }

    /* ── ANALYTICS ── */
    .analytics-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 10px; }
    .analytics-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 16px; display: flex; align-items: center; justify-content: space-between; }
    .analytics-info-name { font-size: var(--fs-sm); font-weight: var(--fw-semibold); }
    .analytics-info-tip { font-size: var(--fs-xs); color: var(--text-faint); margin-top: 2px; }
    .analytics-count { font-size: 1.5rem; font-weight: var(--fw-bold); color: var(--gold); letter-spacing: -0.04em; }

    /* ── EXCEL SECTION ── */
    .excel-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 24px; max-width: 480px; }
    .excel-card h3 { font-size: var(--fs-base); font-weight: var(--fw-semibold); margin-bottom: 6px; }
    .excel-card p { font-size: var(--fs-sm); color: var(--text-muted); margin-bottom: 20px; line-height: 1.6; }
    .form-group { margin-bottom: 14px; }
    .form-group label { display: block; font-size: var(--fs-xs); color: var(--text-muted); margin-bottom: 6px; }
    .form-group input[type="file"] { font-size: var(--fs-sm); color: var(--text-muted); }

    /* ── SLIDE-IN PANEL ── */
    .panel-overlay {
      position: fixed; inset: 0; z-index: 200;
      background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
      opacity: 0; pointer-events: none; transition: opacity 0.2s;
    }
    .panel-overlay.open { opacity: 1; pointer-events: all; }

    .slide-panel {
      position: fixed; top: 0; right: 0; bottom: 0; z-index: 201;
      width: 440px; max-width: 100vw;
      background: var(--bg2); border-left: 1px solid var(--border);
      display: flex; flex-direction: column;
      transform: translateX(100%); transition: transform 0.3s cubic-bezier(0.16,1,0.3,1);
      overflow: hidden;
    }
    .panel-overlay.open .slide-panel { transform: translateX(0); }

    .slide-header {
      padding: 20px 24px 16px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
    }
    .slide-title { font-size: var(--fs-base); font-weight: var(--fw-semibold); color: var(--text); }
    .slide-close {
      width: 28px; height: 28px; border-radius: 6px;
      background: var(--bg3); border: 1px solid var(--border);
      color: var(--text-muted); cursor: pointer; font-size: 1rem;
      display: flex; align-items: center; justify-content: center; transition: all 0.15s;
    }
    .slide-close:hover { background: var(--border); color: var(--text); }

    .slide-body { flex: 1; overflow-y: auto; padding: 20px 24px; }
    .slide-footer { padding: 16px 24px; border-top: 1px solid var(--border); display: flex; gap: 8px; flex-shrink: 0; }

    /* ── FORM ── */
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
    .form-col { display: flex; flex-direction: column; gap: 12px; }
    .field { display: flex; flex-direction: column; gap: 5px; }
    .field label { font-size: var(--fs-xs); color: var(--text-muted); }
    .field input, .field textarea, .field select {
      background: var(--bg3); border: 1px solid var(--border); color: var(--text);
      border-radius: 7px; padding: 8px 12px; font-size: var(--fs-sm); font-family: inherit;
      transition: border-color 0.15s, box-shadow 0.15s; outline: none;
    }
    .field input:focus, .field textarea:focus {
      border-color: var(--gold); box-shadow: 0 0 0 3px rgba(200,168,75,0.1);
    }
    .field input::placeholder, .field textarea::placeholder { color: var(--text-faint); }
    .field textarea { resize: vertical; min-height: 72px; }
    .field-full { grid-column: 1 / -1; }
    .field-sep { grid-column: 1 / -1; border: none; border-top: 1px solid var(--border); margin: 4px 0; }
    .field-section { grid-column: 1 / -1; font-size: var(--fs-xs); font-weight: var(--fw-semibold); color: var(--text-faint); text-transform: uppercase; letter-spacing: 0.08em; padding-top: 4px; }

    .btn-submit { flex: 1; height: 40px; background: var(--gold); border: none; border-radius: 8px; font-size: var(--fs-sm); font-weight: var(--fw-semibold); color: #000; cursor: pointer; font-family: inherit; transition: background 0.15s; }
    .btn-submit:hover { background: var(--gold-light); }
    .btn-cancel { height: 40px; padding: 0 16px; background: transparent; border: 1px solid var(--border); border-radius: 8px; font-size: var(--fs-sm); color: var(--text-muted); cursor: pointer; font-family: inherit; transition: all 0.15s; }
    .btn-cancel:hover { border-color: var(--border-gold); color: var(--text); }

    @media (max-width: 640px) {
      .stat-row { grid-template-columns: 1fr 1fr; }
      .dash-tabs { flex-wrap: wrap; }
      .slide-panel { width: 100vw; }
      .form-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav class="dash-nav">
  <a href="/" class="nav-logo">NFC<em>Kartify</em></a>
  <span class="nav-center"><%= firma.ad %></span>
  <div class="nav-right">
    <form method="POST" action="/firma/cikis" style="margin:0">
      <button type="submit" class="btn btn-ghost">Çıkış</button>
    </form>
  </div>
</nav>

<!-- FLASH -->
<% if (success && success.length) { %>
  <div class="flash-bar flash-success">✓ <%= success[0] %></div>
<% } %>
<% if (error && error.length) { %>
  <div class="flash-bar flash-error">✕ <%= error[0] %></div>
<% } %>

<!-- MAIN -->
<div class="dash-main">

  <!-- HEADER -->
  <div class="dash-header">
    <div>
      <div class="dash-title">Hoş geldiniz</div>
      <div class="dash-subtitle"><%= firma.yetkili_email %></div>
    </div>
    <button class="btn btn-gold" onclick="openSlide()">+ Yeni Çalışan</button>
  </div>

  <!-- STATS -->
  <div class="stat-row">
    <div class="stat-card">
      <div class="stat-card-n"><%= aktifSayisi + pasifSayisi %></div>
      <div class="stat-card-l">Toplam çalışan</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-n"><%= aktifSayisi %></div>
      <div class="stat-card-l">Aktif profil</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-n"><%= pasifSayisi %></div>
      <div class="stat-card-l">Pasif profil</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-n"><%= toplamGoruntulenme %></div>
      <div class="stat-card-l">Toplam görüntülenme</div>
    </div>
  </div>

  <!-- TABS -->
  <div class="dash-tabs">
    <a href="/?tab=calisanlar" class="dash-tab <%= tab === 'calisanlar' ? 'active' : '' %>">Çalışanlar</a>
    <a href="/?tab=istatistik" class="dash-tab <%= tab === 'istatistik' ? 'active' : '' %>">İstatistik</a>
    <a href="/?tab=analytics"  class="dash-tab <%= tab === 'analytics'  ? 'active' : '' %>">Link Analytics</a>
    <a href="/?tab=excel"      class="dash-tab <%= tab === 'excel'      ? 'active' : '' %>">Excel Yükle</a>
    <% if (firma.paket === 'kurumsal') { %>
    <a href="/?tab=icerik" class="dash-tab <%= tab === 'icerik' ? 'active' : '' %>">İçerik</a>
    <a href="/?tab=raf"    class="dash-tab <%= tab === 'raf'    ? 'active' : '' %>">Raf Kartları</a>
    <a href="/?tab=saha"   class="dash-tab <%= tab === 'saha'   ? 'active' : '' %>">Saha İstatistikleri</a>
    <% } %>
  </div>

  <!-- TAB: ÇALIŞANLAR -->
  <% if (tab === 'calisanlar') { %>
    <% const aktifCalisanlar = calisanlar.filter(c => c.durum === 'aktif'); %>
    <% const pasifCalisanlar = calisanlar.filter(c => c.durum === 'pasif'); %>
    <% if (aktifCalisanlar.length) { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Ad Soyad</th>
            <th>Unvan / Departman</th>
            <th>Profil URL</th>
            <th>Durum</th>
            <th>İşlem</th>
          </tr>
        </thead>
        <tbody>
          <% aktifCalisanlar.forEach(c => { %>
          <tr>
            <td>
              <div class="td-name"><%= c.ad %> <%= c.soyad %></div>
            </td>
            <td>
              <div style="font-size:var(--fs-xs);color:var(--text-muted)"><%= c.unvan || '—' %></div>
              <div class="td-sub"><%= c.departman || '' %></div>
            </td>
            <td class="td-url">
              <a href="/<%= firma.slug %>/<%= c.slug %>" target="_blank">/<%= firma.slug %>/<%= c.slug %></a>
            </td>
            <td>
              <span class="badge badge-<%= c.durum %>"><%= c.durum %></span>
              <% if (!c.onayli) { %>
                <div style="margin-top:6px">
                  <span style="color:#b45309;font-size:12px">⏳ Onay Bekliyor</span>
                  <form method="POST" action="/firma/panel/calisan/<%= c.id %>/onayla" style="display:inline">
                    <button type="submit" class="btn btn-gold btn-sm">Onayla</button>
                  </form>
                </div>
              <% } %>
            </td>
            <td>
              <div class="td-actions">
                <% if (!c.foto_url) { %>
                  <button class="btn btn-sm" style="background:#b45309;color:#fff;border:none" onclick='openSlideEdit(<%- JSON.stringify(c) %>)'>📷 Fotoğraf Ekle</button>
                <% } %>
                <button class="btn btn-border btn-sm" onclick='openSlideEdit(<%- JSON.stringify(c) %>)'>Düzenle</button>
                <form method="POST" action="/firma/panel/<%= c.id %>/durum" style="margin:0">
                  <input type="hidden" name="_method" value="PATCH">
                  <input type="hidden" name="durum" value="<%= c.durum === 'aktif' ? 'pasif' : 'aktif' %>">
                  <button type="submit" class="btn btn-danger-sm btn-sm"><%= c.durum === 'aktif' ? 'Pasife Al' : 'Aktif Et' %></button>
                </form>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else if (!pasifCalisanlar.length) { %>
    <div class="table-wrap">
      <div class="empty-state">
        <div class="empty-state-icon">👤</div>
        <div class="empty-state-title">Henüz çalışan yok</div>
        <div class="empty-state-sub">İlk çalışanı ekleyerek başlayın</div>
        <button class="btn btn-gold" onclick="openSlide()">+ Yeni Çalışan Ekle</button>
      </div>
    </div>
    <% } %>

    <% if (pasifCalisanlar.length) { %>
    <details class="table-wrap" style="padding:0">
      <summary style="cursor:pointer;padding:14px 20px;font-weight:600;color:var(--text-muted)">Pasif Çalışanlar (<%= pasifCalisanlar.length %>)</summary>
      <table>
        <thead>
          <tr>
            <th>Ad Soyad</th>
            <th>Unvan / Departman</th>
            <th>Profil URL</th>
            <th>Durum</th>
            <th>İşlem</th>
          </tr>
        </thead>
        <tbody>
          <% pasifCalisanlar.forEach(c => { %>
          <tr>
            <td>
              <div class="td-name"><%= c.ad %> <%= c.soyad %></div>
            </td>
            <td>
              <div style="font-size:var(--fs-xs);color:var(--text-muted)"><%= c.unvan || '—' %></div>
              <div class="td-sub"><%= c.departman || '' %></div>
            </td>
            <td class="td-url">
              <a href="/<%= firma.slug %>/<%= c.slug %>" target="_blank">/<%= firma.slug %>/<%= c.slug %></a>
            </td>
            <td>
              <span class="badge badge-<%= c.durum %>"><%= c.durum %></span>
            </td>
            <td>
              <div class="td-actions">
                <% if (!c.foto_url) { %>
                  <button class="btn btn-sm" style="background:#b45309;color:#fff;border:none" onclick='openSlideEdit(<%- JSON.stringify(c) %>)'>📷 Fotoğraf Ekle</button>
                <% } %>
                <button class="btn btn-border btn-sm" onclick='openSlideEdit(<%- JSON.stringify(c) %>)'>Düzenle</button>
                <form method="POST" action="/firma/panel/<%= c.id %>/durum" style="margin:0">
                  <input type="hidden" name="_method" value="PATCH">
                  <input type="hidden" name="durum" value="aktif">
                  <button type="submit" class="btn btn-danger-sm btn-sm">Aktif Et</button>
                </form>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </details>
    <% } %>

  <!-- TAB: İSTATİSTİK -->
  <% } else if (tab === 'istatistik') { %>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Ad Soyad</th><th>Görüntülenme</th><th>Durum</th><th>Kart</th></tr></thead>
        <tbody>
          <% [...calisanlar].sort((a,b) => (b.goruntuleme_sayisi||0) - (a.goruntuleme_sayisi||0)).forEach(c => { %>
          <tr>
            <td class="td-name"><%= c.ad %> <%= c.soyad %></td>
            <td style="font-weight:var(--fw-semibold);color:var(--gold)"><%= c.goruntuleme_sayisi || 0 %></td>
            <td><span class="badge badge-<%= c.durum %>"><%= c.durum %></span></td>
            <td>
              <% if (c.karta_yazildi) { %>
                <span style="color:#2e7d32;font-weight:600">✓ Yazıldı<%= c.kart_kilitli ? ' 🔒' : '' %></span>
                <form method="POST" action="/kurumsal/calisan/<%= c.id %>/kart-isaretle" style="display:inline">
                  <input type="hidden" name="yazildi" value="false">
                  <button type="submit">Kaldır</button>
                </form>
              <% } else { %>
                <span style="color:#9ca3af">○ Yazılmadı</span>
                <form method="POST" action="/kurumsal/calisan/<%= c.id %>/kart-isaretle" style="display:inline">
                  <input type="hidden" name="yazildi" value="true">
                  <button type="submit">Yazıldı işaretle</button>
                </form>
              <% } %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

  <!-- TAB: ANALYTICS -->
  <% } else if (tab === 'analytics') { %>
    <% if (linkAnalytics.length) { %>
    <div class="analytics-grid">
      <% linkAnalytics.forEach(row => { %>
      <div class="analytics-card">
        <div>
          <div class="analytics-info-name"><%= row.ad %> <%= row.soyad %></div>
          <div class="analytics-info-tip"><%= row.tip %></div>
        </div>
        <div class="analytics-count"><%= row.sayi %></div>
      </div>
      <% }); %>
    </div>
    <% } else { %>
    <div class="table-wrap">
      <div class="empty-state">
        <div class="empty-state-icon">📊</div>
        <div class="empty-state-title">Henüz tıklama verisi yok</div>
        <div class="empty-state-sub">Profil linkleri tıklandıkça burada görünür</div>
      </div>
    </div>
    <% } %>

  <!-- TAB: EXCEL -->
  <% } else if (tab === 'excel') { %>
    <div class="excel-card">
