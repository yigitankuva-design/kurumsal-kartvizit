<!-- Employee data for edit -->
<script>
  function temaUygula(tema) {
    document.documentElement.setAttribute('data-theme', tema);
    const ay = document.getElementById('temaIkonAy');
    const gunes = document.getElementById('temaIkonGunes');
    if (ay) ay.style.display = tema === 'dark' ? '' : 'none';
    if (gunes) gunes.style.display = tema === 'light' ? '' : 'none';
  }

  function temaDegistir() {
    const mevcut = document.documentElement.getAttribute('data-theme') || 'dark';
    const yeni = mevcut === 'light' ? 'dark' : 'light';
    try { localStorage.setItem('nfck-tema', yeni); } catch (e) {}
    temaUygula(yeni);
    if (window.isikGorselUygulaYenile) window.isikGorselUygulaYenile();
  }

  temaUygula(document.documentElement.getAttribute('data-theme') || 'dark');

  /* ── GÖRÜNÜM: vurgu rengi seçici (SV kare + ton çubuğu) + ışık derecesi ── */
  (function () {
    var gorunumBtn = document.querySelector('.gorunum-ctl-wrap');
    if (!gorunumBtn) return;

    var GOLD_TABAN_HEX = <%- JSON.stringify(firma.tema_renk || '#c8a84b') %>;
    var ISIK_TABAN = <%- Number(firma.tema_isik_seviyesi) || 50 %>;

    function hexToHsv(hex) {
      var r = parseInt(hex.slice(1, 3), 16) / 255;
      var g = parseInt(hex.slice(3, 5), 16) / 255;
      var b = parseInt(hex.slice(5, 7), 16) / 255;
      var max = Math.max(r, g, b), min = Math.min(r, g, b), d = max - min;
      var h = 0;
      if (d !== 0) {
        if (max === r) h = 60 * (((g - b) / d) % 6);
        else if (max === g) h = 60 * ((b - r) / d + 2);
        else h = 60 * ((r - g) / d + 4);
      }
      if (h < 0) h += 360;
      var s = max === 0 ? 0 : d / max;
      return { h: h, s: s * 100, v: max * 100 };
    }

    function hsvToHex(h, s, v) {
      s = s / 100; v = v / 100;
      var c = v * s, x = c * (1 - Math.abs((h / 60) % 2 - 1)), m = v - c;
      var r, g, b;
      if (h < 60) { r = c; g = x; b = 0; }
      else if (h < 120) { r = x; g = c; b = 0; }
      else if (h < 180) { r = 0; g = c; b = x; }
      else if (h < 240) { r = 0; g = x; b = c; }
      else if (h < 300) { r = x; g = 0; b = c; }
      else { r = c; g = 0; b = x; }
      var toHex = function (n) { n = Math.round((n + m) * 255); return n.toString(16).padStart(2, '0'); };
      return '#' + toHex(r) + toHex(g) + toHex(b);
    }

    var hsvDurum = hexToHsv(GOLD_TABAN_HEX);
    var kaydetZamanlayici = null;

    function gorunumPopToggle() {
      document.getElementById('gorunumPop').classList.toggle('open');
    }
    window.gorunumPopToggle = gorunumPopToggle;

    document.addEventListener('click', function (e) {
      if (!gorunumBtn.contains(e.target)) document.getElementById('gorunumPop').classList.remove('open');
    });

    function vurguRengiUygula(kaydet) {
      var hex = hsvToHex(hsvDurum.h, hsvDurum.s, hsvDurum.v);
      var kok = document.documentElement.style;
      kok.setProperty('--gold', hex);
      kok.setProperty('--gold-light', 'color-mix(in srgb, white 22%, ' + hex + ')');
      kok.setProperty('--gold-dim', 'color-mix(in srgb, ' + hex + ' 10%, transparent)');
      kok.setProperty('--border-gold', 'color-mix(in srgb, ' + hex + ' 32%, transparent)');
      kok.setProperty('--gold-glow', 'color-mix(in srgb, ' + hex + ' 35%, transparent)');
      document.getElementById('colorSwatch').style.background = hex;
      document.getElementById('colorHex').textContent = hex.toUpperCase();
      document.getElementById('svHandle').style.left = hsvDurum.s + '%';
      document.getElementById('svHandle').style.bottom = hsvDurum.v + '%';
      document.getElementById('svHueLayer').style.background = 'hsl(' + hsvDurum.h + ',100%,50%)';
      document.getElementById('hueHandle').style.left = (hsvDurum.h / 360 * 100) + '%';
      document.getElementById('hueHandle').style.background = 'hsl(' + hsvDurum.h + ',100%,50%)';
      if (kaydet) temaKaydetGecikmeli(hex, Number(document.getElementById('lightSlider').value));
    }

    function svSurukle(e) {
      var rect = document.getElementById('svSquare').getBoundingClientRect();
      var x = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
      var y = Math.max(0, Math.min(1, (e.clientY - rect.top) / rect.height));
      hsvDurum.s = x * 100;
      hsvDurum.v = (1 - y) * 100;
      vurguRengiUygula(true);
    }

    function hueSurukle(e) {
      var rect = document.getElementById('hueStrip').getBoundingClientRect();
      var x = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
      hsvDurum.h = x * 360;
      vurguRengiUygula(true);
    }

    function surukleBagla(el, handler) {
      el.addEventListener('pointerdown', function (e) {
        el.setPointerCapture(e.pointerId);
        handler(e);
        var move = function (ev) { handler(ev); };
        var up = function () {
          document.removeEventListener('pointermove', move);
          document.removeEventListener('pointerup', up);
        };
        document.addEventListener('pointermove', move);
        document.addEventListener('pointerup', up);
      });
    }
    surukleBagla(document.getElementById('svSquare'), svSurukle);
    surukleBagla(document.getElementById('hueStrip'), hueSurukle);

    function isikGorselUygula(deger) {
      deger = Number(deger);
      document.getElementById('lightVal').textContent = deger;
      var pct = Math.abs(deger - 50) * 1.6;
      var yon = deger >= 50 ? 'white' : 'black';
      var tabanlar = (document.documentElement.getAttribute('data-theme') || 'dark') === 'dark'
        ? { bg: '#1c1c20', bg2: '#222227', bg3: '#28282e', bg4: '#2e2e35' }
        : { bg: '#f7f5f0', bg2: '#ffffff', bg3: '#eeece3', bg4: '#e4e1d5' };
      var kok = document.documentElement.style;
      Object.keys(tabanlar).forEach(function (k) {
        kok.setProperty('--' + k, 'color-mix(in srgb, ' + yon + ' ' + pct + '%, ' + tabanlar[k] + ')');
      });
    }

    function isikDerecesiUygula(deger) {
      isikGorselUygula(deger);
      var hex = hsvToHex(hsvDurum.h, hsvDurum.s, hsvDurum.v);
      temaKaydetGecikmeli(hex, Number(deger));
    }
    window.isikDerecesiUygula = isikDerecesiUygula;

    function temaKaydetGecikmeli(renk, isikSeviyesi) {
      clearTimeout(kaydetZamanlayici);
      var durumEl = document.getElementById('gorunumKaydetDurum');
      durumEl.textContent = '';
      kaydetZamanlayici = setTimeout(function () {
        durumEl.textContent = 'Kaydediliyor...';
        fetch('/firma/panel/tema', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: 'renk=' + encodeURIComponent(renk) + '&isikSeviyesi=' + encodeURIComponent(isikSeviyesi)
        }).then(function (res) {
          durumEl.textContent = res.ok ? 'Kaydedildi' : 'Kaydedilemedi';
          setTimeout(function () { durumEl.textContent = ''; }, 2000);
        }).catch(function () { durumEl.textContent = 'Bağlantı hatası'; });
      }, 500);
    }

    document.getElementById('lightSlider').value = ISIK_TABAN;
    document.getElementById('lightVal').textContent = ISIK_TABAN;
    vurguRengiUygula(false);
    isikGorselUygula(ISIK_TABAN);
    window.isikGorselUygulaYenile = function () { isikGorselUygula(document.getElementById('lightSlider').value); };
  })();

  function formYukleniyorGoster(form, metin) {
    const btn = form.querySelector('button[type="submit"]');
    if (!btn || btn.disabled) return true;
    btn.dataset.orijinalMetin = btn.textContent;
    btn.disabled = true;
    btn.textContent = metin || 'Kaydediliyor...';
    return true;
  }

  function elOlustur(etiket, metin, stiller) {
    const el = document.createElement(etiket);
    if (metin !== undefined) el.textContent = metin;
    if (stiller) Object.assign(el.style, stiller);
    return el;
  }

  async function eczaneIslemGonder(idler, islem) {
    if (islem === 'sil' && !confirm(idler.length + ' eczane silinsin mi? Okutma geçmişi de silinir.')) return;
    if (islem === 'pasife-al' && !confirm(idler.length + ' eczane pasife alınsın mı?')) return;
    sessionStorage.setItem('eczaneScrollY', String(window.scrollY));
    try {
      const res = await fetch('/kurumsal/eczane/toplu-islem', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ idler, islem }),
      });
      if (res.ok) {
        window.location.reload();
      } else {
        alert('İşlem başarısız.');
      }
    } catch (err) {
      alert('Bağlantı hatası.');
    }
  }

  function eczaneTekIslem(id, islem) {
    eczaneIslemGonder([id], islem);
  }

  function eczaneSecilenler() {
    return [...document.querySelectorAll('.eczane-sec:checked')].map(el => Number(el.value));
  }

  function eczaneTopluIslem(islem) {
    const idler = eczaneSecilenler();
    if (!idler.length) return;
    eczaneIslemGonder(idler, islem);
  }

  function eczaneTumSecToggle(kaynak) {
    document.querySelectorAll('.eczane-sec').forEach(el => { el.checked = kaynak.checked; });
    eczaneToplaButonDurumu();
  }

  function eczaneToplaButonDurumu() {
    const varMi = eczaneSecilenler().length > 0;
    ['eczaneTopluOnaylaBtn', 'eczaneTopluPasifBtn', 'eczaneTopluSilBtn'].forEach(id => {
      const btn = document.getElementById(id);
      if (btn) btn.disabled = !varMi;
    });
  }

  document.addEventListener('change', (e) => {
    if (e.target.classList && e.target.classList.contains('eczane-sec')) eczaneToplaButonDurumu();
  });

  // 'load' kullanılıyor ('DOMContentLoaded' değil): tablo tam yerleşmeden
  // scrollTo hedefe ulaşamayabilir.
  window.addEventListener('load', () => {
    const kayitliScroll = sessionStorage.getItem('eczaneScrollY');
    if (kayitliScroll !== null) {
      window.scrollTo(0, Number(kayitliScroll));
      sessionStorage.removeItem('eczaneScrollY');
    }
  });

  function eczaneYonetimAc(eczaneId) {
    const tpl = document.getElementById('ecTpl-' + eczaneId);
    if (!tpl) return;
    const body = document.getElementById('ecYonetimBody');
    body.innerHTML = '';
    body.appendChild(tpl.content.cloneNode(true));
    document.getElementById('ecYonetimAd').textContent = tpl.dataset.ad || 'Eczane';
    document.getElementById('ecYonetimOverlay').classList.add('open');
  }
  function ecYonetimKapat() {
    document.getElementById('ecYonetimOverlay').classList.remove('open');
  }

  var _aramaZamanlayici = null;
  function aramaOtomatikGonder(input) {
    clearTimeout(_aramaZamanlayici);
    _aramaZamanlayici = setTimeout(function () { input.form.submit(); }, 400);
  }

  function listeToggle(id, btnId, gosterMetin, gizleMetin) {
    var el = document.getElementById(id), btn = document.getElementById(btnId);
    if (!el) return;
    var acik = el.style.display !== 'none';
    el.style.display = acik ? 'none' : 'block';
    if (btn) btn.textContent = acik ? gosterMetin : gizleMetin;
  }
  function hucreDeger(td) {
    if (!td) return '';
    var t = td.getAttribute('data-sirala'); if (t == null) t = td.textContent.trim();
    var n = parseFloat(String(t).replace(/[^\d.,-]/g, '').replace(/\./g, '').replace(/,/g, '.'));
    return isNaN(n) ? String(t).toLocaleLowerCase('tr') : n;
  }
  function tabloSirala(th) {
    var tablo = th.closest('table'); if (!tablo) return;
    var basliklar = th.parentNode.children;
    var idx = Array.prototype.indexOf.call(basliklar, th);
    var tbody = tablo.tBodies[0]; if (!tbody) return;
    var yon = th.getAttribute('data-yon') === 'desc' ? 'asc' : 'desc';
    Array.prototype.forEach.call(basliklar, function (h) { h.removeAttribute('data-yon'); var o = h.querySelector('.sok'); if (o) o.remove(); });
    th.setAttribute('data-yon', yon);
    var satirlar = Array.prototype.slice.call(tbody.rows);
    satirlar.sort(function (a, b) { var av = hucreDeger(a.cells[idx]), bv = hucreDeger(b.cells[idx]); if (av < bv) return yon === 'asc' ? -1 : 1; if (av > bv) return yon === 'asc' ? 1 : -1; return 0; });
    satirlar.forEach(function (r) { tbody.appendChild(r); });
    var ok = document.createElement('span'); ok.className = 'sok'; ok.textContent = yon === 'asc' ? ' ▲' : ' ▼'; th.appendChild(ok);
  }

  async function eczaneDetayGoster(eczaneId, eczaneAdi) {
    document.getElementById('eczaneDetayBaslik').textContent = eczaneAdi + ' — Detay';
    const icerik = document.getElementById('eczaneDetayIcerik');
    icerik.textContent = 'Yükleniyor...';
    document.getElementById('eczaneDetayModal').style.display = 'flex';
    try {
      const res = await fetch('/kurumsal/eczane/' + eczaneId + '/detay');
      const veri = await res.json();
      icerik.textContent = '';
      if (!res.ok) {
        icerik.textContent = veri.error || 'Detay alınamadı.';
        return;
      }
      icerik.appendChild(elOlustur('p', 'Toplam okutma: ' + veri.okutma_sayisi));
      icerik.appendChild(elOlustur('p', 'Yaklaşık farklı kişi: ' + veri.farkli_kisi_tahmini));
      icerik.appendChild(elOlustur('p', 'PDF açılma: ' + veri.pdf_acilma_sayisi));

      icerik.appendChild(elOlustur('p', 'Tıklama dağılımı:', { marginTop: '10px', fontWeight: '700' }));
      const tiklamaListesi = document.createElement('ul');
      Object.keys(veri.tiklama_dagilimi).forEach(function(tip) {
        tiklamaListesi.appendChild(elOlustur('li', tip + ': ' + veri.tiklama_dagilimi[tip]));
      });
      icerik.appendChild(tiklamaListesi);

      if (veri.ziyaret_etkisi.length) {
        icerik.appendChild(elOlustur('p', 'Ziyaret etkisi:', { marginTop: '10px', fontWeight: '700' }));
        const ziyaretListesi = document.createElement('ul');
        veri.ziyaret_etkisi.forEach(function(z) {
          const tarih = new Date(z.ziyaret_tarihi).toLocaleDateString('tr-TR');
          ziyaretListesi.appendChild(elOlustur('li', tarih + ' ziyaretinden sonra ' + z.sonraki_okutma_sayisi + ' okutma'));
        });
        icerik.appendChild(ziyaretListesi);
      }
    } catch (err) {
      icerik.textContent = 'Detay alınamadı.';
    }
  }

  const overlay = document.getElementById('panelOverlay');
  let editId = null;

  function govdeKilitle() {
    var barGenislik = window.innerWidth - document.documentElement.clientWidth;
    document.body.style.paddingRight = barGenislik + 'px';
    document.body.style.overflow = 'hidden';
  }
  function govdeSerbest() {
    document.body.style.overflow = '';
    document.body.style.paddingRight = '';
  }

  function openSlide() {
    editId = null;
    document.getElementById('slideTitle').textContent = 'Yeni Çalışan';
    document.getElementById('slideForm').action = '/firma/panel/ekle';
    document.getElementById('formMethod').value = '';
    document.getElementById('createOnlyFields').style.display = 'contents';
    document.getElementById('f_kvkk').required = true;
    clearForm();
    overlay.classList.add('open');
    govdeKilitle();
  }

  function openSlideEdit(c) {
    editId = c.id;
    document.getElementById('slideTitle').textContent = 'Çalışan Düzenle';
    document.getElementById('slideForm').action = `/firma/panel/${c.id}/duzenle`;
    document.getElementById('formMethod').value = 'PUT';
    document.getElementById('createOnlyFields').style.display = 'none';
    document.getElementById('f_kvkk').required = false;
    fillForm(c);
    document.getElementById('f_foto').value = '';
    const amiriSelect = document.getElementById('f_amiri_id');
    if (amiriSelect) {
      // kendisini seçenekler arasından gizle (kendine bağlı olamaz)
      Array.from(amiriSelect.options).forEach(opt => {
        opt.style.display = opt.value === String(c.id) ? 'none' : '';
      });
      amiriSelect.value = c.amiri_id || '';
    }
    const ekipKutu = document.getElementById('f_ekip_yoneticisi');
    if (ekipKutu) ekipKutu.checked = !!c.ekip_yoneticisi;
    overlay.classList.add('open');
    govdeKilitle();
  }

  function closeSlide() {
    overlay.classList.remove('open');
    govdeSerbest();
  }

  function closeSlideOutside(e) {
    if (e.target === overlay) closeSlide();
  }

  let detayCalisan = null;
  function calisanDetayGoster(e, c) {
    if (e.target.closest('button, a, form')) return;
    detayCalisan = c;
    document.getElementById('detayAvatar').textContent = (c.ad[0] || '') + (c.soyad[0] || '');
    document.getElementById('detayAd').textContent = c.ad + ' ' + c.soyad;
    document.getElementById('detaySub').textContent = [c.unvan, c.departman].filter(Boolean).join(' · ') || '—';
    document.getElementById('detayEmail').textContent = c.email || '—';
    document.getElementById('detayTelefon').textContent = c.telefon || '—';
    document.getElementById('detayGoruntulenme').textContent = c.goruntuleme_sayisi != null ? c.goruntuleme_sayisi : '—';
    document.getElementById('detayLink').textContent = '/' + <%- JSON.stringify(firma.slug) %> + '/' + c.slug;
    document.getElementById('detayOverlay').classList.add('open');
  }

  function calisanDetayKapat() {
    document.getElementById('detayOverlay').classList.remove('open');
  }

  function calisanDetayDuzenle() {
    if (!detayCalisan) return;
    calisanDetayKapat();
    openSlideEdit(detayCalisan);
  }

  function submitSlide() {
    const btn = document.getElementById('slideKaydetBtn');
    if (btn && !btn.disabled) {
      btn.disabled = true;
      btn.textContent = 'Kaydediliyor...';
    }
    document.getElementById('slideForm').submit();
  }

  function clearForm() {
    ['ad','soyad','unvan','departman','telefon','email','linkedin','instagram','twitter','website','biyografi','foto','giris_email','giris_sifre','amiri_id'].forEach(f => {
      const el = document.getElementById('f_' + f);
      if (el) el.value = '';
    });
    document.getElementById('f_kvkk').checked = false;
    const ekipKutu = document.getElementById('f_ekip_yoneticisi');
    if (ekipKutu) ekipKutu.checked = false;
  }

  function fillForm(c) {
    const map = { ad:'ad', soyad:'soyad', unvan:'unvan', departman:'departman', telefon:'telefon', email:'email', linkedin:'linkedin', instagram:'instagram', twitter:'twitter', website:'website', biyografi:'biyografi', giris_email:'giris_email' };
    Object.entries(map).forEach(([field, key]) => {
      const el = document.getElementById('f_' + field);
      if (el) el.value = c[key] || '';
    });
  }

  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeSlide(); });

  function urunDuzenleAc(u) {
    document.getElementById('urunDuzenleForm').action = '/kurumsal/urunler/' + u.id;
    document.getElementById('urunDuzenleAd').value = u.ad;
    document.getElementById('urunDuzenleAciklama').value = u.aciklama || '';
    document.getElementById('urunDuzenleAktifKutu').checked = u.aktif;
    document.getElementById('urunDuzenleAktifGizli').value = u.aktif ? 'true' : 'false';
    document.getElementById('urunDuzenleFotoInput').value = '';
    document.getElementById('urunDuzenleModal').style.display = 'flex';
  }
</script>
<script src="/js/foto-kirpici.js"></script>
<script>
  fotoKirpiciBaglama('logoInput');
  fotoKirpiciBaglama('f_foto');
  fotoKirpiciBaglama('urunFotoInput');
  fotoKirpiciBaglama('urunDuzenleFotoInput');
</script>
