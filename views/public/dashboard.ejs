<!DOCTYPE html>
<html lang="tr" data-theme="dark">
<head>
  <script>(function(){try{var t=localStorage.getItem('nfck-tema');if(t==='light'||t==='dark')document.documentElement.setAttribute('data-theme',t);}catch(e){}})();</script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NFCKartify — <%= firma.ad %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --fs-xs: 0.72rem;
      --fs-sm: 0.8rem;
      --fs-base: 0.875rem;
      --fw-normal: 400;
      --fw-medium: 500;
      --fw-semibold: 600;
      --fw-bold: 700;
    }
    :root[data-theme="dark"] {
      --bg: #1c1c20;
      --bg2: #222227;
      --bg3: #28282e;
      --bg4: #2e2e35;
      --border: rgba(255,255,255,0.07);
      --border-gold: rgba(200,168,75,0.3);
      --gold: #c8a84b;
      --gold-light: #e5c46a;
      --gold-dim: rgba(200,168,75,0.1);
      --text: #f1f0ee;
      --text-muted: #888880;
      --text-faint: #444440;
      --danger: #ef4444;
      --danger-dim: rgba(239,68,68,0.1);
      --success: #22c55e;
      --success-dim: rgba(34,197,94,0.1);
      --warning: #f59e0b;
      --warning-dim: rgba(245,158,11,0.1);
      --nav-bg: rgba(13,13,15,0.95);
      --btn-gold-text: #000;
      --gold-glow: rgba(200,168,75,0.35);
    }
    :root[data-theme="light"] {
      --bg: #f7f5f0;
      --bg2: #ffffff;
      --bg3: #eeece3;
      --bg4: #e4e1d5;
      --border: rgba(28,28,32,0.1);
      --border-gold: rgba(138,106,36,0.35);
      --gold: #8a6a24;
      --gold-light: #a17c2c;
      --gold-dim: rgba(138,106,36,0.1);
      --text: #1c1c20;
      --text-muted: #6b6a63;
      --text-faint: #6f6e66;
      --danger: #dc2626;
      --danger-dim: rgba(220,38,38,0.08);
      --success: #16a34a;
      --success-dim: rgba(22,163,74,0.08);
      --warning: #b45309;
      --warning-dim: rgba(180,83,9,0.08);
      --nav-bg: rgba(255,255,255,0.85);
      --btn-gold-text: #fff;
      --gold-glow: rgba(138,106,36,0.15);
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); font-size: var(--fs-base); line-height: 1.5; -webkit-font-smoothing: antialiased; overflow-x: hidden; transition: background 0.15s, color 0.15s; }

    /* ── NAV ── */
    .dash-nav {
      position: sticky; top: 0; z-index: 50;
      height: 52px; display: flex; align-items: center; justify-content: space-between;
      padding: 0 24px;
      background: var(--nav-bg); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo { font-size: var(--fs-base); font-weight: var(--fw-bold); color: var(--text); text-decoration: none; letter-spacing: -0.02em; }
    .nav-logo em { font-style: normal; color: var(--gold); }
    .nav-center { font-size: var(--fs-sm); color: var(--text-muted); font-weight: var(--fw-medium); }
    .nav-right { display: flex; align-items: center; gap: 8px; }

    /* ── APP SHELL (sidebar + main) ── */
    .app-shell { display: flex; min-height: 100vh; }
    .app-sidebar {
      width: 218px; flex-shrink: 0;
      background: var(--bg2); border-right: 1px solid var(--border);
      display: flex; flex-direction: column;
      position: sticky; top: 0; height: 100vh;
    }
    .sidebar-logo { font-size: var(--fs-base); font-weight: var(--fw-bold); letter-spacing: -0.02em; color: var(--text); text-decoration: none; padding: 18px 18px 14px; display: block; }
    .sidebar-logo em { font-style: normal; color: var(--gold); }
    .sidebar-nav { flex: 1; overflow-y: auto; padding: 6px 12px; }
    .sidebar-group-label { font-size: 10.5px; font-weight: var(--fw-semibold); color: var(--text-faint); text-transform: uppercase; letter-spacing: .05em; padding: 14px 8px 6px; }
    .sidebar-item {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 10px; border-radius: 7px; margin-bottom: 1px;
      color: var(--text-muted); font-size: var(--fs-sm); font-weight: var(--fw-medium);
      text-decoration: none; border-left: 2px solid transparent;
      transition: background .12s, color .12s;
    }
    .sidebar-item svg { width: 16px; height: 16px; flex-shrink: 0; opacity: .85; }
    .sidebar-item:hover { background: var(--bg3); color: var(--text); }
    .sidebar-item.active { background: var(--gold-dim); color: var(--gold); border-left-color: var(--gold); font-weight: var(--fw-semibold); }
    .sidebar-item.active svg { opacity: 1; }
    .sidebar-foot { padding: 12px 18px; border-top: 1px solid var(--border); display: flex; align-items: center; gap: 9px; }
    .sidebar-user-dot { width: 26px; height: 26px; border-radius: 50%; background: var(--bg4); color: var(--gold); display: flex; align-items: center; justify-content: center; font-weight: var(--fw-bold); font-size: 10.5px; flex-shrink: 0; }
    .sidebar-user-email { font-size: 11px; color: var(--text-faint); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    .app-main { flex: 1; min-width: 0; }
    .app-topbar {
      position: sticky; top: 0; z-index: 50; height: 52px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 24px; background: var(--nav-bg); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .breadcrumb { font-size: var(--fs-sm); color: var(--text-faint); }
    .breadcrumb b { color: var(--text); font-weight: var(--fw-semibold); }

    @media (max-width: 860px) {
      .app-shell { flex-direction: column; }
      .app-sidebar { width: 100%; height: auto; position: static; flex-direction: row; align-items: center; overflow-x: auto; }
      .sidebar-logo { padding: 10px 14px; flex-shrink: 0; }
      .sidebar-nav { display: flex; padding: 6px 8px; overflow-x: auto; flex: none; }
      .sidebar-group-label { display: none; }
      .sidebar-item { flex-shrink: 0; border-left: none; border-bottom: 2px solid transparent; }
      .sidebar-item.active { border-left-color: transparent; border-bottom-color: var(--gold); }
      .sidebar-foot { display: none; }
    }

    /* ── GÖRÜNÜM (renk seçici) ── */
    .gorunum-ctl-wrap { position: relative; }
    .gorunum-pop { position: absolute; top: calc(100% + 8px); right: 0; width: 260px; background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; box-shadow: 0 16px 40px rgba(0,0,0,0.35); padding: 16px; z-index: 300; display: none; }
    .gorunum-pop.open { display: block; }
    .gorunum-pop-label { font-size: var(--fs-xs); font-weight: var(--fw-semibold); color: var(--text-muted); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 9px; }
    .gorunum-pop-divider { height: 1px; background: var(--border); margin: 14px 0; }
    .sv-square { position: relative; width: 100%; height: 120px; border-radius: 8px; cursor: crosshair; border: 1px solid var(--border); overflow: hidden; touch-action: none; }
    .sv-hue-layer { position: absolute; inset: 0; }
    .sv-white-layer { position: absolute; inset: 0; background: linear-gradient(to right, #fff, rgba(255,255,255,0)); }
    .sv-black-layer { position: absolute; inset: 0; background: linear-gradient(to top, #000, rgba(0,0,0,0)); }
    .sv-handle { position: absolute; width: 14px; height: 14px; border-radius: 50%; border: 2px solid #fff; box-shadow: 0 0 0 1px rgba(0,0,0,.5), 0 1px 5px rgba(0,0,0,.4); transform: translate(-50%, 50%); pointer-events: none; }
    .hue-strip { position: relative; width: 100%; height: 12px; border-radius: 6px; margin-top: 10px; cursor: pointer; border: 1px solid var(--border); touch-action: none; background: linear-gradient(to right, #f00, #ff0, #0f0, #0ff, #00f, #f0f, #f00); }
    .hue-handle { position: absolute; top: 50%; width: 15px; height: 15px; border-radius: 50%; border: 2px solid #fff; box-shadow: 0 0 0 1px rgba(0,0,0,.5), 0 1px 5px rgba(0,0,0,.4); transform: translate(-50%, -50%); pointer-events: none; }
    .color-readout { display: flex; align-items: center; gap: 9px; margin-top: 12px; }
    .color-swatch { width: 26px; height: 26px; border-radius: 7px; border: 1px solid var(--border); flex-shrink: 0; }
    .color-hex { font-family: monospace; font-size: var(--fs-xs); color: var(--text-muted); }
    .light-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px; }
    .light-val { font-family: monospace; font-size: var(--fs-xs); color: var(--text); }
    .gorunum-slider { width: 100%; -webkit-appearance: none; appearance: none; height: 4px; border-radius: 3px; background: var(--bg4); outline: none; margin: 8px 0 2px; }
    .gorunum-slider::-webkit-slider-thumb { -webkit-appearance: none; width: 15px; height: 15px; border-radius: 50%; background: var(--gold); cursor: pointer; }
    .gorunum-slider::-moz-range-thumb { width: 15px; height: 15px; border-radius: 50%; background: var(--gold); border: none; cursor: pointer; }
    .gorunum-slider-ends { display: flex; justify-content: space-between; font-size: 10px; color: var(--text-faint); }
    .gorunum-save-status { font-size: 10.5px; color: var(--text-faint); margin-top: 10px; text-align: center; min-height: 14px; }

    /* ── BUTTONS ── */
    .btn { display: inline-flex; align-items: center; gap: 6px; height: 32px; padding: 0 14px; border-radius: 6px; font-size: var(--fs-sm); font-weight: var(--fw-medium); cursor: pointer; border: none; font-family: inherit; text-decoration: none; transition: all 0.15s; white-space: nowrap; }
    .btn-ghost { background: transparent; color: var(--text-muted); }
    .btn-ghost:hover { background: var(--bg3); color: var(--text); }
    .btn-gold { background: var(--gold); color: var(--btn-gold-text); font-weight: var(--fw-semibold); box-shadow: 0 0 16px rgba(200,168,75,0.2); }
    .btn-gold:hover { background: var(--gold-light); }
    .btn-border { background: transparent; color: var(--text-muted); border: 1px solid var(--border); }
    .btn-border:hover { border-color: var(--border-gold); color: var(--text); }
    .btn-danger-sm { background: var(--danger-dim); color: var(--danger); border: 1px solid rgba(239,68,68,0.2); }
    .btn-danger-sm:hover { background: rgba(239,68,68,0.18); }
    .btn-warning-sm { background: var(--warning-dim); color: var(--warning); border: 1px solid rgba(245,158,11,0.2); }
    .btn-warning-sm:hover { background: rgba(245,158,11,0.18); }
    .btn-sm { height: 28px; padding: 0 10px; font-size: var(--fs-xs); }
    .btn-link { background: none; border: none; padding: 0 4px; height: auto; color: var(--text-faint); text-decoration: none; }
    .btn-link:hover { color: var(--text-muted); text-decoration: underline; text-underline-offset: 2px; }

    /* ── FLASH ── */
    .flash-bar {
      padding: 10px 24px; font-size: var(--fs-sm); font-weight: var(--fw-medium);
      display: flex; align-items: center; gap: 8px;
    }
    .flash-success { background: var(--success-dim); color: var(--success); border-bottom: 1px solid rgba(34,197,94,0.15); }
    .flash-error { background: var(--danger-dim); color: var(--danger); border-bottom: 1px solid rgba(239,68,68,0.15); }

    /* ── MAIN LAYOUT ── */
    .dash-main { max-width: 1100px; margin: 0 auto; padding: 28px 24px 64px; }
    .dash-main.dash-main--wide { max-width: 1680px; }
    .ipucu { display: flex; align-items: flex-start; gap: 9px; background: var(--gold-dim); border: 1px solid var(--border-gold); border-radius: 10px; padding: 11px 15px; margin-bottom: 16px; font-size: 13px; color: var(--text); line-height: 1.5; }
    .ipucu .ipucu-ikon { flex: 0 0 auto; font-size: 15px; line-height: 1.3; }
    .ipucu b { color: var(--gold); }
    .nk-intro { color: var(--text-muted); margin: 0 0 20px; font-size: 14px; line-height: 1.6; max-width: 70ch; }
    .nk-list { display: flex; flex-direction: column; gap: 13px; }
    .nk-adim { display: flex; gap: 14px; align-items: flex-start; background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 15px 18px; }
    .nk-no { flex: 0 0 auto; width: 30px; height: 30px; border-radius: 50%; background: var(--gold); color: #fff; display: grid; place-items: center; font-weight: 800; font-size: 15px; }
    .nk-adim .nk-bas { font-size: 15px; font-weight: 700; color: var(--text); }
    .nk-adim p { margin: 5px 0 0; color: var(--text-muted); font-size: 13.5px; line-height: 1.65; }
    .nk-adim p b { color: var(--gold); font-weight: 700; }

    /* ── HEADER ── */
    .dash-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
    .dash-title { font-size: 1.125rem; font-weight: var(--fw-bold); color: var(--text); letter-spacing: -0.02em; }
    .dash-subtitle { font-size: var(--fs-xs); color: var(--text-faint); margin-top: 2px; }

    /* ── STAT CARDS ── */
    .stat-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 24px; }
    .stat-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 16px 18px; }
    .stat-card-n { font-size: 1.5rem; font-weight: var(--fw-bold); color: var(--gold); letter-spacing: -0.04em; text-shadow: 0 0 20px var(--gold-glow); font-variant-numeric: tabular-nums; }
    .stat-card-l { font-size: var(--fs-xs); color: var(--text-faint); margin-top: 2px; }

    /* ── TAB GROUPS ── */
    .dash-tabs-main { display: flex; gap: 4px; border-bottom: 1px solid var(--border); margin-bottom: 14px; }
    .dash-tab-main { padding: 8px 4px; margin-bottom: -1px; border-bottom: 2px solid transparent; font-size: var(--fs-sm); font-weight: var(--fw-semibold); color: var(--text-muted); text-decoration: none; transition: all 0.15s; white-space: nowrap; }
    .dash-tab-main:hover { color: var(--text); }
    .dash-tab-main.active { color: var(--gold); border-bottom-color: var(--gold); }

    /* ── TABS ── */
    .dash-tabs { display: flex; gap: 2px; background: var(--bg2); border: 1px solid var(--border); border-radius: 8px; padding: 3px; width: fit-content; margin-bottom: 20px; }
    .dash-tab { padding: 6px 16px; border-radius: 6px; font-size: var(--fs-xs); font-weight: var(--fw-medium); color: var(--text-muted); text-decoration: none; border: none; background: transparent; cursor: pointer; font-family: inherit; transition: all 0.15s; white-space: nowrap; }
    .dash-tab.active, .dash-tab:hover { color: var(--text); background: var(--bg3); }
    .dash-tab.active { color: var(--gold); }

    /* ── TABLE ── */
    .table-wrap { border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
    table { width: 100%; border-collapse: collapse; font-variant-numeric: tabular-nums; }
    thead th { padding: 10px 16px; text-align: left; font-size: 11px; font-weight: var(--fw-semibold); color: var(--text-faint); background: var(--bg2); border-bottom: 1px solid var(--border); text-transform: uppercase; letter-spacing: 0.04em; }
    tbody tr { border-bottom: 1px solid var(--border); transition: background 0.1s; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: var(--bg2); }
    tbody tr.tr-tiklanabilir { cursor: pointer; }
    tbody td { padding: 12px 16px; font-size: var(--fs-sm); vertical-align: middle; }
    .td-name { font-weight: var(--fw-semibold); color: var(--text); }
    .td-sub { font-size: var(--fs-xs); color: var(--text-faint); margin-top: 1px; }
    .td-url a { font-size: var(--fs-xs); color: var(--text-faint); text-decoration: none; font-family: monospace; }
    .td-url a:hover { color: var(--gold); }
    .td-actions { display: flex; gap: 6px; align-items: center; }

    .badge { display: inline-flex; align-items: center; gap: 6px; height: 20px; font-size: var(--fs-xs); font-weight: var(--fw-medium); }
    .badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
    .badge-aktif { color: var(--success); }
    .badge-pasif { color: var(--text-faint); }
    .badge-beklemede { color: var(--warning); }

    .empty-state { text-align: center; padding: 48px 24px; }
    .empty-state-icon { margin-bottom: 12px; }
    .empty-state-icon svg { color: var(--text-faint); }
    .ikon-inline { vertical-align: -3px; flex-shrink: 0; }
    .ikon-heading { vertical-align: -3px; margin-right: 6px; flex-shrink: 0; }
    .empty-state-title { font-size: var(--fs-sm); font-weight: var(--fw-semibold); color: var(--text-muted); margin-bottom: 6px; }
    .empty-state-sub { font-size: var(--fs-xs); color: var(--text-faint); margin-bottom: 16px; }

    /* ── ANALYTICS ── */
    .analytics-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 10px; }
    .analytics-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 16px; display: flex; align-items: center; justify-content: space-between; }
    .analytics-info-name { font-size: var(--fs-sm); font-weight: var(--fw-semibold); }
    .analytics-info-tip { font-size: var(--fs-xs); color: var(--text-faint); margin-top: 2px; }
    .analytics-count { font-size: 1.5rem; font-weight: var(--fw-bold); color: var(--gold); letter-spacing: -0.04em; }

    /* ── EXCEL SECTION ── */
    .excel-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 24px; max-width: 480px; }
    .excel-card h3 { font-size: var(--fs-base); font-weight: var(--fw-semibold); margin-bottom: 6px; }
    .excel-card p { font-size: var(--fs-sm); color: var(--text-muted); margin-bottom: 20px; line-height: 1.6; }
    .form-group { margin-bottom: 14px; }
    .form-group label { display: block; font-size: var(--fs-xs); color: var(--text-muted); margin-bottom: 6px; }
    .form-group input[type="file"] { font-size: var(--fs-sm); color: var(--text-muted); }

    /* ── SLIDE-IN PANEL ── */
    .panel-overlay {
      position: fixed; inset: 0; z-index: 200;
      background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
      opacity: 0; pointer-events: none; transition: opacity 0.2s;
    }
    .panel-overlay.open { opacity: 1; pointer-events: all; }

    .slide-panel {
      position: fixed; top: 50%; left: 50%; z-index: 201;
      width: 440px; max-width: calc(100vw - 32px); max-height: calc(100vh - 64px);
      background: var(--bg2); border: 1px solid var(--border); border-radius: 14px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.35);
      display: flex; flex-direction: column;
      transform: translate(-50%, -50%) scale(0.96); opacity: 0;
      transition: transform 0.22s cubic-bezier(0.16,1,0.3,1), opacity 0.18s;
      overflow: hidden; pointer-events: none;
    }
    .panel-overlay.open .slide-panel { transform: translate(-50%, -50%) scale(1); opacity: 1; pointer-events: all; }

    .slide-header {
      padding: 20px 24px 16px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
    }
    .slide-title { font-size: var(--fs-base); font-weight: var(--fw-semibold); color: var(--text); }
    .slide-close {
      width: 28px; height: 28px; border-radius: 6px;
      background: var(--bg3); border: 1px solid var(--border);
      color: var(--text-muted); cursor: pointer; font-size: 1rem;
      display: flex; align-items: center; justify-content: center; transition: all 0.15s;
    }
    .slide-close:hover { background: var(--border); color: var(--text); }

    /* ── ÇALIŞAN DETAY PANELİ (satır tıkla-aç, salt-okunur) ── */
    .detay-overlay {
      position: fixed; inset: 0; z-index: 190;
      background: rgba(0,0,0,0.4); backdrop-filter: blur(2px);
      opacity: 0; pointer-events: none; transition: opacity 0.2s;
    }
    .detay-overlay.open { opacity: 1; pointer-events: all; }
    .detay-panel {
      position: fixed; top: 0; right: 0; bottom: 0; z-index: 191;
      width: 340px; max-width: 92vw;
      background: var(--bg2); border-left: 1px solid var(--border);
      display: flex; flex-direction: column;
      transform: translateX(100%); transition: transform 0.28s cubic-bezier(0.16,1,0.3,1);
      overflow: hidden;
    }
    .detay-overlay.open .detay-panel { transform: translateX(0); }
    .detay-head { padding: 22px 22px 16px; border-bottom: 1px solid var(--border); display: flex; align-items: flex-start; justify-content: space-between; flex-shrink: 0; }
    .detay-avatar { width: 42px; height: 42px; border-radius: 50%; background: var(--bg4); display: flex; align-items: center; justify-content: center; font-size: var(--fs-base); font-weight: var(--fw-bold); color: var(--gold); margin-bottom: 10px; }
    .detay-name { font-size: 1rem; font-weight: var(--fw-bold); color: var(--text); }
    .detay-sub { font-size: var(--fs-xs); color: var(--text-faint); margin-top: 2px; }
    .detay-body { padding: 6px 22px 22px; overflow-y: auto; flex: 1; }
    .detay-field { padding: 11px 0; border-bottom: 1px solid var(--border); }
    .detay-field .fl { font-size: 10.5px; color: var(--text-faint); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 3px; }
    .detay-field .fv { font-size: var(--fs-sm); color: var(--text); }
    .detay-foot { padding: 16px 22px; border-top: 1px solid var(--border); flex-shrink: 0; }

    .slide-body { flex: 1; overflow-y: auto; overflow-x: hidden; padding: 20px 24px; }
    .slide-footer { padding: 16px 24px; border-top: 1px solid var(--border); display: flex; gap: 8px; flex-shrink: 0; }

    /* ── FORM ── */
    .form-row { display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1fr); gap: 12px; margin-bottom: 12px; }
    .form-col { display: flex; flex-direction: column; gap: 12px; min-width: 0; }
    .field { display: flex; flex-direction: column; gap: 5px; min-width: 0; }
    .field label { font-size: var(--fs-xs); color: var(--text-muted); }
    .field input, .field textarea, .field select {
      width: 100%; max-width: 100%; min-width: 0; box-sizing: border-box;
      background: var(--bg3); border: 1px solid var(--border); color: var(--text);
      border-radius: 7px; padding: 8px 12px; font-size: var(--fs-sm); font-family: inherit;
      transition: border-color 0.15s, box-shadow 0.15s; outline: none;
    }
    .field input:focus, .field textarea:focus {
      border-color: var(--gold); box-shadow: 0 0 0 3px rgba(200,168,75,0.1);
    }
    .field input::placeholder, .field textarea::placeholder { color: var(--text-faint); }
    .field textarea { resize: vertical; min-height: 72px; }
    .field-full { grid-column: 1 / -1; }
    .field-sep { grid-column: 1 / -1; border: none; border-top: 1px solid var(--border); margin: 4px 0; }
    .field-section { grid-column: 1 / -1; font-size: var(--fs-xs); font-weight: var(--fw-semibold); color: var(--text-faint); text-transform: uppercase; letter-spacing: 0.08em; padding-top: 4px; }

    /* ── ISI HARİTASI ── */
    .isi-haritasi { display: grid; grid-template-rows: repeat(7, 11px); grid-auto-flow: column; grid-auto-columns: 11px; gap: 3px; overflow-x: auto; padding-bottom: 4px; }
    .isi-haritasi-gun { width: 11px; height: 11px; border-radius: 2px; background: var(--bg3); }
    .isi-haritasi-gun[data-seviye="1"] { background: color-mix(in srgb, var(--gold) 20%, var(--bg3)); }
    .isi-haritasi-gun[data-seviye="2"] { background: color-mix(in srgb, var(--gold) 45%, var(--bg3)); }
    .isi-haritasi-gun[data-seviye="3"] { background: color-mix(in srgb, var(--gold) 70%, var(--bg3)); }
    .isi-haritasi-gun[data-seviye="4"] { background: var(--gold); }

    .btn-submit { flex: 1; height: 40px; background: var(--gold); border: none; border-radius: 8px; font-size: var(--fs-sm); font-weight: var(--fw-semibold); color: var(--btn-gold-text); cursor: pointer; font-family: inherit; transition: background 0.15s; }
    .btn-submit:hover { background: var(--gold-light); }
    .btn-cancel { height: 40px; padding: 0 16px; background: transparent; border: 1px solid var(--border); border-radius: 8px; font-size: var(--fs-sm); color: var(--text-muted); cursor: pointer; font-family: inherit; transition: all 0.15s; }
    .btn-cancel:hover { border-color: var(--border-gold); color: var(--text); }

    @media (max-width: 640px) {
      .stat-row { grid-template-columns: 1fr 1fr; }
      .dash-tabs { flex-wrap: wrap; }
      .slide-panel { width: calc(100vw - 24px); max-height: calc(100vh - 40px); }
      .form-row { grid-template-columns: 1fr; }
    }
    .soru-chip { padding:7px 12px; border:1px solid var(--border); background:var(--surface,#fff); border-radius:20px; font-size:var(--fs-sm); cursor:pointer; color:var(--text-muted); transition:all .15s; }
    .soru-chip:hover { border-color:var(--gold); color:var(--text); }
    .soru-chip.active { background:var(--gold); border-color:var(--gold); color:#1a1a1a; font-weight:600; }
  </style>
</head>
<body>
<%
function ikon(isim, boyut, sinif) {
  boyut = boyut || 16;
  sinif = sinif === undefined ? 'ikon-inline' : sinif;
  var yollar = {
    kamera: '<path d="M4 7h3l1.5-2h5L15 7h3a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1z"/><circle cx="12" cy="13" r="3.2"/>',
    kullanici: '<circle cx="12" cy="8" r="3.5"/><path d="M5 20c0-3.9 3.1-7 7-7s7 3.1 7 7"/>',
    kilit: '<rect x="5" y="10" width="14" height="10" rx="1.5"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/>',
    duraklat: '<rect x="6" y="5" width="4" height="14" rx="1"/><rect x="14" y="5" width="4" height="14" rx="1"/>',
    grafik: '<path d="M4 20V10M10 20V4M16 20v-7M22 20H2"/>',
    pano: '<rect x="6" y="4" width="12" height="16" rx="1.5"/><path d="M9 4V3a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v1"/><path d="M9 11h6M9 15h6"/>',
    kutu: '<path d="M3 8l9-5 9 5-9 5-9-5z"/><path d="M3 8v9l9 5 9-5V8"/><path d="M12 13v9"/>',
    hediye: '<rect x="4" y="9" width="16" height="11" rx="1"/><path d="M4 13h16"/><path d="M12 9v11"/><path d="M12 9c-1.7 0-3-1.1-3-2.5S9.3 4 11 4c1.4 0 1.9 1.6 1 2.5M12 9c1.7 0 3-1.1 3-2.5S14.7 4 13 4c-1.4 0-1.9 1.6-1 2.5"/>',
    cop: '<path d="M5 7h14M9 7V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2M7 7l1 12a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1l1-12"/>',
    kalem: '<path d="M4 20l1-4L16 5l3 3L8 19l-4 1z"/><path d="M14 7l3 3"/>',
    uyari: '<path d="M12 3.5L22 20H2L12 3.5z"/><path d="M12 10v4"/><circle cx="12" cy="17" r="0.8" fill="currentColor" stroke="none"/>',
    konum: '<path d="M12 21s7-6.3 7-11.5A7 7 0 0 0 5 9.5C5 14.7 12 21 12 21z"/><circle cx="12" cy="9.5" r="2.3"/>',
    ay: '<path d="M20 14.5A8.5 8.5 0 1 1 9.5 4 6.5 6.5 0 0 0 20 14.5z"/>',
    gunes: '<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2 12h2M20 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/>',
    gorunum: '<circle cx="12" cy="12" r="9"/><path d="M12 3a6 9 0 0 0 0 18M12 3a6 9 0 0 1 0 18" opacity="0.5"/>'
  };
  var d = yollar[isim] || '';
  return '<svg class="' + sinif + '" viewBox="0 0 24 24" width="' + boyut + '" height="' + boyut + '" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">' + d + '</svg>';
}

var tabGruplari = {
  genel: ['genel'],
  calisanlar: ['calisanlar', 'kullanicilar'],
  eczane: ['raf', 'indirim'],
  icerik: ['icerik', 'urunler'],
  veriekle: ['excel'],
  istatistik: ['istatistik', 'saha'],
  saha: ['analytics', 'gecmis'],
  yardim: ['yardim']
};
function tabGrubuBul(aktifTab) {
  for (var grup in tabGruplari) {
    if (tabGruplari[grup].indexOf(aktifTab) !== -1) return grup;
  }
  return 'calisanlar';
}
var aktifGrup = tabGrubuBul(tab);
if (tab === 'home') aktifGrup = 'home';

var grupEtiketleri = {
  home: 'Ana Sayfa',
  genel: 'Genel Bakış',
  calisanlar: 'Personel Yönetim Ağı',
  eczane: 'Eczane Yönetim Ağı',
  icerik: 'İçerik Yönetim',
  veriekle: 'Veri Ekle',
  istatistik: 'İstatistikler',
  saha: 'Saha Yönetim Ağı',
  yardim: 'Nasıl Kullanılır'
};

function jsonAttr(obj) {
  return JSON.stringify(obj)
    .replace(/&/g, '&amp;')
    .replace(/'/g, '&#39;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}
%>

<!-- APP SHELL -->
<div class="app-shell">
  <aside class="app-sidebar">
    <a href="/" class="sidebar-logo">NFC<em>Kartify</em></a>
    <nav class="sidebar-nav">
      <div class="sidebar-group-label">İşletme</div>
      <% if (rol !== 'sadece_saha') { %>
      <a href="/?tab=calisanlar" class="sidebar-item <%= aktifGrup === 'calisanlar' ? 'active' : '' %>"><%- ikon('kullanici') %> Personel Yönetim Ağı</a>
      <% } %>
      <% if (firma.paket === 'kurumsal' && rol !== 'sadece_calisan') { %>
      <a href="/?tab=raf" class="sidebar-item <%= aktifGrup === 'eczane' ? 'active' : '' %>"><%- ikon('kutu') %> Eczane Yönetim Ağı</a>
      <% } %>
      <a href="/?tab=gecmis" class="sidebar-item <%= aktifGrup === 'saha' ? 'active' : '' %>"><%- ikon('grafik') %> Saha Yönetim Ağı</a>

      <% if (rol !== 'sadece_saha' || (firma.paket === 'kurumsal' && rol !== 'sadece_calisan')) { %>
      <div class="sidebar-group-label">Veri Ekle</div>
      <% if (rol !== 'sadece_saha') { %>
      <a href="/?tab=excel" class="sidebar-item <%= aktifGrup === 'veriekle' ? 'active' : '' %>"><%- ikon('kutu') %> Toplu Yükleme</a>
      <% } %>
      <% if (firma.paket === 'kurumsal' && rol !== 'sadece_calisan') { %>
      <a href="/?tab=icerik" class="sidebar-item <%= aktifGrup === 'icerik' ? 'active' : '' %>"><%- ikon('kamera') %> İçerik Yönetim</a>
      <% } %>
      <% } %>

      <div class="sidebar-group-label">İstatistikler</div>
      <% if (rol !== 'sadece_saha') { %>
      <a href="/?tab=istatistik" class="sidebar-item <%= tab === 'istatistik' ? 'active' : '' %>"><%- ikon('grafik') %> Personel İstatistikleri</a>
      <% } %>
      <% if (firma.paket === 'kurumsal' && rol !== 'sadece_calisan') { %>
      <a href="/?tab=saha" class="sidebar-item <%= tab === 'saha' ? 'active' : '' %>"><%- ikon('grafik') %> Eczane İstatistikleri</a>
      <% } %>

      <div class="sidebar-group-label">Yardım</div>
      <a href="/?tab=yardim" class="sidebar-item <%= aktifGrup === 'yardim' ? 'active' : '' %>"><span style="width:16px;display:inline-flex;justify-content:center;flex-shrink:0">❔</span> Nasıl Kullanılır?</a>
    </nav>
    <div class="sidebar-foot">
      <div class="sidebar-user-dot"><%= firma.ad.slice(0, 2).toUpperCase() %></div>
      <div class="sidebar-user-email"><%= firma.yetkili_email %></div>
    </div>
  </aside>

  <div class="app-main">
    <div class="app-topbar">
      <div class="breadcrumb"><%= firma.ad %> / <b><%= grupEtiketleri[aktifGrup] || 'Genel Bakış' %></b></div>
      <div class="nav-right">
        <% if (!rol || rol === 'tam_yetkili') { %>
        <div class="gorunum-ctl-wrap">
          <button type="button" class="btn btn-ghost" onclick="gorunumPopToggle()" title="Görünümü özelleştir">
            <%- ikon('gorunum', 16, '') %> Görünüm
          </button>
          <div class="gorunum-pop" id="gorunumPop">
            <div class="gorunum-pop-label">Vurgu Rengi</div>
            <div class="sv-square" id="svSquare">
              <div class="sv-hue-layer" id="svHueLayer"></div>
              <div class="sv-white-layer"></div>
              <div class="sv-black-layer"></div>
              <div class="sv-handle" id="svHandle"></div>
            </div>
            <div class="hue-strip" id="hueStrip">
              <div class="hue-handle" id="hueHandle"></div>
            </div>
            <div class="color-readout">
              <div class="color-swatch" id="colorSwatch"></div>
              <div class="color-hex" id="colorHex">#C8A84B</div>
            </div>
            <div class="gorunum-pop-divider"></div>
            <div class="light-row"><span class="gorunum-pop-label" style="margin:0">Işık Derecesi</span><span class="light-val" id="lightVal">50</span></div>
            <input type="range" class="gorunum-slider" id="lightSlider" min="0" max="100" value="50" oninput="isikDerecesiUygula(this.value)">
            <div class="gorunum-slider-ends"><span>Koyu</span><span>Açık</span></div>
            <div class="gorunum-save-status" id="gorunumKaydetDurum"></div>
          </div>
        </div>
        <% } %>
        <button type="button" id="temaBtn" class="btn btn-ghost" onclick="temaDegistir()" title="Temayı değiştir">
          <span id="temaIkonAy"><%- ikon('ay', 16, '') %></span>
          <span id="temaIkonGunes" style="display:none"><%- ikon('gunes', 16, '') %></span>
        </button>
        <form method="POST" action="/firma/cikis" style="margin:0">
          <button type="submit" class="btn btn-ghost">Çıkış</button>
        </form>
      </div>
    </div>

<!-- FLASH -->
<% if (success && success.length) { %>
  <div class="flash-bar flash-success">✓ <%= success[0] %></div>
<% } %>
<% if (error && error.length) { %>
  <div class="flash-bar flash-error">✕ <%= error[0] %></div>
<% } %>

<!-- MAIN -->
<div class="dash-main <%= tab === 'organizasyon' ? 'dash-main--wide' : '' %>">

  <!-- ANA SAYFA (boş karşılama) -->
  <% if (tab === 'home') { %>
  <div class="table-wrap" style="padding:64px 24px;text-align:center">
    <div style="font-size:42px;margin-bottom:12px">👋</div>
    <div style="font-size:19px;font-weight:700;margin-bottom:6px"><%= firma.ad %> paneline hoş geldiniz</div>
    <div style="color:var(--text-faint);font-size:13px">Başlamak için soldaki menüden bir bölüm seçin.</div>
  </div>
  <% } %>

  <!-- HEADER (sadece Çalışanlar sekmesinde ekleme butonu) -->
  <% if (tab === 'calisanlar') { %>
  <div class="dash-header" style="justify-content:flex-end">
    <button class="btn btn-gold" onclick="openSlide()">+ Yeni Çalışan</button>
  </div>
  <% } %>

  <!-- SUB TABS -->
  <% if (aktifGrup !== 'genel' && aktifGrup !== 'istatistik' && aktifGrup !== 'veriekle' && aktifGrup !== 'yardim' && tab !== 'home') { %>
  <div class="dash-tabs">
    <% if (aktifGrup === 'calisanlar') { %>
    <a href="/?tab=calisanlar" class="dash-tab <%= tab === 'calisanlar' ? 'active' : '' %>">Çalışanlar</a>
    <a href="/?tab=organizasyon" class="dash-tab <%= tab === 'organizasyon' ? 'active' : '' %>">Organizasyon</a>
    <% if (!rol || rol === 'tam_yetkili') { %>
    <a href="/?tab=kullanicilar" class="dash-tab <%= tab === 'kullanicilar' ? 'active' : '' %>">Kullanıcılar</a>
    <% } %>
    <% } else if (aktifGrup === 'eczane') { %>
    <a href="/?tab=raf"     class="dash-tab <%= tab === 'raf'     ? 'active' : '' %>">Raf Kartları</a>
    <a href="/?tab=indirim" class="dash-tab <%= tab === 'indirim' ? 'active' : '' %>">İndirim</a>
    <% } else if (aktifGrup === 'icerik') { %>
    <a href="/?tab=icerik"  class="dash-tab <%= tab === 'icerik'  ? 'active' : '' %>">İçerik</a>
    <a href="/?tab=urunler" class="dash-tab <%= tab === 'urunler' ? 'active' : '' %>">Ürünler</a>
    <% } else if (aktifGrup === 'saha') { %>
    <a href="/?tab=gecmis"    class="dash-tab <%= tab === 'gecmis'    ? 'active' : '' %>">İşlem Geçmişi</a>
    <% } %>
  </div>
  <% } %>

  <!-- TAB: NASIL KULLANILIR -->
  <% if (tab === 'yardim') { %>
    <div class="table-wrap" style="padding:24px 24px 28px">
      <h2 style="margin:0 0 6px;font-size:20px">Nasıl Kullanılır?</h2>
      <p class="nk-intro">Sistemi ilk kez mi kullanıyorsun? Merak etme, çok basit. Aşağıdaki adımları sırayla yap; her adımda tam olarak nereye tıklayacağın yazıyor. Soldaki menü hep açık kalır, oradan istediğin yere geçebilirsin.</p>
      <div class="nk-list">

        <div class="nk-adim"><span class="nk-no">1</span><div>
          <div class="nk-bas">Çalışanlarını ekle</div>
          <p>Soldan <b>Personel Yönetim Ağı</b>'na tıkla. Sağ üstteki <b>+ Yeni Çalışan</b> düğmesiyle bir kişiyi ekle (ad, soyad, görev, telefon...). <br>Çok kişi varsa tek tek uğraşma: <b>Veri Ekle → Toplu Yükleme</b>'ye git, <b>Şablonu İndir</b>, Excel'i doldur, sonra <b>dosyayı seçip Yükle</b>.</p>
        </div></div>

        <div class="nk-adim"><span class="nk-no">2</span><div>
          <div class="nk-bas">Kim kimin altında çalışıyor belirle</div>
          <p><b>Personel Yönetim Ağı → Organizasyon</b>'a tıkla. Bir çalışanı düzenlerken <b>Amiri</b> kısmından bağlı olduğu yöneticiyi seç. Kişi bir ekibin başıysa <b>Ekip yöneticisi</b> kutusunu işaretle. Şirket şeması burada kendiliğinden çizilir.</p>
        </div></div>

        <% if (firma.paket === 'kurumsal') { %>
        <div class="nk-adim"><span class="nk-no">3</span><div>
          <div class="nk-bas">Eczaneleri ekle</div>
          <p><b>Eczane Yönetim Ağı → Raf Kartları</b>'na git, <b>+ Eczane Ekle</b> ile ekle. Çok eczane varsa yine <b>Veri Ekle → Toplu Yükleme → Eczane Şablonu İndir</b> ile topluca yükle.</p>
        </div></div>

        <div class="nk-adim"><span class="nk-no">4</span><div>
          <div class="nk-bas">Firmanın görsellerini yükle</div>
          <p><b>Veri Ekle → İçerik Yönetim</b>'e git. Buradan firmanın <b>logosunu</b>, <b>kataloğunu (PDF)</b> ve <b>eczacı eğitim dokümanını (PDF)</b> yükle. Bunlar müşterinin gördüğü kartlarda görünür.</p>
        </div></div>

        <div class="nk-adim"><span class="nk-no">5</span><div>
          <div class="nk-bas">Ürünlerini ekle</div>
          <p><b>Veri Ekle → İçerik Yönetim → Ürünler</b>'e git, <b>+ Ürün Ekle</b> ile ürünü, fotoğrafını ve varsa broşürünü (PDF) ekle. Ürünler raf kartında listelenir.</p>
        </div></div>

        <div class="nk-adim"><span class="nk-no">6</span><div>
          <div class="nk-bas">İndirim kampanyası aç (istersen)</div>
          <p><b>Eczane Yönetim Ağı → İndirim</b>'e git. Kampanyayı aç, indirim yüzdesini yaz, <b>Kaydet</b>'e bas. Müşteri raf sayfasında indirim kodu alabilir.</p>
        </div></div>
        <% } %>

        <div class="nk-adim"><span class="nk-no"><%= firma.paket === 'kurumsal' ? '7' : '3' %></span><div>
          <div class="nk-bas">Sonuçları takip et</div>
          <p><b>İstatistikler → Personel İstatistikleri</b>'nde çalışan kartlarının kaç kez görüntülendiğini görürsün.<% if (firma.paket === 'kurumsal') { %> <b>Eczane İstatistikleri</b>'nde saha ziyaretlerini izlersin.<% } %> Kimin ne değiştirdiğini <b>Saha Yönetim Ağı → İşlem Geçmişi</b>'nde bulursun.</p>
        </div></div>

      </div>
      <p class="nk-intro" style="margin-top:22px;margin-bottom:0">Takıldığın bir yer olursa her ekranın en üstündeki <b>💡 ipucu</b> satırına bak — orada o sayfada ne yapman gerektiği kısaca yazıyor.</p>
    </div>
  <% } %>

  <!-- TAB: ORGANİZASYON -->
  <% if (tab === 'organizasyon') { %>
    <% if (!hiyerarsiAgaci || !hiyerarsiAgaci.length) { %>
    <div class="table-wrap"><div class="empty-state">
      <div class="empty-state-title">Hiyerarşi tanımlı değil</div>
      <div class="empty-state-sub">Çalışanlara "amiri" atadıkça organizasyon şeması burada oluşur.</div>
    </div></div>
    <% } else { %>
    <div class="table-wrap" style="padding:14px 16px;margin-bottom:10px;display:flex;gap:10px;align-items:center;flex-wrap:wrap">
      <strong style="font-size:var(--fs-md)">Organizasyon Şeması</strong>
      <span style="font-size:var(--fs-xs);color:var(--text-faint)">Bir yöneticiye tıkla → ekibi açılır · ekipte isim ara · yönetici üyeye tıkla → alt ekibine in · isme tıkla → profil sayfası</span>
    </div>
    <style>
      .oc-stats{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px}
      .oc-stat{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:8px 14px;font-size:11.5px;color:var(--text-faint);font-weight:600}
      .oc-stat b{display:block;font-size:17px;color:var(--text);font-weight:800;line-height:1.05}
      .oc-wrap{background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:20px 20px 24px}
      .oc-av{border-radius:50%;object-fit:cover;display:grid;place-items:center;font-weight:750;color:#fff;flex:0 0 auto}
      /* Kök — tam genişlik neon banner */
      .oc-kok{margin-bottom:16px}
      .oc-kokcard{position:relative;overflow:hidden;display:flex;align-items:center;gap:16px;width:100%;cursor:pointer;color:#fff;
        border-radius:18px;padding:18px 24px;background:linear-gradient(158deg,#241c0e,#16120a);
        border:1px solid rgba(234,179,8,.38);box-shadow:0 20px 46px -24px rgba(234,179,8,.5);transition:transform .14s ease}
      .oc-kokcard:hover{transform:translateY(-2px)}
      .oc-kokcard::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:linear-gradient(90deg,#f59e0b,#fbbf24,#f97316)}
      .oc-kokcard .oc-av{width:62px;height:62px;font-size:20px;background:#16120a;border:2px solid #fbbf24;box-shadow:0 0 18px -3px #fbbf24}
      .oc-kokcard .kk-nm{font-size:18px;font-weight:800;letter-spacing:-.01em}
      .oc-kokcard .kk-gorev{margin-left:auto;flex:0 0 auto;font-size:11px;font-weight:800;background:#fbbf24;color:#1a1205;
        padding:6px 14px;border-radius:999px;box-shadow:0 0 14px -3px #fbbf24;white-space:nowrap}
      /* Yönetici kartları — genişliği dolduran yatay neon kutular */
      .oc-mgrrow{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:16px}
      .oc-mgr{position:relative;overflow:hidden;display:flex;align-items:center;gap:14px;cursor:pointer;color:#fff;
        border-radius:16px;padding:16px 16px 16px 22px;background:linear-gradient(158deg,#1b2131,#12161f);
        border:1px solid rgba(255,255,255,.09);box-shadow:0 18px 40px -22px var(--c2);transition:transform .14s ease,box-shadow .14s ease}
      .oc-mgr::before{content:'';position:absolute;top:0;bottom:0;left:0;width:5px;background:linear-gradient(180deg,var(--c1),var(--c2),var(--c3))}
      .oc-mgr:hover{transform:translateY(-3px);box-shadow:0 26px 50px -22px var(--c2)}
      .oc-mgr.active{outline:2px solid var(--c2);outline-offset:2px}
      .oc-mgr .oc-av{width:54px;height:54px;font-size:16px;background:#12161f;border:2px solid var(--c2);box-shadow:0 0 15px -3px var(--c2)}
      .oc-mgr .info{min-width:0;padding-right:56px}
      .oc-mgr .nm{font-size:15px;font-weight:750;line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
      .oc-mgr .sz{margin-top:7px;font-size:11px;font-weight:750;color:var(--c2);background:#12161f;border:1px solid var(--c2);border-radius:999px;padding:3px 11px;display:inline-block}
      .oc-mgr .gorev{position:absolute;top:11px;right:12px;max-width:54%;font-size:9.5px;font-weight:800;padding:4px 11px;border-radius:999px;
        color:#0b0e14;background:var(--c2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;box-shadow:0 0 12px -3px var(--c2)}
      /* Ekip paneli */
      .oc-team{display:none;margin-top:18px;border:1px solid var(--border);border-radius:16px;overflow:hidden;background:var(--surface);
        box-shadow:0 24px 50px -28px rgba(0,0,0,.5)}
      .oc-team.open{display:block}
      .oc-bc{display:flex;flex-wrap:wrap;align-items:center;gap:4px;padding:11px 16px;font-size:12px;background:var(--bg3);border-bottom:1px solid var(--border)}
      .oc-bc a{color:var(--gold);cursor:pointer;text-decoration:none;font-weight:600}
      .oc-bc span.sep{color:var(--text-faint);opacity:.6}
      .oc-bc span.cur{color:var(--text-faint)}
      .oc-thead{position:relative;overflow:hidden;display:flex;align-items:center;gap:13px;padding:16px 18px;color:#fff;flex-wrap:wrap;background:linear-gradient(158deg,#1b2131,#12161f)}
      .oc-thead::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:linear-gradient(90deg,var(--c1),var(--c2),var(--c1))}
      .oc-thead .oc-av{width:52px;height:52px;font-size:16px;background:#12161f;border:2px solid var(--c2);box-shadow:0 0 15px -3px var(--c2)}
      .oc-thead .th-nm{font-size:16px;font-weight:800;letter-spacing:-.01em}
      .oc-thead .th-ti{font-size:12px;color:rgba(255,255,255,.85)}
      .oc-thead .th-prof{font-size:11px;font-weight:700;background:var(--c2);color:#0b0e14;border:none;cursor:pointer;padding:7px 13px;border-radius:9px;text-decoration:none}
      .oc-thead .grow{margin-left:auto;display:flex;gap:10px;align-items:center;flex-wrap:wrap}
      .oc-thead input{border:none;border-radius:10px;padding:9px 13px;font-size:13px;width:210px;max-width:52vw;background:rgba(255,255,255,.12);color:#fff}
      .oc-thead input::placeholder{color:rgba(255,255,255,.6)}
      .oc-thead .x{width:32px;height:32px;border-radius:50%;border:none;cursor:pointer;background:rgba(255,255,255,.18);color:#fff;font-size:16px}
      .oc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:10px;padding:16px 18px;max-height:56vh;overflow:auto}
      .oc-mem{display:flex;align-items:center;gap:11px;padding:10px 12px;border:1px solid var(--border);border-left:4px solid var(--mc);
        border-radius:13px;background:var(--surface);cursor:pointer;transition:background .12s ease,transform .12s ease}
      .oc-mem:hover{background:var(--bg3);transform:translateY(-1px)}
      .oc-mem .mav{width:38px;height:38px;border-radius:50%;background:linear-gradient(158deg,var(--mc),var(--mc2));color:#fff;
        display:grid;place-items:center;font-weight:700;font-size:13px;flex:0 0 38px;border:2px solid rgba(255,255,255,.5);object-fit:cover}
      .oc-mem .mnm{font-size:13px;font-weight:700;line-height:1.15;color:var(--text)}
      .oc-mem .mti{font-size:10.5px;color:var(--text-faint);margin-top:1px}
      .oc-mem .mchip{margin-left:auto;font-size:10px;font-weight:800;white-space:nowrap;padding:3px 9px;border-radius:999px;background:var(--bg3);color:var(--mc);border:1px solid var(--border)}
      .oc-mem .mzi{margin-left:auto;font-size:10.5px;color:var(--text-faint);white-space:nowrap}
      .oc-bos{padding:24px 16px;color:var(--text-faint);font-size:13px;text-align:center}
    </style>
    <div class="oc-stats" id="ocStats"></div>
    <div class="oc-wrap">
      <div id="ocKok" class="oc-kok"></div>
      <div id="ocMgrRow" class="oc-mgrrow"></div>
      <div class="oc-team" id="ocTeam">
        <div class="oc-bc" id="ocBc"></div>
        <div class="oc-thead" id="ocThead">
          <span id="ocThAv"></span>
          <span><span class="th-nm" id="ocThNm"></span><br><span class="th-ti" id="ocThTi"></span></span>
          <span class="grow">
            <a class="th-prof" id="ocThProf" target="_blank" rel="noopener">Profil ↗</a>
            <input id="ocAra" placeholder="Bu ekipte isim ara…" autocomplete="off">
            <button type="button" class="x" onclick="ocTeamKapat()" aria-label="Kapat">✕</button>
          </span>
        </div>
        <div class="oc-grid" id="ocGrid"></div>
      </div>
    </div>
    <script>
      (function () {
        const orgVeri = <%- JSON.stringify(hiyerarsiAgaci) %>;
        const FIRMA_SLUG = <%- JSON.stringify(typeof firma !== 'undefined' && firma ? (firma.slug || '') : '') %>;
        // Neon renk üçlüleri (departmandan bağımsız, her ekibe bir üçlü)
        const PAIRS = [['#6366f1','#a855f7','#ec4899'],['#06b6d4','#3b82f6','#8b5cf6'],['#10b981','#84cc16','#f59e0b'],['#f43f5e','#fb7185','#f59e0b'],['#8b5cf6','#d946ef','#f472b6'],['#0ea5e9','#22d3ee','#34d399'],['#f59e0b','#f97316','#ef4444'],['#14b8a6','#06b6d4','#3b82f6'],['#a855f7','#ec4899','#f43f5e'],['#22c55e','#84cc16','#eab308']];

        const $ = id => document.getElementById(id);
        function el(tag, cls){ const e = document.createElement(tag); if (cls) e.className = cls; return e; }
        function initials(n){ return (((n.ad||' ')[0]||'') + ((n.soyad||' ')[0]||'')).toLocaleUpperCase('tr'); }
        function avatar(n, cls){ if (n.foto_url){ const im = el('img', cls); im.src = n.foto_url; im.alt = ''; return im; } const d = el('div', cls); d.textContent = initials(n); return d; }
        function tamAd(n){ return ((n.ad||'') + ' ' + (n.soyad||'')).trim(); }
        function profilUrl(n){ return (FIRMA_SLUG && n.slug) ? ('/' + FIRMA_SLUG + '/' + n.slug) : null; }
        function git(n){ const u = profilUrl(n); if (u) window.open(u, '_blank', 'noopener'); }
        function yonetici(n){ return !!(n.cocuklar && n.cocuklar.length); }
        function ekipBuyuk(n){ let c = 0; (function w(l){ l.forEach(function(x){ c++; w(x.cocuklar||[]); }); })(n.cocuklar||[]); return c; }

        let kok = null, topList = orgVeri;
        if (orgVeri.length === 1 && yonetici(orgVeri[0])){ kok = orgVeri[0]; topList = kok.cocuklar; }

        // Her yöneticiye kendi rengi (ön-sıra gezinme; collapse'tan bağımsız → renkler sabit)
        const mgrColor = {}; let ci = 0;
        (function ata(list){ list.forEach(function(n){ if (yonetici(n)){ mgrColor[n.id] = PAIRS[ci % PAIRS.length]; ci++; } ata(n.cocuklar||[]); }); })(topList);
        function renk(n){ return mgrColor[n.id] || PAIRS[0]; }

        // İstatistik
        let toplam = (kok ? 1 : 0); (function say(l){ l.forEach(function(x){ toplam++; say(x.cocuklar||[]); }); })(topList);
        (function(){
          const s = $('ocStats');
          function box(n, l){ const b = el('div','oc-stat'); const bb = el('b'); bb.textContent = String(n); b.appendChild(bb); b.appendChild(document.createTextNode(l)); return b; }
          s.append(box(toplam, 'Çalışan'), box(Object.keys(mgrColor).length, 'Yönetici / ekip'));
        })();

        // Kök
        (function(){
          const h = $('ocKok');
          if (!kok){ h.style.display = 'none'; return; }
          const c = el('div', 'oc-kokcard');
          c.appendChild(avatar(kok, 'oc-av'));
          const info = el('div'); const nm = el('div','kk-nm'); nm.textContent = tamAd(kok); info.appendChild(nm);
          c.appendChild(info);
          if (kok.unvan){ const g = el('div','kk-gorev'); g.textContent = kok.unvan; c.appendChild(g); }
          if (profilUrl(kok)) c.onclick = function(){ git(kok); }; else c.style.cursor = 'default';
          h.appendChild(c);
        })();

        // Yönetici satırı (kökün doğrudan altı)
        (function(){
          const row = $('ocMgrRow');
          topList.forEach(function(n){
            const t3 = renk(n);
            const c = el('div','oc-mgr'); c.dataset.id = n.id;
            c.style.setProperty('--c1', t3[0]); c.style.setProperty('--c2', t3[1]); c.style.setProperty('--c3', t3[2] || t3[1]);
            if (n.unvan){ const g = el('div','gorev'); g.textContent = n.unvan; c.appendChild(g); }  // sağ üst = GÖREV
            c.appendChild(avatar(n, 'oc-av'));
            const info = el('div','info');
            const nm = el('div','nm'); nm.textContent = tamAd(n); info.appendChild(nm);
            if (yonetici(n)){ const sz = el('div','sz'); sz.textContent = ekipBuyuk(n) + ' kişi'; info.appendChild(sz); }
            c.appendChild(info);
            c.onclick = function(){ if (yonetici(n)) ekipAc([n]); else git(n); };
            row.appendChild(c);
          });
        })();

        // ── Ekip paneli: accordion + drill ──
        let path = [];
        function aktifIsaretle(){
          const topId = path.length ? String(path[0].id) : null;
          document.querySelectorAll('.oc-mgr').forEach(function(m){ m.classList.toggle('active', topId === m.dataset.id); });
        }
        window.ocTeamKapat = function(){ path = []; $('ocTeam').classList.remove('open'); aktifIsaretle(); };

        function ekipAc(yeniPath){
          path = yeniPath;
          const odak = path[path.length - 1];
          const pair = renk(odak);
          const t = $('ocTeam'); t.style.setProperty('--c1', pair[0]); t.style.setProperty('--c2', pair[1]);
          const av = $('ocThAv'); av.textContent = ''; av.appendChild(avatar(odak, 'oc-av'));
          $('ocThNm').textContent = tamAd(odak);
          $('ocThTi').textContent = (odak.unvan || '') + ' · ' + ekipBuyuk(odak) + ' kişilik ekip';
          const prof = $('ocThProf'); const pu = profilUrl(odak); if (pu){ prof.style.display = ''; prof.href = pu; } else prof.style.display = 'none';
          // breadcrumb
          const bc = $('ocBc'); bc.textContent = '';
          if (kok){ const a = el('a'); a.textContent = tamAd(kok); a.onclick = function(){ ocTeamKapat(); }; bc.appendChild(a); }
          path.forEach(function(node, i){
            if (kok || i > 0){ const sep = el('span','sep'); sep.textContent = ' › '; bc.appendChild(sep); }
            if (i < path.length - 1){ const a = el('a'); a.textContent = tamAd(node); a.onclick = function(){ ekipAc(path.slice(0, i + 1)); }; bc.appendChild(a); }
            else { const s = el('span','cur'); s.textContent = tamAd(node); bc.appendChild(s); }
          });
          $('ocAra').value = ''; cizGrid('');
          t.classList.add('open'); aktifIsaretle(); t.scrollIntoView({ behavior:'smooth', block:'nearest' }); $('ocAra').focus();
        }

        function cizGrid(filtre){
          const odak = path[path.length - 1];
          const g = $('ocGrid'); g.textContent = '';
          const f = (filtre||'').toLocaleLowerCase('tr').trim();
          const uyeler = (odak.cocuklar||[]).filter(function(u){ return !f || tamAd(u).toLocaleLowerCase('tr').includes(f); });
          if (!uyeler.length){ const b = el('div','oc-bos'); b.textContent = 'Eşleşen kişi yok.'; g.appendChild(b); return; }
          const frag = document.createDocumentFragment();
          const odakPair = renk(odak);
          uyeler.forEach(function(u){
            const alt = yonetici(u);
            const pair = alt ? renk(u) : odakPair;
            const m = el('div','oc-mem'); m.style.setProperty('--mc', pair[0]); m.style.setProperty('--mc2', pair[1]);
            m.appendChild(avatar(u, 'mav'));
            const info = el('div'); const nm = el('div','mnm'); nm.textContent = tamAd(u); info.appendChild(nm);
            if (u.unvan){ const ti = el('div','mti'); ti.textContent = u.unvan; info.appendChild(ti); }
            m.appendChild(info);
            if (alt){ const ch = el('div','mchip'); ch.textContent = ekipBuyuk(u) + ' kişi ›'; m.appendChild(ch); m.onclick = function(){ ekipAc(path.concat([u])); }; }
            else { const z = el('div','mzi'); z.textContent = (u.kendiZiyaret||0) + ' zyt'; m.appendChild(z); m.onclick = function(){ git(u); }; }
            frag.appendChild(m);
          });
          g.appendChild(frag);
        }
        $('ocAra').addEventListener('input', function(e){ if (path.length) cizGrid(e.target.value); });
      })();
    </script>
    <% } %>
  <% } %>

  <!-- TAB: KULLANICILAR -->
  <% if (tab === 'kullanicilar') { %>
    <div class="table-wrap" style="padding:20px;margin-bottom:16px">
      <h3 style="margin-bottom:12px">Yeni Kullanıcı Davet Et</h3>
      <form method="POST" action="/firma/kullanicilar/ekle" style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end">
        <div class="field" style="min-width:160px">
          <label>Ad Soyad</label>
          <input name="ad" required>
        </div>
        <div class="field" style="min-width:200px">
          <label>E-posta</label>
          <input type="email" name="email" required>
        </div>
        <div class="field" style="min-width:160px">
          <label>Şifre</label>
          <input type="text" name="sifre" required minlength="6">
        </div>
        <div class="field" style="min-width:160px">
          <label>Rol</label>
          <select name="rol" required>
            <option value="tam_yetkili">Tam Yetkili</option>
            <option value="sadece_calisan">Sadece Çalışan Yönetimi</option>
            <option value="sadece_saha">Sadece Saha/Eczane</option>
          </select>
        </div>
        <button type="submit" class="btn btn-gold" style="height:36px">Ekle</button>
      </form>
    </div>
    <% if (!kullanicilarListesi.length) { %>
    <div class="table-wrap">
      <div class="empty-state">
        <div class="empty-state-icon"><%- ikon('kullanici', 32, '') %></div>
        <div class="empty-state-title">Henüz ek kullanıcı yok</div>
        <div class="empty-state-sub">Yukarıdan davet ederek başlayın</div>
      </div>
    </div>
    <% } else { %>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Ad Soyad</th><th>E-posta</th><th>Rol</th><th>İşlem</th></tr></thead>
        <tbody>
          <% kullanicilarListesi.forEach(k => { %>
          <tr>
            <td class="td-name"><%= k.ad %></td>
            <td><%= k.email %></td>
            <td><%= k.rol === 'tam_yetkili' ? 'Tam Yetkili' : k.rol === 'sadece_calisan' ? 'Sadece Çalışan' : 'Sadece Saha' %></td>
            <td>
              <form method="POST" action="/firma/kullanicilar/<%= k.id %>/sil" style="display:inline" onsubmit="return confirm('<%= k.ad %> kaldırılsın mı?')">
                <button type="submit" class="btn-link">Kaldır</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>

  <!-- TAB: ÇALIŞANLAR -->
  <% } else if (tab === 'calisanlar') { %>
    <div class="ipucu"><span class="ipucu-ikon">💡</span><span>Çalışanlarını buradan görürsün. Yeni eklemek için sağ üstteki <b>+ Yeni Çalışan</b>'a bas; bir çalışana tıklarsan bilgilerini açıp düzenlersin.</span></div>
    <% const aramaMetni = (ara || '').toLocaleLowerCase('tr').trim(); %>
    <% const calisanlarFiltreli = aramaMetni
         ? calisanlar.filter(c => (c.ad || '').toLocaleLowerCase('tr').startsWith(aramaMetni) || (c.soyad || '').toLocaleLowerCase('tr').startsWith(aramaMetni))
         : calisanlar; %>
    <% const aktifCalisanlarTum = calisanlarFiltreli.filter(c => c.durum === 'aktif'); %>
    <% const pasifCalisanlar = calisanlarFiltreli.filter(c => c.durum === 'pasif'); %>
    <% const SAYFA_BOYUTU = 20; %>
    <% const toplamSayfa = Math.max(1, Math.ceil(aktifCalisanlarTum.length / SAYFA_BOYUTU)); %>
    <% const mevcutSayfa = Math.min(Math.max(sayfa || 1, 1), toplamSayfa); %>
    <% const aktifCalisanlar = aktifCalisanlarTum.slice((mevcutSayfa - 1) * SAYFA_BOYUTU, mevcutSayfa * SAYFA_BOYUTU); %>

    <form method="GET" action="/" style="margin-bottom:16px;display:flex;gap:8px;max-width:380px;align-items:center">
      <input type="hidden" name="tab" value="calisanlar">
      <input type="text" name="ara" placeholder="İsim veya e-posta ara..." value="<%= ara || '' %>" oninput="aramaOtomatikGonder(this)"
             style="flex:1;height:32px;padding:0 12px;border-radius:7px;border:1px solid var(--border);background:var(--bg3);color:var(--text);font-size:var(--fs-sm);font-family:inherit">
      <button type="submit" class="btn btn-border btn-sm">Ara</button>
      <% if (ara) { %><a href="/?tab=calisanlar" class="btn btn-ghost btn-sm">Temizle</a><% } %>
    </form>

    <button type="button" id="calisanListeBtn" class="btn btn-border btn-sm" style="margin-bottom:14px" onclick="listeToggle('calisanListeKutu','calisanListeBtn','Tüm Personeli Listele','Listeyi Gizle')"><%= ara ? 'Listeyi Gizle' : 'Tüm Personeli Listele' %></button>
    <div id="calisanListeKutu" style="display:<%= ara ? 'block' : 'none' %>">

    <% if (aktifCalisanlar.length) { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Ad Soyad</th>
            <th>Unvan / Departman</th>
            <th>Profil URL</th>
            <th>Durum</th>
            <th>İşlem</th>
          </tr>
        </thead>
        <tbody>
          <% aktifCalisanlar.forEach(c => { %>
          <tr class="tr-tiklanabilir" onclick='calisanDetayGoster(event, <%- jsonAttr(c) %>)'>
            <td>
              <div class="td-name"><%= c.ad %> <%= c.soyad %></div>
            </td>
            <td>
              <div style="font-size:var(--fs-xs);color:var(--text-muted)"><%= c.unvan || '—' %></div>
              <div class="td-sub"><%= c.departman || '' %></div>
            </td>
            <td class="td-url">
              <a href="/<%= firma.slug %>/<%= c.slug %>" target="_blank">/<%= firma.slug %>/<%= c.slug %></a>
            </td>
            <td>
              <span class="badge badge-<%= c.durum %>"><%= c.durum %></span>
              <% if (!c.onayli) { %>
                <div style="margin-top:6px">
                  <span class="badge badge-beklemede">Onay Bekliyor</span>
                  <form method="POST" action="/firma/panel/calisan/<%= c.id %>/onayla" style="display:inline">
                    <button type="submit" class="btn btn-gold btn-sm">Onayla</button>
                  </form>
                </div>
              <% } %>
            </td>
            <td>
              <div class="td-actions">
                <% if (!c.foto_url) { %>
                  <button class="btn btn-warning-sm btn-sm" onclick='openSlideEdit(<%- jsonAttr(c) %>)'><%- ikon('kamera') %>Fotoğraf Ekle</button>
                <% } %>
                <button class="btn btn-border btn-sm" onclick='openSlideEdit(<%- jsonAttr(c) %>)'>Düzenle</button>
                <form method="POST" action="/firma/panel/<%= c.id %>/durum" style="margin:0">
                  <input type="hidden" name="_method" value="PATCH">
                  <input type="hidden" name="durum" value="<%= c.durum === 'aktif' ? 'pasif' : 'aktif' %>">
                  <button type="submit" class="btn btn-danger-sm btn-sm"><%= c.durum === 'aktif' ? 'Pasife Al' : 'Aktif Et' %></button>
                </form>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% if (toplamSayfa > 1) { %>
    <div style="display:flex;gap:8px;align-items:center;justify-content:center;margin:16px 0">
      <% if (mevcutSayfa > 1) { %>
        <a class="btn btn-border btn-sm" href="/?tab=calisanlar&ara=<%= encodeURIComponent(ara || '') %>&sayfa=<%= mevcutSayfa - 1 %>">← Önceki</a>
      <% } %>
      <span style="font-size:var(--fs-xs);color:var(--text-muted)">Sayfa <%= mevcutSayfa %> / <%= toplamSayfa %></span>
      <% if (mevcutSayfa < toplamSayfa) { %>
        <a class="btn btn-border btn-sm" href="/?tab=calisanlar&ara=<%= encodeURIComponent(ara || '') %>&sayfa=<%= mevcutSayfa + 1 %>">Sonraki →</a>
      <% } %>
    </div>
    <% } %>
    <% } else if (!pasifCalisanlar.length) { %>
    <div class="table-wrap">
      <div class="empty-state">
        <div class="empty-state-icon"><%- ikon('kullanici', 32, '') %></div>
        <div class="empty-state-title">Henüz çalışan yok</div>
        <div class="empty-state-sub">İlk çalışanı ekleyerek başlayın</div>
        <button class="btn btn-gold" onclick="openSlide()">+ Yeni Çalışan Ekle</button>
      </div>
    </div>
    <% } %>

    <% if (pasifCalisanlar.length) { %>
    <details class="table-wrap" style="padding:0">
      <summary style="cursor:pointer;padding:14px 20px;font-weight:600;color:var(--text-muted)">Pasif Çalışanlar (<%= pasifCalisanlar.length %>)</summary>
      <table>
        <thead>
          <tr>
            <th>Ad Soyad</th>
            <th>Unvan / Departman</th>
            <th>Profil URL</th>
            <th>Durum</th>
            <th>İşlem</th>
          </tr>
        </thead>
        <tbody>
          <% pasifCalisanlar.forEach(c => { %>
          <tr>
            <td>
              <div class="td-name"><%= c.ad %> <%= c.soyad %></div>
            </td>
            <td>
              <div style="font-size:var(--fs-xs);color:var(--text-muted)"><%= c.unvan || '—' %></div>
              <div class="td-sub"><%= c.departman || '' %></div>
            </td>
            <td class="td-url">
              <a href="/<%= firma.slug %>/<%= c.slug %>" target="_blank">/<%= firma.slug %>/<%= c.slug %></a>
            </td>
            <td>
              <span class="badge badge-<%= c.durum %>"><%= c.durum %></span>
            </td>
            <td>
              <div class="td-actions">
                <% if (!c.foto_url) { %>
                  <button class="btn btn-warning-sm btn-sm" onclick='openSlideEdit(<%- jsonAttr(c) %>)'><%- ikon('kamera') %>Fotoğraf Ekle</button>
                <% } %>
                <button class="btn btn-border btn-sm" onclick='openSlideEdit(<%- jsonAttr(c) %>)'>Düzenle</button>
                <form method="POST" action="/firma/panel/<%= c.id %>/durum" style="margin:0">
                  <input type="hidden" name="_method" value="PATCH">
                  <input type="hidden" name="durum" value="aktif">
                  <button type="submit" class="btn btn-danger-sm btn-sm">Aktif Et</button>
                </form>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </details>
    <% } %>
    </div>

  <!-- TAB: İSTATİSTİK -->
  <% } else if (tab === 'istatistik') { %>
    <div class="ipucu"><span class="ipucu-ikon">💡</span><span>Çalışan kartlarının kaç kez görüntülendiğini ve performansını burada görürsün. Üstteki kutudan isimle arayabilirsin.</span></div>
    <% const aramaMetniIst = (ara || '').toLocaleLowerCase('tr').trim(); %>
    <% const calisanlarIstatistik = aramaMetniIst
         ? calisanlar.filter(c => (c.ad || '').toLocaleLowerCase('tr').startsWith(aramaMetniIst) || (c.soyad || '').toLocaleLowerCase('tr').startsWith(aramaMetniIst))
         : calisanlar; %>
    <form method="GET" action="/" style="margin-bottom:16px;display:flex;gap:8px;max-width:380px;align-items:center">
      <input type="hidden" name="tab" value="istatistik">
      <input type="text" name="ara" placeholder="İsimle ara..." value="<%= ara || '' %>" oninput="aramaOtomatikGonder(this)"
             style="flex:1;height:32px;padding:0 12px;border-radius:7px;border:1px solid var(--border);background:var(--bg3);color:var(--text);font-size:var(--fs-sm);font-family:inherit">
      <button type="submit" class="btn btn-border btn-sm">Ara</button>
      <% if (ara) { %><a href="/?tab=istatistik" class="btn btn-ghost btn-sm">Temizle</a><% } %>
    </form>

    <button type="button" id="istatistikListeBtn" class="btn btn-border btn-sm" style="margin-bottom:14px" onclick="listeToggle('istatistikListeKutu','istatistikListeBtn','Tüm Listeyi Göster','Listeyi Gizle')"><%= ara ? 'Listeyi Gizle' : 'Tüm Listeyi Göster' %></button>
    <div id="istatistikListeKutu" style="display:<%= ara ? 'block' : 'none' %>">
    <div class="table-wrap">
      <table>
        <thead><tr><th class="sortable" onclick="tabloSirala(this)" style="cursor:pointer;user-select:none">Ad Soyad</th><th class="sortable" data-yon="desc" onclick="tabloSirala(this)" style="cursor:pointer;user-select:none">Görüntülenme ▼</th><th>Durum</th><th>Kart</th></tr></thead>
        <tbody>
          <% [...calisanlarIstatistik].sort((a,b) => (b.goruntuleme_sayisi||0) - (a.goruntuleme_sayisi||0)).forEach(c => { %>
          <tr>
            <td class="td-name"><%= c.ad %> <%= c.soyad %></td>
            <td style="font-weight:var(--fw-semibold);color:var(--gold)"><%= c.goruntuleme_sayisi || 0 %></td>
            <td><span class="badge badge-<%= c.durum %>"><%= c.durum %></span></td>
            <td>
              <% if (c.karta_yazildi) { %>
                <span style="color:var(--success);font-weight:600">✓ Yazıldı<% if (c.kart_kilitli) { %> <%- ikon('kilit', 13, 'ikon-inline') %><% } %></span>
                <form method="POST" action="/kurumsal/calisan/<%= c.id %>/kart-isaretle" style="display:inline">
                  <input type="hidden" name="yazildi" value="false">
                  <button type="submit" class="btn-link">Kaldır</button>
                </form>
              <% } else { %>
                <span style="color:var(--text-faint)">○ Yazılmadı</span>
                <form method="POST" action="/kurumsal/calisan/<%= c.id %>/kart-isaretle" style="display:inline">
                  <input type="hidden" name="yazildi" value="true">
                  <button type="submit" class="btn btn-border btn-sm">Yazıldı işaretle</button>
                </form>
              <% } %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    </div>

  <!-- TAB: ANALYTICS -->
  <% } else if (tab === 'analytics') { %>
    <% if (linkAnalytics.length) { %>
    <div class="analytics-grid">
      <% linkAnalytics.forEach(row => { %>
      <div class="analytics-card">
        <div>
          <div class="analytics-info-name"><%= row.ad %> <%= row.soyad %></div>
          <div class="analytics-info-tip"><%= row.tip %></div>
        </div>
        <div class="analytics-count"><%= row.sayi %></div>
      </div>
      <% }); %>
    </div>
    <% } else { %>
    <div class="table-wrap">
      <div class="empty-state">
        <div class="empty-state-icon"><%- ikon('grafik', 32, '') %></div>
        <div class="empty-state-title">Henüz tıklama verisi yok</div>
        <div class="empty-state-sub">Profil linkleri tıklandıkça burada görünür</div>
      </div>
    </div>
    <% } %>

  <!-- TAB: EXCEL -->
  <% } else if (tab === 'excel') { %>
    <div class="ipucu"><span class="ipucu-ikon">💡</span><span>Çok sayıda kaydı tek tek girmek yerine buradan topluca ekle: önce <b>Şablonu İndir</b>, Excel'i doldur, sonra <b>dosyayı seçip Yükle</b>. Çalışan ve eczane için ayrı şablon var.</span></div>
    <div class="excel-card">
      <h3>Excel ile toplu yükleme</h3>
      <p>Önce şablonu indirin, doldurun, ardından yükleyin. 100 çalışanı saniyeler içinde ekleyin.</p>
      <a href="/firma/panel/excel-sablon" class="btn btn-border" style="margin-bottom:20px;height:36px;">⬇ Şablonu İndir (.xlsx)</a>
      <form method="POST" action="/firma/panel/toplu-yukle" enctype="multipart/form-data" onsubmit="return formYukleniyorGoster(this, 'Yükleniyor...')">
        <div class="form-group">
          <label>Excel dosyası (.xlsx)</label>
          <input type="file" name="excel" accept=".xlsx,.xls" required>
        </div>
        <button type="submit" class="btn btn-gold" style="height:36px;">Yükle ve İçe Aktar</button>
      </form>
    </div>
    <% if (firma.paket === 'kurumsal') { %>
    <div class="excel-card" style="margin-top:20px">
      <h3>Eczane ile toplu yükleme</h3>
      <p>Eczane listesini Excel ile toplu ekleyin. İçe aktarılan eczaneler onaylanana kadar mobilde görünmez.</p>
      <a href="/kurumsal/eczane-sablon" class="btn btn-border" style="margin-bottom:20px;height:36px;">⬇ Eczane Şablonu İndir (.xlsx)</a>
      <form method="POST" action="/kurumsal/eczane-toplu-yukle" enctype="multipart/form-data" onsubmit="return formYukleniyorGoster(this, 'Yükleniyor...')">
        <div class="form-group">
          <label>Excel dosyası (.xlsx)</label>
          <input type="file" name="excel" accept=".xlsx,.xls" required>
        </div>
        <button type="submit" class="btn btn-gold" style="height:36px;">Yükle ve İçe Aktar</button>
      </form>
    </div>
    <% } %>

  <!-- TAB: İŞLEM GEÇMİŞİ -->
  <% } else if (tab === 'gecmis') { %>
    <% const islemEtiketleri = {
         calisan_pasife_alindi: 'Çalışan pasife alındı',
         calisan_sifre_degisti: 'Çalışan giriş şifresi değiştirildi',
         eczane_silindi: 'Eczane silindi',
         eczane_toplu_onayla: 'Eczaneler toplu onaylandı',
         eczane_toplu_pasife_al: 'Eczaneler toplu pasife alındı',
         eczane_toplu_aktif_yap: 'Eczaneler toplu aktif edildi',
         eczane_toplu_sil: 'Eczaneler toplu silindi',
         indirim_ayar_degisti: 'İndirim kampanyası ayarları değiştirildi',
       }; %>
    <% if (islemGecmisi.length) { %>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Tarih</th><th>İşlem</th><th>Detay</th></tr></thead>
        <tbody>
          <% islemGecmisi.forEach(g => { %>
          <tr>
            <td class="td-sub"><%= new Date(g.created_at).toLocaleString('tr-TR') %></td>
            <td class="td-name"><%= islemEtiketleri[g.islem] || g.islem %></td>
            <td><%= g.aciklama || '—' %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="table-wrap">
      <div class="empty-state">
        <div class="empty-state-icon"><%- ikon('pano', 32, '') %></div>
        <div class="empty-state-title">Henüz işlem geçmişi yok</div>
        <div class="empty-state-sub">Silme, pasife alma gibi riskli işlemler burada listelenir</div>
      </div>
    </div>
    <% } %>

  <!-- TAB: KURUMSAL İÇERİK -->
  <% } else if (tab === 'icerik' && firma.paket === 'kurumsal') { %>
    <div class="ipucu"><span class="ipucu-ikon">💡</span><span>Firmanın <b>logosu</b>, <b>kataloğu</b> ve <b>eczacı eğitim dokümanı</b>nı buradan yükle. Bunlar müşterinin gördüğü kartlarda görünür.</span></div>
    <style>
      .icr-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;margin-bottom:16px}
      .icr-card{padding:20px}
      .icr-head{display:flex;align-items:center;gap:10px;margin-bottom:4px}
      .icr-icon{width:34px;height:34px;border-radius:9px;background:var(--gold-dim);color:var(--gold);display:flex;align-items:center;justify-content:center;flex-shrink:0}
      .icr-title{font-size:14.5px;font-weight:700}
      .icr-sub{font-size:12px;color:var(--text-faint);margin-bottom:16px}
      .icr-field-label{font-size:11.5px;font-weight:600;color:var(--text-muted);margin-bottom:5px;display:block}
      .icr-status{display:flex;align-items:center;gap:8px;padding:9px 12px;border-radius:8px;background:var(--bg3);font-size:12.5px;margin-bottom:14px}
      .icr-status.bos{color:var(--text-faint)}
      .icr-status.dolu{color:var(--success)}
      .icr-status a{color:inherit;text-decoration:underline;text-underline-offset:2px}
      .icr-logo-preview{width:56px;height:56px;border-radius:12px;object-fit:contain;background:#fff;border:1px solid var(--border);flex-shrink:0}
      .icr-upload-row{display:flex;gap:8px;align-items:center}
      .icr-upload-row input[type=file]{flex:1;min-width:0;font-size:12px}
      .icr-sosyal-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px}
      .icr-sosyal-item label{display:flex;align-items:center;gap:7px;font-size:12px;font-weight:600;color:var(--text-muted);margin-bottom:5px}
      .icr-sosyal-item .ikon-inline{color:var(--gold);flex-shrink:0}
      .icr-section{margin-bottom:28px}
      .icr-section-head{display:flex;align-items:center;gap:10px;margin-bottom:14px}
      .icr-section-title{font-size:15.5px;font-weight:700}
      .icr-section-badge{font-size:10.5px;font-weight:600;color:var(--text-faint);background:var(--bg3);padding:3px 9px;border-radius:20px;text-transform:uppercase;letter-spacing:.03em}
    </style>

    <!-- BÖLÜM: RAF KARTI İÇERİĞİ (eczane/müşteri tarafı) -->
    <div class="icr-section">
      <div class="icr-section-head">
        <span class="icr-section-title">🏪 Raf Kartı İçeriği</span>
        <span class="icr-section-badge">Eczane · Müşteri tarafı</span>
      </div>
      <div class="icr-grid">
        <!-- Logo -->
        <div class="table-wrap icr-card">
          <div class="icr-head"><span class="icr-icon"><%- ikon('kamera', 17, '') %></span><span class="icr-title">Logo</span></div>
          <div class="icr-sub">Panel ve raf kartı sayfalarında görünür</div>
          <form method="POST" action="/kurumsal/logo" enctype="multipart/form-data" onsubmit="return formYukleniyorGoster(this, 'Yükleniyor...')">
            <div class="icr-upload-row" style="margin-bottom:12px">
              <% if (firma.logo_url) { %><img src="<%= firma.logo_url %>" alt="" class="icr-logo-preview"><% } else { %>
              <div class="icr-logo-preview" style="display:flex;align-items:center;justify-content:center;color:var(--text-faint);font-size:10px">Yok</div>
              <% } %>
              <input type="file" name="logo" id="logoInput" accept="image/*" required>
            </div>
            <button type="submit" class="btn btn-gold" style="width:100%">Logoyu Yükle</button>
          </form>
        </div>

        <!-- Katalog PDF -->
        <div class="table-wrap icr-card">
          <div class="icr-head"><span class="icr-icon"><%- ikon('pano', 17, '') %></span><span class="icr-title">Ürün Kataloğu</span></div>
          <div class="icr-sub">PDF — raf kartı sayfasında indirilebilir</div>
          <div class="icr-status <%= firma.katalog_url ? 'dolu' : 'bos' %>">
            <%- ikon(firma.katalog_url ? 'pano' : 'uyari', 14, '') %>
            <% if (firma.katalog_url) { %><a href="<%= firma.katalog_url %>" target="_blank">Mevcut kataloğu görüntüle</a><% } else { %>Henüz yüklenmedi<% } %>
          </div>
          <form method="POST" action="/kurumsal/katalog" enctype="multipart/form-data" onsubmit="return formYukleniyorGoster(this, 'Yükleniyor...')">
            <div class="icr-upload-row" style="margin-bottom:12px">
              <input type="file" name="katalog" accept="application/pdf" required>
            </div>
            <button type="submit" class="btn btn-gold" style="width:100%">Kataloğu Yükle</button>
          </form>
        </div>

        <!-- Sosyal / Web Linkleri -->
        <div class="table-wrap icr-card" style="grid-column:1/-1">
          <div class="icr-head"><span class="icr-icon"><%- ikon('konum', 17, '') %></span><span class="icr-title">Web ve Sosyal Medya Linkleri</span></div>
          <div class="icr-sub">Raf kartı sayfasında ikon olarak görünür</div>
          <form method="POST" action="/kurumsal/icerik">
            <div class="icr-sosyal-grid" style="margin-bottom:16px">
              <div class="icr-sosyal-item"><label><%- ikon('konum', 14, '') %>Web sitesi</label><input name="website" placeholder="https://..." value="<%= firma.website || '' %>"></div>
              <div class="icr-sosyal-item"><label><%- ikon('kamera', 14, '') %>Instagram</label><input name="instagram" placeholder="kullaniciadi" value="<%= firma.instagram || '' %>"></div>
              <div class="icr-sosyal-item"><label><%- ikon('kullanici', 14, '') %>LinkedIn</label><input name="linkedin" placeholder="şirket sayfası" value="<%= firma.linkedin || '' %>"></div>
              <div class="icr-sosyal-item"><label><%- ikon('grafik', 14, '') %>Twitter / X</label><input name="twitter" placeholder="kullaniciadi" value="<%= firma.twitter || '' %>"></div>
              <div class="icr-sosyal-item"><label><%- ikon('kamera', 14, '') %>YouTube</label><input name="youtube" placeholder="kanal linki" value="<%= firma.youtube || '' %>"></div>
              <div class="icr-sosyal-item"><label><%- ikon('kamera', 14, '') %>TikTok</label><input name="tiktok" placeholder="kullaniciadi" value="<%= firma.tiktok || '' %>"></div>
              <div class="icr-sosyal-item"><label><%- ikon('kullanici', 14, '') %>WhatsApp</label><input name="whatsapp" placeholder="+90 5xx xxx xx xx" value="<%= firma.whatsapp || '' %>"></div>
            </div>
            <button type="submit" class="btn btn-gold">Linkleri Kaydet</button>
          </form>
        </div>
      </div>
    </div>

    <!-- BÖLÜM: ECZACI SAYFASI İÇERİĞİ (eczacı tarafı) -->
    <div class="icr-section">
      <div class="icr-section-head">
        <span class="icr-section-title">💊 Eczacı Sayfası İçeriği</span>
        <span class="icr-section-badge">Eczacı tarafı</span>
      </div>
      <div class="icr-grid">
        <!-- Eczacı Sayfası -->
        <div class="table-wrap icr-card">
          <div class="icr-head"><span class="icr-icon"><%- ikon('kullanici', 17, '') %></span><span class="icr-title">Kampanya / Eğitim Metni</span></div>
          <div class="icr-sub">Eczacılara özel kampanya / eğitim içeriği</div>
          <form method="POST" action="/kurumsal/eczaci-icerik" style="display:flex;flex-direction:column;gap:12px">
            <div>
              <span class="icr-field-label">Kampanya başlığı</span>
              <input name="eczaci_baslik" placeholder="Örn. Kış Sezonu Vitamin Kampanyası" value="<%= firma.eczaci_baslik || '' %>">
            </div>
            <div>
              <span class="icr-field-label">Kampanya / eğitim metni</span>
              <textarea name="eczaci_metin" placeholder="Eczacılara gösterilecek açıklama metni" rows="4"><%= firma.eczaci_metin || '' %></textarea>
            </div>
            <div>
              <span class="icr-field-label">YouTube video linki</span>
              <input name="eczaci_video_url" placeholder="https://youtube.com/..." value="<%= firma.eczaci_video_url || '' %>">
            </div>
            <button type="submit" class="btn btn-gold">Kaydet</button>
          </form>
        </div>

        <!-- Eğitim Dokümanı -->
        <div class="table-wrap icr-card">
          <div class="icr-head"><span class="icr-icon"><%- ikon('pano', 17, '') %></span><span class="icr-title">Eğitim Dokümanı</span></div>
          <div class="icr-sub">PDF — eczacı sayfasında indirilebilir</div>
          <div class="icr-status <%= firma.eczaci_pdf_url ? 'dolu' : 'bos' %>">
            <%- ikon(firma.eczaci_pdf_url ? 'pano' : 'uyari', 14, '') %>
            <% if (firma.eczaci_pdf_url) { %><a href="<%= firma.eczaci_pdf_url %>" target="_blank">Mevcut dokümanı görüntüle</a><% } else { %>Henüz yüklenmedi<% } %>
          </div>
          <form method="POST" action="/kurumsal/eczaci-pdf" enctype="multipart/form-data" onsubmit="return formYukleniyorGoster(this, 'Yükleniyor...')">
            <div class="icr-upload-row" style="margin-bottom:12px">
              <input type="file" name="eczaci_pdf" accept="application/pdf" required>
            </div>
            <button type="submit" class="btn btn-gold" style="width:100%">Dokümanı Yükle</button>
          </form>
        </div>
      </div>
    </div>

  <!-- TAB: ÜRÜNLER -->
  <% } else if (tab === 'urunler' && firma.paket === 'kurumsal') { %>
    <div class="ipucu"><span class="ipucu-ikon">💡</span><span>Ürünlerini buradan ekle (<b>+ Ürün Ekle</b>). Fotoğraf ve broşür (PDF) ekleyebilirsin; ürünler raf kartında listelenir.</span></div>
    <div class="table-wrap" style="padding:20px;margin-bottom:16px;max-width:560px">
      <h3 style="margin-bottom:12px">Yeni Ürün Ekle</h3>
      <form method="POST" action="/kurumsal/urunler" enctype="multipart/form-data" style="display:flex;flex-direction:column;gap:8px" onsubmit="return formYukleniyorGoster(this, 'Kaydediliyor...')">
        <input name="ad" placeholder="Ürün adı *" required>
        <textarea name="aciklama" placeholder="Kısa açıklama" rows="3"></textarea>
        <input type="file" name="foto" id="urunFotoInput" accept="image/*">
        <button type="submit" class="btn btn-gold">Ekle</button>
      </form>
    </div>

    <% if (urunler.length) { %>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Foto</th><th>Ad</th><th>Durum</th><th>PDF</th><th>İşlem</th></tr></thead>
        <tbody>
          <% urunler.forEach(u => { %>
          <tr>
            <td><% if (u.foto_url) { %><img src="<%= u.foto_url %>" alt="" style="width:44px;height:44px;border-radius:8px;object-fit:cover"><% } else { %>—<% } %></td>
