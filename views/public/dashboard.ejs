    </div>
  </div>
  <% } %>

  <!-- SUB TABS -->
  <% if (aktifGrup !== 'genel' && tab !== 'home') { %>
  <div class="dash-tabs">
    <% if (aktifGrup === 'calisanlar') { %>
    <a href="/?tab=calisanlar" class="dash-tab <%= tab === 'calisanlar' ? 'active' : '' %>">Çalışanlar</a>
    <a href="/?tab=istatistik" class="dash-tab <%= tab === 'istatistik' ? 'active' : '' %>">İstatistik</a>
    <a href="/?tab=organizasyon" class="dash-tab <%= tab === 'organizasyon' ? 'active' : '' %>">Organizasyon</a>
    <a href="/?tab=excel"      class="dash-tab <%= tab === 'excel'      ? 'active' : '' %>">Excel Yükle</a>
    <% if (!rol || rol === 'tam_yetkili') { %>
    <a href="/?tab=kullanicilar" class="dash-tab <%= tab === 'kullanicilar' ? 'active' : '' %>">Kullanıcılar</a>
    <% } %>
    <% } else if (aktifGrup === 'eczane') { %>
    <a href="/?tab=raf"     class="dash-tab <%= tab === 'raf'     ? 'active' : '' %>">Raf Kartları</a>
    <a href="/?tab=indirim" class="dash-tab <%= tab === 'indirim' ? 'active' : '' %>">İndirim</a>
    <% } else if (aktifGrup === 'icerik') { %>
    <a href="/?tab=icerik"  class="dash-tab <%= tab === 'icerik'  ? 'active' : '' %>">İçerik</a>
    <a href="/?tab=urunler" class="dash-tab <%= tab === 'urunler' ? 'active' : '' %>">Ürünler</a>
    <% } else if (aktifGrup === 'saha') { %>
    <% if (firma.paket === 'kurumsal') { %>
    <a href="/?tab=saha" class="dash-tab <%= tab === 'saha' ? 'active' : '' %>">Saha İstatistikleri</a>
    <% } %>
    <a href="/?tab=analytics" class="dash-tab <%= tab === 'analytics' ? 'active' : '' %>">Link Analytics</a>
    <a href="/?tab=gecmis"    class="dash-tab <%= tab === 'gecmis'    ? 'active' : '' %>">İşlem Geçmişi</a>
    <% } %>
  </div>
  <% } %>

  <!-- TAB: ORGANİZASYON -->
  <% if (tab === 'organizasyon') { %>
    <% if (!hiyerarsiAgaci || !hiyerarsiAgaci.length) { %>
    <div class="table-wrap"><div class="empty-state">
      <div class="empty-state-title">Hiyerarşi tanımlı değil</div>
      <div class="empty-state-sub">Çalışanlara "amiri" atadıkça organizasyon şeması burada oluşur.</div>
    </div></div>
    <% } else { %>
    <div class="table-wrap" style="padding:14px 16px;margin-bottom:10px;display:flex;gap:10px;align-items:center;flex-wrap:wrap">
      <strong style="font-size:var(--fs-md)">Organizasyon Şeması</strong>
      <span style="font-size:var(--fs-xs);color:var(--text-faint)">Düğüme tıkla → alt ekibi aç/kapa · son 90 gün ekip ziyaretleri</span>
      <span style="margin-left:auto;display:flex;gap:8px">
        <button type="button" class="btn btn-border btn-sm" onclick="orgTumunuAc()">Tümünü Aç</button>
        <button type="button" class="btn btn-border btn-sm" onclick="orgTumunuKapat()">Tümünü Kapat</button>
      </span>
    </div>
    <div class="table-wrap" style="padding:8px;height:72vh;overflow:hidden;background:var(--surface)">
      <svg id="orgSvg" preserveAspectRatio="xMidYMid meet" style="display:block;width:100%;height:100%"></svg>
    </div>
    <script>
      (function () {
        const orgVeri = <%- JSON.stringify(hiyerarsiAgaci) %>;
        const svg = document.getElementById('orgSvg');
        const NS = 'http://www.w3.org/2000/svg';
        const NW = 216, NH = 44, COLGAP = 66, ROWGAP = 12, PAD = 16;
        const renkler = [
          { bg: '#efeafc', br: '#c4b8ec', tx: '#4a3d8f' }, // kök (lavanta)
          { bg: '#dde9fb', br: '#93b6e6', tx: '#25497e' }, // 2. seviye (mavi)
          { bg: '#d7f0e3', br: '#8ecfae', tx: '#1f6b4a' }, // 3. seviye (yeşil)
          { bg: '#e4f3e6', br: '#aad9b3', tx: '#396b41' }  // 4+ (açık yeşil)
        ];
        const kapali = new Set();

        function hesapla() {
          let leaf = 0;
          const yer = new Map();
          const baglar = [];
          function walk(n, derinlik) {
            const cocuk = n.cocuklar || [];
            const kapaliMi = kapali.has(n.id);
            const gorunen = kapaliMi ? [] : cocuk;
            let y;
            if (!gorunen.length) {
              y = leaf * (NH + ROWGAP) + NH / 2; leaf++;
            } else {
              const ys = gorunen.map(c => walk(c, derinlik + 1));
              y = (ys[0] + ys[ys.length - 1]) / 2;
              gorunen.forEach(c => baglar.push([n, c]));
            }
            yer.set(n, { x: derinlik * (NW + COLGAP) + PAD, y: y + PAD, derinlik, dolu: cocuk.length > 0, kapaliMi });
            return y;
          }
          orgVeri.forEach(k => walk(k, 0));
          let maxX = 0;
          yer.forEach(p => { if (p.x > maxX) maxX = p.x; });
          return { yer, baglar, w: maxX + NW + PAD, h: leaf * (NH + ROWGAP) + PAD * 2 };
        }

        function el(tag, attrs) {
          const e = document.createElementNS(NS, tag);
          for (const k in attrs) e.setAttribute(k, attrs[k]);
          return e;
        }

        function ciz() {
          const { yer, baglar, w, h } = hesapla();
          svg.setAttribute('viewBox', '0 0 ' + w + ' ' + h);
          while (svg.firstChild) svg.removeChild(svg.firstChild);

          baglar.forEach(([p, c]) => {
            const pp = yer.get(p), cp = yer.get(c);
            const x1 = pp.x + NW, y1 = pp.y, x2 = cp.x, y2 = cp.y, mx = (x1 + x2) / 2;
            svg.appendChild(el('path', {
              d: 'M' + x1 + ',' + y1 + ' C' + mx + ',' + y1 + ' ' + mx + ',' + y2 + ' ' + x2 + ',' + y2,
              fill: 'none', stroke: '#c8cdd6', 'stroke-width': '1.6'
            }));
          });

          yer.forEach((pos, n) => {
            const r = renkler[Math.min(pos.derinlik, renkler.length - 1)];
            const g = el('g', {});
            g.style.cursor = pos.dolu ? 'pointer' : 'default';
            if (pos.dolu) g.addEventListener('click', () => {
              if (kapali.has(n.id)) kapali.delete(n.id); else kapali.add(n.id);
              ciz();
            });
            g.appendChild(el('rect', {
              x: pos.x, y: pos.y - NH / 2, width: NW, height: NH, rx: 11,
              fill: r.bg, stroke: r.br, 'stroke-width': '1.6'
            }));
            const t1 = el('text', { x: pos.x + 13, y: pos.y - 3, fill: r.tx, 'font-size': '12.5', 'font-weight': '700' });
            t1.textContent = (n.ad + ' ' + n.soyad).slice(0, 26);
            g.appendChild(t1);
            const rozet = pos.dolu ? ('👥 ' + n.ekipZiyaret + (pos.kapaliMi ? '  ▸' : '  ▾')) : ('🧍 ' + n.kendiZiyaret);
            const t2 = el('text', { x: pos.x + 13, y: pos.y + 13, fill: r.tx, 'font-size': '10.5', opacity: '0.82' });
            t2.textContent = ((n.unvan || '') + ' · ' + rozet).slice(0, 34);
            g.appendChild(t2);
            svg.appendChild(g);
          });
        }

        window.orgTumunuAc = function () { kapali.clear(); ciz(); };
        window.orgTumunuKapat = function () {
          kapali.clear();
          (function all(n) {
            if ((n.cocuklar || []).length) { kapali.add(n.id); n.cocuklar.forEach(all); }
          });
          orgVeri.forEach(function tara(n) { if ((n.cocuklar || []).length) { kapali.add(n.id); n.cocuklar.forEach(tara); } });
          ciz();
        };
        ciz();
      })();
    </script>
    <% } %>
  <% } %>

  <!-- TAB: GENEL BAKIŞ -->
  <% if (tab === 'genel') { %>
    <% if (!genelBakis) { %>
    <div class="table-wrap">
      <div class="empty-state">
        <div class="empty-state-icon"><%- ikon('grafik', 32, '') %></div>
        <div class="empty-state-title">Henüz veri yok</div>
        <div class="empty-state-sub">Profil linkleri paylaşıldıkça burada trendler görünür</div>
      </div>
    </div>
    <% } else { %>
    <div class="stat-row" style="grid-template-columns:repeat(2,1fr);margin-bottom:16px">
      <div class="stat-card">
        <div class="stat-card-n"><%= genelBakis.tiklamaBuDonem %></div>
        <div class="stat-card-l">Son 7 gün — toplam tıklama</div>
        <div style="margin-top:6px">
          <% if (genelBakis.tiklamaDegisim === null) { %>
            <span style="color:var(--text-faint);font-size:var(--fs-xs)">yeni veri</span>
          <% } else if (genelBakis.tiklamaDegisim > 0) { %>
            <span style="color:var(--success);font-size:var(--fs-xs);font-weight:var(--fw-semibold)">↑ %<%= genelBakis.tiklamaDegisim %> önceki haftaya göre</span>
          <% } else if (genelBakis.tiklamaDegisim < 0) { %>
            <span style="color:var(--danger);font-size:var(--fs-xs);font-weight:var(--fw-semibold)">↓ %<%= Math.abs(genelBakis.tiklamaDegisim) %> önceki haftaya göre</span>
          <% } else { %>
            <span style="color:var(--text-faint);font-size:var(--fs-xs)">önceki haftayla aynı</span>
          <% } %>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-card-n"><%= genelBakis.goruntulemeBuDonem %></div>
        <div class="stat-card-l">Son 7 gün — profil görüntüleme</div>
        <div style="margin-top:6px">
          <% if (genelBakis.goruntulemeDegisim === null) { %>
            <span style="color:var(--text-faint);font-size:var(--fs-xs)">yeni veri</span>
          <% } else if (genelBakis.goruntulemeDegisim > 0) { %>
            <span style="color:var(--success);font-size:var(--fs-xs);font-weight:var(--fw-semibold)">↑ %<%= genelBakis.goruntulemeDegisim %> önceki haftaya göre</span>
          <% } else if (genelBakis.goruntulemeDegisim < 0) { %>
            <span style="color:var(--danger);font-size:var(--fs-xs);font-weight:var(--fw-semibold)">↓ %<%= Math.abs(genelBakis.goruntulemeDegisim) %> önceki haftaya göre</span>
          <% } else { %>
            <span style="color:var(--text-faint);font-size:var(--fs-xs)">önceki haftayla aynı</span>
          <% } %>
        </div>
      </div>
    </div>
    <div class="table-wrap" style="padding:20px">
      <h3 style="margin-bottom:12px">Son 14 Gün — Tıklama Trendi</h3>
      <canvas id="chartGenelSparkline" height="60"></canvas>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
      const genelSparkline = <%- JSON.stringify(genelBakis.sparkline) %>;
      new Chart(document.getElementById('chartGenelSparkline'), {
        type: 'line',
        data: {
          labels: genelSparkline.map((_, i) => i - 13),
          datasets: [{ data: genelSparkline, borderColor: '#c8a84b', backgroundColor: 'rgba(200,168,75,0.1)', fill: true, tension: 0.3, pointRadius: 0 }]
        },
        options: { plugins: { legend: { display: false } }, scales: { x: { display: false }, y: { display: false } } }
      });
    </script>
    <div class="table-wrap" style="padding:20px;margin-top:16px">
      <h3 style="margin-bottom:12px">Son 90 Gün — Aktivite Yoğunluğu</h3>
      <div class="isi-haritasi">
        <% genelBakis.isiHaritasi.forEach(g => { %>
        <div class="isi-haritasi-gun" data-seviye="<%= g.seviye %>" title="<%= g.tarih %>: <%= g.sayi %> etkileşim"></div>
        <% }) %>
      </div>
    </div>
    <% if (genelBakis.tiklamaDagilimi.length) { %>
    <div class="table-wrap" style="padding:20px;margin-top:16px">
      <h3 style="margin-bottom:12px">Tıklama Dağılımı — Son 90 Gün</h3>
      <canvas id="chartTiklamaDagilimi" height="80"></canvas>
    </div>
    <script>
      const dagilimVeri = <%- JSON.stringify(genelBakis.tiklamaDagilimi) %>;
      new Chart(document.getElementById('chartTiklamaDagilimi'), {
        type: 'doughnut',
        data: {
          labels: dagilimVeri.map(r => r.tip),
          datasets: [{ data: dagilimVeri.map(r => r.sayi), backgroundColor: ['#c8a84b','#3a7ca5','#7a9e7e','#a5673a','#8a5ca5','#a53a5c','#5ca58a','#a5a53a'] }]
        }
      });
    </script>
    <% } %>
    <div class="table-wrap liderlik-tablosu" style="padding:20px;margin-top:16px">
      <h3 style="margin-bottom:12px">Liderlik Tablosu — Son 30 Gün En Aktif Çalışanlar</h3>
      <% if (!genelBakis.liderlikTablosu.length) { %>
      <div class="empty-state-sub">Henüz veri yok</div>
      <% } else { %>
      <table>
        <thead><tr><th>Çalışan</th><th>Etkileşim</th></tr></thead>
        <tbody>
          <% genelBakis.liderlikTablosu.forEach((r, i) => { %>
          <tr><td><%= i + 1 %>. <%= r.ad %> <%= r.soyad %></td><td><%= r.sayi %></td></tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
    <% if (firma.paket === 'kurumsal') { %>
    <div class="table-wrap" style="padding:20px;margin-top:16px">
      <h3 style="margin-bottom:12px">Gelişmiş Rapor</h3>
      <p style="font-size:var(--fs-sm);color:var(--text-muted);margin-bottom:12px">Ziyaretler, eczane özeti, temsilci özeti ve indirim kullanımını tek dosyada indirin.</p>
      <a href="/kurumsal/rapor-excel" class="btn btn-border" style="height:36px;">⬇ Gelişmiş Raporu İndir (.xlsx)</a>
      <a href="/kurumsal/rapor-pdf" class="btn btn-border" style="height:36px;margin-left:8px;">⬇ Haftalık Özet PDF</a>
    </div>
    <% } %>
    <% } %>

  <!-- TAB: KULLANICILAR -->
  <% } else if (tab === 'kullanicilar') { %>
    <div class="table-wrap" style="padding:20px;margin-bottom:16px">
      <h3 style="margin-bottom:12px">Yeni Kullanıcı Davet Et</h3>
      <form method="POST" action="/firma/kullanicilar/ekle" style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end">
        <div class="field" style="min-width:160px">
          <label>Ad Soyad</label>
          <input name="ad" required>
        </div>
        <div class="field" style="min-width:200px">
          <label>E-posta</label>
          <input type="email" name="email" required>
        </div>
        <div class="field" style="min-width:160px">
          <label>Şifre</label>
          <input type="text" name="sifre" required minlength="6">
        </div>
        <div class="field" style="min-width:160px">
          <label>Rol</label>
          <select name="rol" required>
            <option value="tam_yetkili">Tam Yetkili</option>
            <option value="sadece_calisan">Sadece Çalışan Yönetimi</option>
            <option value="sadece_saha">Sadece Saha/Eczane</option>
          </select>
        </div>
        <button type="submit" class="btn btn-gold" style="height:36px">Ekle</button>
      </form>
    </div>
    <% if (!kullanicilarListesi.length) { %>
    <div class="table-wrap">
      <div class="empty-state">
        <div class="empty-state-icon"><%- ikon('kullanici', 32, '') %></div>
        <div class="empty-state-title">Henüz ek kullanıcı yok</div>
        <div class="empty-state-sub">Yukarıdan davet ederek başlayın</div>
      </div>
    </div>
    <% } else { %>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Ad Soyad</th><th>E-posta</th><th>Rol</th><th>İşlem</th></tr></thead>
        <tbody>
          <% kullanicilarListesi.forEach(k => { %>
          <tr>
            <td class="td-name"><%= k.ad %></td>
            <td><%= k.email %></td>
            <td><%= k.rol === 'tam_yetkili' ? 'Tam Yetkili' : k.rol === 'sadece_calisan' ? 'Sadece Çalışan' : 'Sadece Saha' %></td>
            <td>
              <form method="POST" action="/firma/kullanicilar/<%= k.id %>/sil" style="display:inline" onsubmit="return confirm('<%= k.ad %> kaldırılsın mı?')">
                <button type="submit" class="btn-link">Kaldır</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>

  <!-- TAB: ÇALIŞANLAR -->
  <% } else if (tab === 'calisanlar') { %>
    <% const aramaMetni = (ara || '').toLowerCase().trim(); %>
    <% const calisanlarFiltreli = aramaMetni
         ? calisanlar.filter(c => (c.ad + ' ' + c.soyad + ' ' + (c.email || '')).toLowerCase().includes(aramaMetni))
         : calisanlar; %>
    <% const aktifCalisanlarTum = calisanlarFiltreli.filter(c => c.durum === 'aktif'); %>
    <% const pasifCalisanlar = calisanlarFiltreli.filter(c => c.durum === 'pasif'); %>
    <% const SAYFA_BOYUTU = 20; %>
    <% const toplamSayfa = Math.max(1, Math.ceil(aktifCalisanlarTum.length / SAYFA_BOYUTU)); %>
    <% const mevcutSayfa = Math.min(Math.max(sayfa || 1, 1), toplamSayfa); %>
    <% const aktifCalisanlar = aktifCalisanlarTum.slice((mevcutSayfa - 1) * SAYFA_BOYUTU, mevcutSayfa * SAYFA_BOYUTU); %>

    <form method="GET" action="/" style="margin-bottom:16px;display:flex;gap:8px;max-width:380px;align-items:center">
      <input type="hidden" name="tab" value="calisanlar">
      <input type="text" name="ara" placeholder="İsim veya e-posta ara..." value="<%= ara || '' %>"
             style="flex:1;height:32px;padding:0 12px;border-radius:7px;border:1px solid var(--border);background:var(--bg3);color:var(--text);font-size:var(--fs-sm);font-family:inherit">
      <button type="submit" class="btn btn-border btn-sm">Ara</button>
      <% if (ara) { %><a href="/?tab=calisanlar" class="btn btn-ghost btn-sm">Temizle</a><% } %>
    </form>

    <% if (aktifCalisanlar.length) { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Ad Soyad</th>
            <th>Unvan / Departman</th>
            <th>Profil URL</th>
            <th>Durum</th>
            <th>İşlem</th>
          </tr>
        </thead>
        <tbody>
          <% aktifCalisanlar.forEach(c => { %>
          <tr class="tr-tiklanabilir" onclick='calisanDetayGoster(event, <%- jsonAttr(c) %>)'>
            <td>
              <div class="td-name"><%= c.ad %> <%= c.soyad %></div>
            </td>
            <td>
              <div style="font-size:var(--fs-xs);color:var(--text-muted)"><%= c.unvan || '—' %></div>
              <div class="td-sub"><%= c.departman || '' %></div>
            </td>
            <td class="td-url">
              <a href="/<%= firma.slug %>/<%= c.slug %>" target="_blank">/<%= firma.slug %>/<%= c.slug %></a>
            </td>
            <td>
              <span class="badge badge-<%= c.durum %>"><%= c.durum %></span>
              <% if (!c.onayli) { %>
                <div style="margin-top:6px">
                  <span class="badge badge-beklemede">Onay Bekliyor</span>
                  <form method="POST" action="/firma/panel/calisan/<%= c.id %>/onayla" style="display:inline">
                    <button type="submit" class="btn btn-gold btn-sm">Onayla</button>
                  </form>
                </div>
              <% } %>
            </td>
            <td>
              <div class="td-actions">
                <% if (!c.foto_url) { %>
                  <button class="btn btn-warning-sm btn-sm" onclick='openSlideEdit(<%- jsonAttr(c) %>)'><%- ikon('kamera') %>Fotoğraf Ekle</button>
                <% } %>
                <button class="btn btn-border btn-sm" onclick='openSlideEdit(<%- jsonAttr(c) %>)'>Düzenle</button>
                <form method="POST" action="/firma/panel/<%= c.id %>/durum" style="margin:0">
                  <input type="hidden" name="_method" value="PATCH">
                  <input type="hidden" name="durum" value="<%= c.durum === 'aktif' ? 'pasif' : 'aktif' %>">
                  <button type="submit" class="btn btn-danger-sm btn-sm"><%= c.durum === 'aktif' ? 'Pasife Al' : 'Aktif Et' %></button>
                </form>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% if (toplamSayfa > 1) { %>
    <div style="display:flex;gap:8px;align-items:center;justify-content:center;margin:16px 0">
      <% if (mevcutSayfa > 1) { %>
        <a class="btn btn-border btn-sm" href="/?tab=calisanlar&ara=<%= encodeURIComponent(ara || '') %>&sayfa=<%= mevcutSayfa - 1 %>">← Önceki</a>
      <% } %>
      <span style="font-size:var(--fs-xs);color:var(--text-muted)">Sayfa <%= mevcutSayfa %> / <%= toplamSayfa %></span>
      <% if (mevcutSayfa < toplamSayfa) { %>
        <a class="btn btn-border btn-sm" href="/?tab=calisanlar&ara=<%= encodeURIComponent(ara || '') %>&sayfa=<%= mevcutSayfa + 1 %>">Sonraki →</a>
      <% } %>
    </div>
    <% } %>
    <% } else if (!pasifCalisanlar.length) { %>
    <div class="table-wrap">
      <div class="empty-state">
        <div class="empty-state-icon"><%- ikon('kullanici', 32, '') %></div>
        <div class="empty-state-title">Henüz çalışan yok</div>
        <div class="empty-state-sub">İlk çalışanı ekleyerek başlayın</div>
        <button class="btn btn-gold" onclick="openSlide()">+ Yeni Çalışan Ekle</button>
      </div>
    </div>
    <% } %>

    <% if (pasifCalisanlar.length) { %>
    <details class="table-wrap" style="padding:0">
      <summary style="cursor:pointer;padding:14px 20px;font-weight:600;color:var(--text-muted)">Pasif Çalışanlar (<%= pasifCalisanlar.length %>)</summary>
      <table>
        <thead>
          <tr>
            <th>Ad Soyad</th>
            <th>Unvan / Departman</th>
            <th>Profil URL</th>
            <th>Durum</th>
            <th>İşlem</th>
          </tr>
        </thead>
        <tbody>
          <% pasifCalisanlar.forEach(c => { %>
          <tr>
            <td>
              <div class="td-name"><%= c.ad %> <%= c.soyad %></div>
            </td>
            <td>
              <div style="font-size:var(--fs-xs);color:var(--text-muted)"><%= c.unvan || '—' %></div>
              <div class="td-sub"><%= c.departman || '' %></div>
            </td>
            <td class="td-url">
              <a href="/<%= firma.slug %>/<%= c.slug %>" target="_blank">/<%= firma.slug %>/<%= c.slug %></a>
            </td>
            <td>
              <span class="badge badge-<%= c.durum %>"><%= c.durum %></span>
            </td>
            <td>
              <div class="td-actions">
                <% if (!c.foto_url) { %>
                  <button class="btn btn-warning-sm btn-sm" onclick='openSlideEdit(<%- jsonAttr(c) %>)'><%- ikon('kamera') %>Fotoğraf Ekle</button>
                <% } %>
                <button class="btn btn-border btn-sm" onclick='openSlideEdit(<%- jsonAttr(c) %>)'>Düzenle</button>
                <form method="POST" action="/firma/panel/<%= c.id %>/durum" style="margin:0">
                  <input type="hidden" name="_method" value="PATCH">
                  <input type="hidden" name="durum" value="aktif">
                  <button type="submit" class="btn btn-danger-sm btn-sm">Aktif Et</button>
                </form>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </details>
    <% } %>

  <!-- TAB: İSTATİSTİK -->
  <% } else if (tab === 'istatistik') { %>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Ad Soyad</th><th>Görüntülenme</th><th>Durum</th><th>Kart</th></tr></thead>
        <tbody>
          <% [...calisanlar].sort((a,b) => (b.goruntuleme_sayisi||0) - (a.goruntuleme_sayisi||0)).forEach(c => { %>
          <tr>
            <td class="td-name"><%= c.ad %> <%= c.soyad %></td>
            <td style="font-weight:var(--fw-semibold);color:var(--gold)"><%= c.goruntuleme_sayisi || 0 %></td>
            <td><span class="badge badge-<%= c.durum %>"><%= c.durum %></span></td>
            <td>
              <% if (c.karta_yazildi) { %>
                <span style="color:var(--success);font-weight:600">✓ Yazıldı<% if (c.kart_kilitli) { %> <%- ikon('kilit', 13, 'ikon-inline') %><% } %></span>
                <form method="POST" action="/kurumsal/calisan/<%= c.id %>/kart-isaretle" style="display:inline">
                  <input type="hidden" name="yazildi" value="false">
                  <button type="submit" class="btn-link">Kaldır</button>
                </form>
              <% } else { %>
                <span style="color:var(--text-faint)">○ Yazılmadı</span>
                <form method="POST" action="/kurumsal/calisan/<%= c.id %>/kart-isaretle" style="display:inline">
                  <input type="hidden" name="yazildi" value="true">
                  <button type="submit" class="btn btn-border btn-sm">Yazıldı işaretle</button>
                </form>
              <% } %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

  <!-- TAB: ANALYTICS -->
  <% } else if (tab === 'analytics') { %>
    <% if (linkAnalytics.length) { %>
    <div class="analytics-grid">
      <% linkAnalytics.forEach(row => { %>
      <div class="analytics-card">
        <div>
          <div class="analytics-info-name"><%= row.ad %> <%= row.soyad %></div>
          <div class="analytics-info-tip"><%= row.tip %></div>
        </div>
        <div class="analytics-count"><%= row.sayi %></div>
      </div>
      <% }); %>
    </div>
    <% } else { %>
    <div class="table-wrap">
      <div class="empty-state">
        <div class="empty-state-icon"><%- ikon('grafik', 32, '') %></div>
        <div class="empty-state-title">Henüz tıklama verisi yok</div>
        <div class="empty-state-sub">Profil linkleri tıklandıkça burada görünür</div>
      </div>
    </div>
    <% } %>

  <!-- TAB: EXCEL -->
  <% } else if (tab === 'excel') { %>
    <div class="excel-card">
      <h3>Excel ile toplu yükleme</h3>
      <p>Önce şablonu indirin, doldurun, ardından yükleyin. 100 çalışanı saniyeler içinde ekleyin.</p>
      <a href="/firma/panel/excel-sablon" class="btn btn-border" style="margin-bottom:20px;height:36px;">⬇ Şablonu İndir (.xlsx)</a>
      <form method="POST" action="/firma/panel/toplu-yukle" enctype="multipart/form-data" onsubmit="return formYukleniyorGoster(this, 'Yükleniyor...')">
        <div class="form-group">
          <label>Excel dosyası (.xlsx)</label>
          <input type="file" name="excel" accept=".xlsx,.xls" required>
        </div>
        <button type="submit" class="btn btn-gold" style="height:36px;">Yükle ve İçe Aktar</button>
      </form>
    </div>
    <% if (firma.paket === 'kurumsal') { %>
    <div class="excel-card" style="margin-top:20px">
      <h3>Eczane ile toplu yükleme</h3>
      <p>Eczane listesini Excel ile toplu ekleyin. İçe aktarılan eczaneler onaylanana kadar mobilde görünmez.</p>
      <a href="/kurumsal/eczane-sablon" class="btn btn-border" style="margin-bottom:20px;height:36px;">⬇ Eczane Şablonu İndir (.xlsx)</a>
      <form method="POST" action="/kurumsal/eczane-toplu-yukle" enctype="multipart/form-data" onsubmit="return formYukleniyorGoster(this, 'Yükleniyor...')">
        <div class="form-group">
          <label>Excel dosyası (.xlsx)</label>
          <input type="file" name="excel" accept=".xlsx,.xls" required>
        </div>
        <button type="submit" class="btn btn-gold" style="height:36px;">Yükle ve İçe Aktar</button>
      </form>
    </div>
    <% } %>

  <!-- TAB: İŞLEM GEÇMİŞİ -->
  <% } else if (tab === 'gecmis') { %>
    <% const islemEtiketleri = {
         calisan_pasife_alindi: 'Çalışan pasife alındı',
         calisan_sifre_degisti: 'Çalışan giriş şifresi değiştirildi',
         eczane_silindi: 'Eczane silindi',
         eczane_toplu_onayla: 'Eczaneler toplu onaylandı',
         eczane_toplu_pasife_al: 'Eczaneler toplu pasife alındı',
         eczane_toplu_aktif_yap: 'Eczaneler toplu aktif edildi',
         eczane_toplu_sil: 'Eczaneler toplu silindi',
         indirim_ayar_degisti: 'İndirim kampanyası ayarları değiştirildi',
       }; %>
    <% if (islemGecmisi.length) { %>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Tarih</th><th>İşlem</th><th>Detay</th></tr></thead>
        <tbody>
          <% islemGecmisi.forEach(g => { %>
          <tr>
            <td class="td-sub"><%= new Date(g.created_at).toLocaleString('tr-TR') %></td>
            <td class="td-name"><%= islemEtiketleri[g.islem] || g.islem %></td>
            <td><%= g.aciklama || '—' %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="table-wrap">
      <div class="empty-state">
        <div class="empty-state-icon"><%- ikon('pano', 32, '') %></div>
        <div class="empty-state-title">Henüz işlem geçmişi yok</div>
        <div class="empty-state-sub">Silme, pasife alma gibi riskli işlemler burada listelenir</div>
      </div>
    </div>
    <% } %>

  <!-- TAB: KURUMSAL İÇERİK -->
  <% } else if (tab === 'icerik' && firma.paket === 'kurumsal') { %>
    <div class="table-wrap" style="padding:20px;max-width:560px">
      <h3 style="margin-bottom:12px">Logo</h3>
      <% if (firma.logo_url) { %><img src="<%= firma.logo_url %>" alt="" style="width:72px;height:72px;border-radius:50%;object-fit:contain;background:#fff;border:1px solid #e5e7eb;margin-bottom:8px"><% } %>
      <form method="POST" action="/kurumsal/logo" enctype="multipart/form-data" style="margin-bottom:24px" onsubmit="return formYukleniyorGoster(this, 'Yükleniyor...')">
        <input type="file" name="logo" id="logoInput" accept="image/*" required>
        <button type="submit" class="btn btn-gold">Logoyu Yükle</button>
      </form>

      <h3 style="margin-bottom:12px">Ürün Kataloğu (PDF)</h3>
      <% if (firma.katalog_url) { %><p style="margin-bottom:8px"><a href="<%= firma.katalog_url %>" target="_blank">Mevcut kataloğu görüntüle</a></p><% } %>
      <form method="POST" action="/kurumsal/katalog" enctype="multipart/form-data" style="margin-bottom:24px" onsubmit="return formYukleniyorGoster(this, 'Yükleniyor...')">
        <input type="file" name="katalog" accept="application/pdf" required>
        <button type="submit" class="btn btn-gold">Kataloğu Yükle</button>
      </form>

      <h3 style="margin-bottom:12px">Linkler</h3>
      <form method="POST" action="/kurumsal/icerik" style="display:flex;flex-direction:column;gap:8px">
        <input name="website"   placeholder="Web sitesi"  value="<%= firma.website   || '' %>">
        <input name="instagram" placeholder="Instagram"   value="<%= firma.instagram || '' %>">
        <input name="linkedin"  placeholder="LinkedIn"    value="<%= firma.linkedin  || '' %>">
        <input name="twitter"   placeholder="Twitter / X" value="<%= firma.twitter   || '' %>">
        <input name="youtube"   placeholder="YouTube"     value="<%= firma.youtube   || '' %>">
        <input name="tiktok"    placeholder="TikTok"      value="<%= firma.tiktok    || '' %>">
        <input name="whatsapp"  placeholder="WhatsApp numarası" value="<%= firma.whatsapp || '' %>">
        <button type="submit" class="btn btn-gold">Kaydet</button>
      </form>

      <h3 style="margin-bottom:12px">Eczacı Sayfası</h3>
      <form method="POST" action="/kurumsal/eczaci-icerik" style="display:flex;flex-direction:column;gap:8px;margin-bottom:24px">
        <input name="eczaci_baslik" placeholder="Kampanya başlığı" value="<%= firma.eczaci_baslik || '' %>">
        <textarea name="eczaci_metin" placeholder="Kampanya / eğitim metni" rows="4"><%= firma.eczaci_metin || '' %></textarea>
        <input name="eczaci_video_url" placeholder="YouTube video linki" value="<%= firma.eczaci_video_url || '' %>">
        <button type="submit" class="btn btn-gold">Kaydet</button>
      </form>

      <h3 style="margin-bottom:12px">Eğitim Dokümanı (PDF)</h3>
      <% if (firma.eczaci_pdf_url) { %><p style="margin-bottom:8px"><a href="<%= firma.eczaci_pdf_url %>" target="_blank">Mevcut dokümanı görüntüle</a></p><% } %>
      <form method="POST" action="/kurumsal/eczaci-pdf" enctype="multipart/form-data" onsubmit="return formYukleniyorGoster(this, 'Yükleniyor...')">
        <input type="file" name="eczaci_pdf" accept="application/pdf" required>
        <button type="submit" class="btn btn-gold">Dokümanı Yükle</button>
      </form>
    </div>

  <!-- TAB: ÜRÜNLER -->
  <% } else if (tab === 'urunler' && firma.paket === 'kurumsal') { %>
    <div class="table-wrap" style="padding:20px;margin-bottom:16px;max-width:560px">
      <h3 style="margin-bottom:12px">Yeni Ürün Ekle</h3>
      <form method="POST" action="/kurumsal/urunler" enctype="multipart/form-data" style="display:flex;flex-direction:column;gap:8px" onsubmit="return formYukleniyorGoster(this, 'Kaydediliyor...')">
        <input name="ad" placeholder="Ürün adı *" required>
        <textarea name="aciklama" placeholder="Kısa açıklama" rows="3"></textarea>
        <input type="file" name="foto" id="urunFotoInput" accept="image/*">
        <button type="submit" class="btn btn-gold">Ekle</button>
      </form>
    </div>

    <% if (urunler.length) { %>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Foto</th><th>Ad</th><th>Durum</th><th>PDF</th><th>İşlem</th></tr></thead>
        <tbody>
          <% urunler.forEach(u => { %>
          <tr>
            <td><% if (u.foto_url) { %><img src="<%= u.foto_url %>" alt="" style="width:44px;height:44px;border-radius:8px;object-fit:cover"><% } else { %>—<% } %></td>
            <td class="td-name"><%= u.ad %></td>
            <td><span class="badge badge-<%= u.aktif ? 'aktif' : 'pasif' %>"><%= u.aktif ? 'Aktif' : 'Pasif' %></span></td>
            <td>
              <% if (u.pdf_url) { %><a href="<%= u.pdf_url %>" target="_blank">Görüntüle</a><% } %>
              <form method="POST" action="/kurumsal/urunler/<%= u.id %>/pdf" enctype="multipart/form-data" style="margin-top:4px" onsubmit="return formYukleniyorGoster(this, 'Yükleniyor...')">
                <input type="file" name="pdf" accept="application/pdf" style="max-width:140px">
                <button type="submit" class="btn btn-sm">Yükle</button>
              </form>
            </td>
            <td>
              <div class="td-actions">
                <button class="btn btn-border btn-sm" onclick='urunDuzenleAc(<%- jsonAttr(u) %>)'>Düzenle</button>
                <form method="POST" action="/kurumsal/urunler/<%= u.id %>" style="display:inline">
                  <input type="hidden" name="_method" value="DELETE">
                  <button type="submit" class="btn btn-danger-sm btn-sm" onclick="return confirm('<%= u.ad %> silinsin mi?')">Sil</button>
                </form>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="table-wrap">
      <div class="empty-state">
        <div class="empty-state-icon"><%- ikon('kutu', 32, '') %></div>
        <div class="empty-state-title">Henüz ürün yok</div>
        <div class="empty-state-sub">Eklediğiniz ürünler raf kartı sayfasında görünür</div>
      </div>
    </div>
    <% } %>

    <!-- Ürün Düzenle Modal -->
    <div id="urunDuzenleModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);align-items:center;justify-content:center;z-index:60;padding:16px">
      <div style="background:#fff;border-radius:12px;padding:24px;max-width:420px;width:100%;position:relative">
        <button type="button" onclick="document.getElementById('urunDuzenleModal').style.display='none'" style="position:absolute;top:12px;right:14px;background:none;border:none;font-size:18px;cursor:pointer">✕</button>
        <h3 style="margin-bottom:16px;font-size:16px;font-weight:700">Ürün Düzenle</h3>
        <form id="urunDuzenleForm" method="POST" enctype="multipart/form-data" style="display:flex;flex-direction:column;gap:8px" onsubmit="return formYukleniyorGoster(this, 'Kaydediliyor...')">
          <input type="hidden" name="_method" value="PUT">
          <input type="hidden" name="aktif" id="urunDuzenleAktifGizli" value="true">
          <input id="urunDuzenleAd" name="ad" placeholder="Ürün adı *" required>
          <textarea id="urunDuzenleAciklama" name="aciklama" placeholder="Kısa açıklama" rows="3"></textarea>
          <label style="display:flex;align-items:center;gap:6px;font-size:13px">
            <input type="checkbox" id="urunDuzenleAktifKutu" onchange="document.getElementById('urunDuzenleAktifGizli').value = this.checked ? 'true' : 'false'">
            Raf kartı sayfasında görünsün
          </label>
          <input type="file" name="foto" id="urunDuzenleFotoInput" accept="image/*">
          <button type="submit" class="btn btn-gold">Kaydet</button>
        </form>
      </div>
    </div>

  <!-- TAB: İNDİRİM -->
  <% } else if (tab === 'indirim' && firma.paket === 'kurumsal') { %>
    <div class="table-wrap" style="padding:20px;margin-bottom:16px;max-width:420px">
      <h3 style="margin-bottom:12px">İndirim Kampanyası</h3>
      <form method="POST" action="/kurumsal/indirim-ayar" style="display:flex;flex-direction:column;gap:10px">
        <label style="display:flex;align-items:center;gap:6px;font-size:14px">
          <input type="checkbox" name="indirim_aktif" value="true" <%= firma.indirim_aktif ? 'checked' : '' %>>
          Kampanya aktif — raf sayfasında "İndirim Kodu Al" butonu görünsün
        </label>
        <label style="font-size:13px;color:var(--text-muted)">
          İndirim yüzdesi
          <input type="number" name="indirim_yuzdesi" min="1" max="100" value="<%= firma.indirim_yuzdesi %>" style="width:100%;margin-top:4px">
        </label>
        <button type="submit" class="btn btn-gold">Kaydet</button>
      </form>
    </div>

    <div class="stat-row">
      <div class="stat-card">
        <div class="stat-card-n"><%= indirimIstatistik.toplamUretilen %></div>
        <div class="stat-card-l">Üretilen kod</div>
      </div>
      <div class="stat-card">
        <div class="stat-card-n"><%= indirimIstatistik.toplamKullanilan %></div>
        <div class="stat-card-l">Kullanılan kod</div>
      </div>
    </div>

    <% if (indirimIstatistik.eczaneBazli.length) { %>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Eczane</th><th>Kullanılan indirim</th></tr></thead>
        <tbody>
          <% indirimIstatistik.eczaneBazli.forEach(e => { %>
          <tr>
            <td class="td-name"><%= e.ad %></td>
            <td><%= e.kullanilanSayi %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="table-wrap">
      <div class="empty-state">
        <div class="empty-state-icon"><%- ikon('hediye', 32, '') %></div>
        <div class="empty-state-title">Henüz kullanılan indirim yok</div>
      </div>
    </div>
    <% } %>

  <!-- TAB: RAF KARTLARI -->
  <% } else if (tab === 'raf' && firma.paket === 'kurumsal') { %>
    <div class="table-wrap" style="padding:20px;margin-bottom:16px;max-width:560px">
      <h3 style="margin-bottom:12px">Yeni Eczane Ekle</h3>
      <form method="POST" action="/kurumsal/eczane-ekle" style="display:flex;gap:8px;flex-wrap:wrap">
        <input name="ad" placeholder="Eczane adı *" required>
        <input name="adres" placeholder="Adres">
        <button type="submit" class="btn btn-gold">Ekle</button>
      </form>
    </div>
    <% const eczaneAramaMetni = (ara || '').toLowerCase().trim(); %>
    <% const eczanelerFiltreli = eczaneAramaMetni
         ? eczaneler.filter(e => (e.ad + ' ' + (e.adres || '')).toLowerCase().includes(eczaneAramaMetni))
         : eczaneler; %>
    <% const aktifEczanelerTum = eczanelerFiltreli.filter(e => e.durum !== 'pasif'); const pasifEczaneler = eczanelerFiltreli.filter(e => e.durum === 'pasif'); %>
    <% const ECZANE_SAYFA_BOYUTU = 20; %>
    <% const eczaneToplamSayfa = Math.max(1, Math.ceil(aktifEczanelerTum.length / ECZANE_SAYFA_BOYUTU)); %>
    <% const eczaneMevcutSayfa = Math.min(Math.max(sayfa || 1, 1), eczaneToplamSayfa); %>
    <% const aktifEczaneler = aktifEczanelerTum.slice((eczaneMevcutSayfa - 1) * ECZANE_SAYFA_BOYUTU, eczaneMevcutSayfa * ECZANE_SAYFA_BOYUTU); %>

    <form method="GET" action="/" style="margin-bottom:16px;display:flex;gap:8px;max-width:380px;align-items:center">
      <input type="hidden" name="tab" value="raf">
      <input type="text" name="ara" placeholder="Eczane adı veya adres ara..." value="<%= ara || '' %>"
             style="flex:1;height:32px;padding:0 12px;border-radius:7px;border:1px solid var(--border);background:var(--bg3);color:var(--text);font-size:var(--fs-sm);font-family:inherit">
      <button type="submit" class="btn btn-border btn-sm">Ara</button>
      <% if (ara) { %><a href="/?tab=raf" class="btn btn-ghost btn-sm">Temizle</a><% } %>
    </form>

    <div class="table-wrap" style="padding:12px 20px;margin-bottom:0;display:flex;gap:8px;align-items:center;flex-wrap:wrap">
      <button type="button" id="eczaneTopluOnaylaBtn" disabled class="btn btn-border btn-sm" onclick="eczaneTopluIslem('onayla')">✓ Toplu Onayla</button>
      <button type="button" id="eczaneTopluPasifBtn" disabled class="btn btn-border btn-sm" onclick="eczaneTopluIslem('pasife-al')"><%- ikon('duraklat') %>Toplu Pasife Al</button>
      <button type="button" id="eczaneTopluSilBtn" disabled class="btn btn-danger-sm" onclick="eczaneTopluIslem('sil')"><%- ikon('cop') %>Toplu Sil</button>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th style="width:34px"><input type="checkbox" id="eczaneTumSec" onchange="eczaneTumSecToggle(this)"></th><th>Eczane</th><th style="width:110px;text-align:right">Okutma</th><th style="width:90px"></th></tr></thead>
        <tbody>
          <% aktifEczaneler.forEach(e => { %>
          <tr>
            <td><input type="checkbox" class="eczane-sec" value="<%= e.id %>"></td>
            <td>
              <span style="font-weight:600"><%= e.ad %></span>
              <% if (!e.onayli) { %><span class="badge badge-beklemede" style="margin-left:6px">Onay Bekliyor</span><% } %>
            </td>
            <td style="text-align:right"><span style="font-weight:700"><%= e.okutma_sayisi %></span></td>
            <td><button type="button" class="btn btn-border btn-sm" onclick="eczaneYonetimAc(<%= e.id %>)">Detay ›</button></td>
          </tr>
          <template id="ecTpl-<%= e.id %>" data-ad="<%= e.ad.replace(/"/g, '&quot;') %>">
            <div class="detay-field"><div class="fl">Adres</div><div class="fv"><%= e.adres || '-' %></div></div>
            <% if (!e.onayli) { %>
            <div class="detay-field"><div class="fl">Onay</div><div class="fv"><span class="badge badge-beklemede">Onay Bekliyor</span> <button type="button" class="btn btn-border btn-sm" onclick="eczaneTekIslem(<%= e.id %>, 'onayla')">Onayla</button></div></div>
            <% } %>
            <div class="detay-field"><div class="fl">Raf Kartı</div><div class="fv"><a href="/raf/<%= e.kod %>" target="_blank">/raf/<%= e.kod %></a> · <%= e.okutma_sayisi %> okutma</div></div>
            <div class="detay-field"><div class="fl">Eczacı Kartı</div><div class="fv">
              <% if (e.eczaci_kod) { %><a href="/eczaci/<%= e.eczaci_kod %>" target="_blank">/eczaci/<%= e.eczaci_kod %></a> · <%= e.eczaci_okutma_sayisi %> okutma<% } else { %>
              <form method="POST" action="/kurumsal/eczane/<%= e.id %>/eczaci-kod-uret" style="display:inline"><button type="submit" class="btn btn-border btn-sm">Kod Üret</button></form><% } %>
            </div></div>
            <div class="detay-field"><div class="fl">Müşteri Kartı Durumu</div><div class="fv">
              <% if (e.musteri_karta_yazildi) { %><span style="color:var(--success);font-weight:600">✓ Yazıldı<% if (e.musteri_kart_kilitli) { %> 🔒<% } %></span>
              <form method="POST" action="/kurumsal/eczane/<%= e.id %>/kart-isaretle" style="display:inline"><input type="hidden" name="tip" value="musteri"><input type="hidden" name="yazildi" value="false"><button type="submit" class="btn-link">Kaldır</button></form>
              <% } else { %><span style="color:var(--text-faint)">○ Yazılmadı</span>
              <form method="POST" action="/kurumsal/eczane/<%= e.id %>/kart-isaretle" style="display:inline"><input type="hidden" name="tip" value="musteri"><input type="hidden" name="yazildi" value="true"><button type="submit" class="btn btn-border btn-sm">İşaretle</button></form><% } %>
            </div></div>
            <div class="detay-field"><div class="fl">Eczacı Kartı Durumu</div><div class="fv">
              <% if (e.eczaci_karta_yazildi) { %><span style="color:var(--success);font-weight:600">✓ Yazıldı<% if (e.eczaci_kart_kilitli) { %> 🔒<% } %></span>
              <form method="POST" action="/kurumsal/eczane/<%= e.id %>/kart-isaretle" style="display:inline"><input type="hidden" name="tip" value="eczaci"><input type="hidden" name="yazildi" value="false"><button type="submit" class="btn-link">Kaldır</button></form>
              <% } else { %><span style="color:var(--text-faint)">○ Yazılmadı</span>
              <form method="POST" action="/kurumsal/eczane/<%= e.id %>/kart-isaretle" style="display:inline"><input type="hidden" name="tip" value="eczaci"><input type="hidden" name="yazildi" value="true"><button type="submit" class="btn btn-border btn-sm">İşaretle</button></form><% } %>
            </div></div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:14px">
              <button type="button" class="btn btn-border btn-sm" onclick="eczaneDetayGoster(<%= e.id %>, '<%= e.ad.replace(/'/g, "\\'") %>')">📊 Okutma Analizi</button>
              <button type="button" class="btn btn-border btn-sm" onclick="eczaneTekIslem(<%= e.id %>, 'pasife-al')">Pasife Al</button>
              <form method="POST" action="/kurumsal/eczane/<%= e.id %>/sil" style="display:inline" onsubmit="return confirm('<%= e.ad %> silinsin mi? Okutma geçmişi de silinir.')"><button type="submit" class="btn btn-danger-sm btn-sm">Sil</button></form>
            </div>
          </template>
          <% }) %>
          <% if (!aktifEczaneler.length) { %><tr><td colspan="4">Aktif eczane yok.</td></tr><% } %>
        </tbody>
      </table>
    </div>
    <% if (eczaneToplamSayfa > 1) { %>
    <div style="display:flex;gap:8px;align-items:center;justify-content:center;margin:16px 0">
      <% if (eczaneMevcutSayfa > 1) { %>
        <a class="btn btn-border btn-sm" href="/?tab=raf&ara=<%= encodeURIComponent(ara || '') %>&sayfa=<%= eczaneMevcutSayfa - 1 %>">← Önceki</a>
      <% } %>
      <span style="font-size:var(--fs-xs);color:var(--text-muted)">Sayfa <%= eczaneMevcutSayfa %> / <%= eczaneToplamSayfa %></span>
      <% if (eczaneMevcutSayfa < eczaneToplamSayfa) { %>
        <a class="btn btn-border btn-sm" href="/?tab=raf&ara=<%= encodeURIComponent(ara || '') %>&sayfa=<%= eczaneMevcutSayfa + 1 %>">Sonraki →</a>
      <% } %>
    </div>
    <% } %>

    <% if (pasifEczaneler.length) { %>
    <details class="table-wrap" style="padding:0;margin-top:16px">
      <summary style="padding:16px 20px;cursor:pointer;font-weight:600">Pasif Eczaneler (<%= pasifEczaneler.length %>)</summary>
      <table>
        <thead><tr><th>Eczane</th><th>Adres</th><th></th></tr></thead>
        <tbody>
          <% pasifEczaneler.forEach(e => { %>
          <tr>
            <td><%= e.ad %></td>
            <td><%= e.adres || '-' %></td>
            <td><button type="button" class="btn btn-border btn-sm" onclick="eczaneTekIslem(<%= e.id %>, 'aktif-yap')">Aktif Yap</button></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </details>
    <% } %>

    <!-- Eczane Detay Modal -->
    <div id="eczaneDetayModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);align-items:center;justify-content:center;z-index:60;padding:16px">
      <div style="background:#fff;color:#1a1a1a;border-radius:12px;padding:24px;max-width:480px;width:100%;max-height:80vh;overflow-y:auto;position:relative">
        <button type="button" onclick="document.getElementById('eczaneDetayModal').style.display='none'" style="position:absolute;top:12px;right:14px;background:none;border:none;font-size:18px;cursor:pointer;color:#555">✕</button>
        <h3 id="eczaneDetayBaslik" style="margin-bottom:16px;font-size:16px;font-weight:700;color:#1a1a1a"></h3>
        <div id="eczaneDetayIcerik" style="font-size:13px;line-height:1.7;color:#333"></div>
      </div>
    </div>

  <!-- TAB: SAHA İSTATİSTİKLERİ -->
  <% } else if (tab === 'saha' && firma.paket === 'kurumsal') { %>
    <% const k = sahaIstatistik.kpi || {}; const AS = sahaIstatistik.akilliSorular || {}; const perf = sahaIstatistik.performans || []; %>
    <!-- KPI ŞERİDİ -->
    <div class="stat-row" style="grid-template-columns:repeat(4,1fr);margin-bottom:16px">
      <div class="stat-card">
        <div class="stat-card-n"><%= k.buAyZiyaret != null ? k.buAyZiyaret : 0 %></div>
        <div class="stat-card-l">Bu ay ziyaret</div>
        <% if (k.ziyaretDegisim != null) { %>
          <div style="margin-top:6px;font-size:var(--fs-xs);font-weight:600;color:<%= k.ziyaretDegisim >= 0 ? 'var(--success)' : 'var(--danger)' %>">
            <%= k.ziyaretDegisim >= 0 ? '↑' : '↓' %> %<%= Math.abs(k.ziyaretDegisim) %> geçen aya göre
          </div>
        <% } %>
      </div>
      <div class="stat-card"><div class="stat-card-n">%<%= k.aktifMumessilOrani || 0 %></div><div class="stat-card-l">Aktif mümessil (bu ay)</div></div>
      <div class="stat-card"><div class="stat-card-n">%<%= k.kartKapsamasi || 0 %></div><div class="stat-card-l">Kart kapsaması</div></div>
      <div class="stat-card"><div class="stat-card-n">%<%= k.indirimDonusumu || 0 %></div><div class="stat-card-l">İndirim dönüşümü</div></div>
    </div>

    <!-- AKILLI SORU CHIP BAR -->
    <div class="table-wrap" style="padding:12px 16px;margin-bottom:16px;display:flex;gap:8px;flex-wrap:wrap">
      <% const chipler = [
        ['1','⭐ En çok ziyaret'], ['2','⚠️ 60+ gün geride'], ['3','📉 Bu ay ziyaretsiz'],
        ['4','🏆 En aktif eczaneler'], ['5','💊 En çok ürün'], ['6','🪪 Kartı eksik'],
        ['7','🗺️ Bölge performansı'], ['8','🎁 İndirim özeti'], ['9','📊 Grafikler']
      ]; %>
      <% chipler.forEach(([no, etiket], i) => { %>
        <button class="soru-chip <%= i === 0 ? 'active' : '' %>" data-soru="<%= no %>" onclick="soruGoster('<%= no %>')"><%= etiket %></button>
      <% }) %>
    </div>

    <!-- 1: En çok ziyaret -->
    <div class="soru-rapor" data-soru="1">
      <div class="table-wrap"><table>
        <thead><tr><th>Mümessil</th><th>Son 30g</th><th>Son 90g</th><th>Durum</th></tr></thead>
        <tbody>
          <% perf.slice().sort((a,b)=>b.ziyaret90-a.ziyaret90).slice(0,10).forEach(r => { %>
          <tr><td><%= r.ad %> <%= r.soyad %></td><td><%= r.ziyaret30 %></td><td><%= r.ziyaret90 %></td>
            <td><%= r.durum === 'yildiz' ? '⭐ Yıldız' : r.durum === 'geride' ? '⚠️ Geride' : '—' %></td></tr>
          <% }) %>
        </tbody>
      </table></div>
    </div>
    <!-- 2: 60+ gün geride -->
    <div class="soru-rapor" data-soru="2" style="display:none">
      <div class="table-wrap"><table>
        <thead><tr><th>Mümessil</th><th>Son ziyaret</th></tr></thead>
        <tbody>
          <% perf.filter(r => r.durum === 'geride').forEach(r => { %>
          <tr><td style="color:var(--danger)"><%= r.ad %> <%= r.soyad %></td>
            <td><%= r.sonZiyaret ? new Date(r.sonZiyaret).toLocaleDateString('tr-TR') : 'Hiç ziyaret yok' %></td></tr>
          <% }) %>
          <% if (!perf.filter(r => r.durum === 'geride').length) { %><tr><td colspan="2">Geride mümessil yok 👍</td></tr><% } %>
        </tbody>
      </table></div>
    </div>
    <!-- 3: Bu ay ziyaretsiz -->
    <div class="soru-rapor" data-soru="3" style="display:none">
      <div class="table-wrap"><table>
        <thead><tr><th>Mümessil</th><th>Son 90g ziyaret</th></tr></thead>
        <tbody>
          <% perf.filter(r => r.ziyaret30 === 0).forEach(r => { %>
          <tr><td><%= r.ad %> <%= r.soyad %></td><td><%= r.ziyaret90 %></td></tr>
          <% }) %>
          <% if (!perf.filter(r => r.ziyaret30 === 0).length) { %><tr><td colspan="2">Herkes bu ay ziyaret yapmış 👍</td></tr><% } %>
        </tbody>
      </table></div>
    </div>
    <!-- 4: En aktif eczaneler -->
    <div class="soru-rapor" data-soru="4" style="display:none">
      <div class="table-wrap"><table>
        <thead><tr><th>Eczane</th><th>Raf okutma</th></tr></thead>
        <tbody>
          <% (sahaIstatistik.eczaneOkutma || []).forEach(r => { %><tr><td><%= r.ad %></td><td><%= r.sayi %></td></tr><% }) %>
        </tbody>
      </table></div>
    </div>
    <!-- 5: En çok tıklanan ürünler -->
    <div class="soru-rapor" data-soru="5" style="display:none">
      <div class="table-wrap"><table>
        <thead><tr><th>Ürün</th><th>Tıklama</th></tr></thead>
        <tbody>
          <% (AS.enCokTiklananUrunler || []).forEach(r => { %><tr><td><%= r.ad %></td><td><%= r.sayi %></td></tr><% }) %>
        </tbody>
      </table></div>
    </div>
    <!-- 6: Kartı eksik eczaneler -->
    <div class="soru-rapor" data-soru="6" style="display:none">
      <div class="table-wrap" style="padding:12px 16px;margin-bottom:8px">
        Toplam <strong><%= AS.kartiEksikEczaneler ? AS.kartiEksikEczaneler.sayi : 0 %></strong> eczanede kart eksik (ilk 100 gösteriliyor).
        <input id="kartiEksikAra" placeholder="Eczane ara…" oninput="tabloAra('kartiEksikAra','kartiEksikTablo')" style="margin-left:8px;padding:4px 8px">
      </div>
      <div class="table-wrap"><table id="kartiEksikTablo">
        <thead><tr><th>Eczane</th><th>Eksik</th></tr></thead>
        <tbody>
          <% ((AS.kartiEksikEczaneler && AS.kartiEksikEczaneler.liste) || []).forEach(r => { %>
          <tr><td><%= r.ad %></td><td style="color:var(--danger)"><%= r.eksik %></td></tr>
          <% }) %>
        </tbody>
      </table></div>
    </div>
    <!-- 7: Bölge performansı -->
    <div class="soru-rapor" data-soru="7" style="display:none">
      <div class="table-wrap"><table>
        <thead><tr><th>Bölge Müdürü</th><th>Ekip ziyareti (90g)</th></tr></thead>
        <tbody>
          <% (AS.bolgePerformans || []).forEach(r => { %><tr><td><%= r.ad %> <%= r.soyad %></td><td><%= r.ekipZiyaret %></td></tr><% }) %>
        </tbody>
      </table></div>
    </div>
    <!-- 8: İndirim özeti -->
    <div class="soru-rapor" data-soru="8" style="display:none">
      <div class="stat-row" style="grid-template-columns:repeat(3,1fr)">
        <div class="stat-card"><div class="stat-card-n"><%= AS.indirimOzeti ? AS.indirimOzeti.uretilen : 0 %></div><div class="stat-card-l">Üretilen kod</div></div>
        <div class="stat-card"><div class="stat-card-n"><%= AS.indirimOzeti ? AS.indirimOzeti.kullanilan : 0 %></div><div class="stat-card-l">Kullanılan</div></div>
        <div class="stat-card"><div class="stat-card-n">%<%= AS.indirimOzeti ? AS.indirimOzeti.oran : 0 %></div><div class="stat-card-l">Dönüşüm</div></div>
      </div>
    </div>
    <!-- 9: Grafikler -->
    <div class="soru-rapor" data-soru="9" style="display:none">
      <div class="table-wrap" style="padding:20px;margin-bottom:16px"><h3 style="margin-bottom:12px">Son 30 Gün — Günlük Ziyaret</h3><canvas id="chartGunluk" height="80"></canvas></div>
      <div class="table-wrap" style="padding:20px;margin-bottom:16px"><h3 style="margin-bottom:12px">Temsilci Başına Ziyaret</h3><canvas id="chartTemsilci" height="80"></canvas></div>
      <div class="table-wrap" style="padding:20px;margin-bottom:16px"><h3 style="margin-bottom:12px">Eczane Başına Okutma</h3><canvas id="chartEczane" height="80"></canvas></div>
      <div class="table-wrap" style="padding:20px"><h3 style="margin-bottom:12px">İçerik Tıklama Dağılımı</h3><canvas id="chartTiklama" height="80"></canvas></div>
    </div>

    <div class="table-wrap" style="padding:12px 16px;margin-top:16px">
      <a href="/kurumsal/ziyaretler-excel" class="btn btn-border" style="height:34px">⬇ Ziyaretleri Excel'e Aktar</a>
      <a href="/kurumsal/rapor-excel" class="btn btn-border" style="height:34px;margin-left:8px">⬇ Gelişmiş Rapor (.xlsx)</a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
      const sahaVeri = <%- JSON.stringify({ gunlukZiyaret: sahaIstatistik.gunlukZiyaret, temsilciZiyaret: sahaIstatistik.temsilciZiyaret, eczaneOkutma: sahaIstatistik.eczaneOkutma, tiklamaDagilimi: sahaIstatistik.tiklamaDagilimi }) %>;
      let grafiklerHazir = false;
      function grafikleriKur() {
        if (grafiklerHazir) return; grafiklerHazir = true;
        new Chart(document.getElementById('chartGunluk'), { type:'line', data:{ labels: sahaVeri.gunlukZiyaret.map(r=>r.gun), datasets:[{ label:'Ziyaret', data: sahaVeri.gunlukZiyaret.map(r=>r.sayi), borderColor:'#c9a15a', tension:0.2 }] } });
        new Chart(document.getElementById('chartTemsilci'), { type:'bar', data:{ labels: sahaVeri.temsilciZiyaret.map(r=>r.ad+' '+r.soyad), datasets:[{ label:'Ziyaret', data: sahaVeri.temsilciZiyaret.map(r=>r.sayi), backgroundColor:'#c9a15a' }] } });
        new Chart(document.getElementById('chartEczane'), { type:'bar', data:{ labels: sahaVeri.eczaneOkutma.map(r=>r.ad), datasets:[{ label:'Okutma', data: sahaVeri.eczaneOkutma.map(r=>r.sayi), backgroundColor:'#3a7ca5' }] } });
        new Chart(document.getElementById('chartTiklama'), { type:'bar', data:{ labels: sahaVeri.tiklamaDagilimi.map(r=>r.tip), datasets:[{ label:'Tıklama', data: sahaVeri.tiklamaDagilimi.map(r=>r.sayi), backgroundColor:'#7a9e7e' }] } });
      }
      function soruGoster(no) {
        document.querySelectorAll('.soru-rapor').forEach(el => { el.style.display = el.dataset.soru === no ? 'block' : 'none'; });
        document.querySelectorAll('.soru-chip').forEach(el => { el.classList.toggle('active', el.dataset.soru === no); });
        if (no === '9') grafikleriKur();
      }
      function tabloAra(inputId, tabloId) {
        const q = document.getElementById(inputId).value.toLowerCase();
        document.querySelectorAll('#' + tabloId + ' tbody tr').forEach(tr => {
          tr.style.display = tr.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
      }
    </script>
  <% } %>

