          <span class="pf-text"><%= f[0] %></span>
        </li>
        <% }) %>
      </ul>
      <a href="mailto:info@nfckartify.com" class="price-btn price-btn-border">Teklif Al</a>
    </div>

    <!-- KURUMSAL (FEATURED) -->
    <div class="price-card price-card-featured">
      <div class="price-popular"><span class="pop-dot"></span>En Popüler</div>
      <div class="price-plan-name gold-name">Kurumsal</div>
      <div class="price-amount">
        <span class="price-num">Özel</span>
      </div>
      <div class="price-desc">Büyüyen kurumsal ekipler için. Sınırsız profil, tam analitik, marka özelleştirme.</div>
      <ul class="price-feats">
        <% [['Sınırsız çalışan profili'],['Link analitik takibi'],['Excel toplu yükleme'],['Otomatik e-posta imzası'],['Marka rengi ve logo'],['QR kod ve NFC desteği']].forEach(f => { %>
        <li>
          <div class="pf-icon pf-icon-check">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <span class="pf-text"><%= f[0] %></span>
        </li>
        <% }) %>
      </ul>
      <button class="price-btn price-btn-gold" onclick="openModal('kayit')">Hemen Başla →</button>
    </div>

  </div>
</div>

<!-- CTA -->
<div class="cta-wrap">
  <div class="cta">
    <h2>Bugün başlayın,<br><span class="gold-text">farkı hissettirin</span></h2>
    <p>Kurumsal NFC dijital kartvizit ile çalışanlarınızı profesyonel bir kimlikle donatın.</p>
    <div class="cta-btns">
      <button class="btn btn-gold btn-hero" onclick="openModal('kayit')">Ücretsiz Hesap Oluştur</button>
      <button class="btn-outline-hero" onclick="openModal('giris')">Giriş Yap</button>
    </div>
  </div>
</div>

<!-- TRUST -->
<div class="trust">
  <div class="trust-item">🔒 SSL Şifreleme</div>
  <div class="trust-item">🇹🇷 KVKK Uyumlu</div>
  <div class="trust-item">📡 NFC Forum Sertifikalı</div>
  <div class="trust-item">⚡ %99.9 Uptime</div>
  <div class="trust-item">🎧 7/24 Destek</div>
</div>

<!-- FOOTER -->
<footer>
  <a href="/" class="footer-logo">NFC<em>Kartify</em></a>
  <div class="footer-links">
    <button onclick="openModal('giris')">Giriş</button>
    <button onclick="openModal('kayit')">Kayıt</button>
    <a href="/bayi/giris">Bayi Girişi</a>
    <a href="/superadmin/giris">Yönetici</a>
    <a href="mailto:info@nfckartify.com">İletişim</a>
  </div>
  <div class="footer-copy">© 2026 NFCKartify</div>
</footer>

<!-- LOGIN MODAL -->
<div class="modal-overlay" id="modalOverlay" onclick="closeModalOutside(event)">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">✕</button>
    <div class="modal-logo">NFC<em>Kartify</em></div>
    <div class="modal-sub" id="modalSub">Hesabınıza giriş yapın</div>
    <div class="modal-tabs">
      <button class="modal-tab" id="tabGiris" onclick="switchTab('giris')">Giriş Yap</button>
      <button class="modal-tab" id="tabKayit" onclick="switchTab('kayit')">Hesap Oluştur</button>
    </div>
    <% if (typeof error !== 'undefined' && error && error.length) { %>
      <div class="modal-flash-error" style="margin-bottom:12px"><%= error[0] %></div>
    <% } %>
    <form class="modal-form" id="formGiris" method="POST" action="/firma/giris">
      <div><label>E-posta</label><input type="email" name="yetkili_email" placeholder="firma@ornek.com" required autocomplete="email"></div>
      <div><label>Şifre</label><input type="password" name="sifre" placeholder="••••••••" required autocomplete="current-password"></div>
      <button type="submit" class="modal-submit">Giriş Yap →</button>
      <div class="modal-divider"><span>veya</span></div>
      <button type="button" class="btn-outline-hero" style="width:100%;height:38px;justify-content:center;" onclick="switchTab('kayit')">Hesap oluştur</button>
    </form>
    <form class="modal-form" id="formKayit" method="POST" action="/firma/kayit" style="display:none">
      <div><label>Firma Adı</label><input type="text" name="ad" placeholder="Örnek Firma A.Ş." required autocomplete="organization"></div>
      <div><label>E-posta</label><input type="email" name="yetkili_email" placeholder="firma@ornek.com" required autocomplete="email"></div>
      <div><label>Şifre</label><input type="password" name="sifre" placeholder="En az 8 karakter" required minlength="8" autocomplete="new-password"></div>
      <button type="submit" class="modal-submit">Hesap Oluştur →</button>
      <div class="modal-divider"><span>veya</span></div>
      <button type="button" class="btn-outline-hero" style="width:100%;height:38px;justify-content:center;" onclick="switchTab('giris')">Zaten hesabım var</button>
    </form>
  </div>
</div>

<style>
@keyframes floatB { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }
</style>

<script>
/* ── TICKER ── */
let base = 138;
setInterval(() => { base = Math.max(118,Math.min(180,base+Math.floor(Math.random()*5)-2)); document.getElementById('ticker').textContent=base; }, 3200);

/* ── 3D CARD TILT ── */
document.querySelectorAll('.card-wrap').forEach(wrap => {
  const card = wrap.querySelector('.nfc-card');
  const sheen = wrap.querySelector('.card-sheen');
  wrap.addEventListener('mousemove', e => {
    const r = card.getBoundingClientRect();
    const x = (e.clientX-r.left)/r.width-0.5, y = (e.clientY-r.top)/r.height-0.5;
    card.style.transform = `perspective(600px) rotateX(${-y*18}deg) rotateY(${x*18}deg) scale(1.05)`;
    if(sheen){sheen.style.left=`${(x+0.5)*150-20}%`;sheen.style.opacity='1';}
  });
  wrap.addEventListener('mouseleave', () => { card.style.transform=''; if(sheen){sheen.style.left='-100%';sheen.style.opacity='0';} });
});

/* ── COUNT-UP ── */
const countObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if(!e.isIntersecting) return;
    const el=e.target, target=+el.dataset.target, suffix=el.dataset.suffix||'';
    let cur=0; const step=target/50;
    const t=setInterval(()=>{ cur+=step; if(cur>=target){el.textContent=target+suffix;clearInterval(t);}else{el.textContent=Math.floor(cur)+suffix;}},25);
    countObs.unobserve(el);
  });
},{threshold:0.5});
document.querySelectorAll('[data-target]').forEach(el=>countObs.observe(el));

/* ── BENTO REVEAL ── */
const bentObs = new IntersectionObserver(entries => {
  entries.forEach((e,i) => { if(e.isIntersecting){setTimeout(()=>e.target.classList.add('visible'),i*70);bentObs.unobserve(e.target);} });
},{threshold:0.1});
document.querySelectorAll('.bcard').forEach(c=>bentObs.observe(c));

/* ── BAR CHART ANIMATE ── */
const barObs = new IntersectionObserver(entries => {
  if(!entries[0].isIntersecting) return;
  [['bar1',60],['bar2',80],['bar3',45],['bar4',90],['bar5',65],['bar6',100]].forEach(([id,h],i) => {
    setTimeout(()=>{ const el=document.getElementById(id); if(el)el.style.height=h+'%'; },i*80);
  });
  barObs.unobserve(entries[0].target);
},{threshold:0.3});
const barEl=document.getElementById('bar1');
if(barEl) barObs.observe(barEl.closest('.bcard'));

/* ── MODAL ── */
const overlay=document.getElementById('modalOverlay');
function openModal(tab){overlay.classList.add('open');document.body.style.overflow='hidden';switchTab(tab);}
function closeModal(){overlay.classList.remove('open');document.body.style.overflow='';}
function closeModalOutside(e){if(e.target===overlay)closeModal();}
function switchTab(tab){
  const g=tab==='giris';
  document.getElementById('formGiris').style.display=g?'flex':'none';
  document.getElementById('formKayit').style.display=g?'none':'flex';
  document.getElementById('tabGiris').classList.toggle('active',g);
  document.getElementById('tabKayit').classList.toggle('active',!g);
  document.getElementById('modalSub').textContent=g?'Hesabınıza giriş yapın':'Ücretsiz hesap oluşturun';
}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeModal();});
<% if(typeof error!=='undefined'&&error&&error.length){%>window.addEventListener('DOMContentLoaded',()=>openModal('giris'));<% } %>
</script>
</body>
</html>
