      <div class="card-footer"><div class="card-name">Kerem Arslan</div><div class="card-role">Bölge Müdürü · MSD</div></div>
    </div>
  </div>
</div>

<hr class="divider">

<!-- STATS -->
<div class="stats">
  <div class="stat"><div class="stat-n">500+</div><div class="stat-l">Aktif profil</div></div>
  <div class="stat"><div class="stat-n">10k+</div><div class="stat-l">Görüntülenme</div></div>
