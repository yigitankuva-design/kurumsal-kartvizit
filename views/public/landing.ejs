<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NFCKartify — Kurumsal Dijital Kartvizit</title>
  <meta name="description" content="Kurumsal NFC dijital kartvizit platformu. Çalışanlarınıza saniyeler içinde dijital kimlik verin.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #0a0a0a;
      --gray-900: #111827;
      --gray-600: #4b5563;
      --gray-400: #9ca3af;
      --gray-200: #e5e7eb;
      --gray-100: #f3f4f6;
      --gray-50: #f9fafb;
      --white: #ffffff;
      --blue: #2563eb;
      --fs-xs: 0.75rem;
      --fs-sm: 0.8125rem;
      --fs-base: 0.875rem;
      --fw-normal: 400;
      --fw-medium: 500;
      --fw-semibold: 600;
    }

    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--white);
      color: var(--gray-900);
      line-height: 1.5;
      font-size: var(--fs-base);
      font-weight: var(--fw-normal);
      -webkit-font-smoothing: antialiased;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      height: 56px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 24px;
      background: rgba(255,255,255,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--gray-200);
    }

    .logo {
      font-size: var(--fs-base); font-weight: var(--fw-semibold);
      color: var(--black); text-decoration: none; letter-spacing: -0.01em;
    }
    .logo em { font-style: normal; color: var(--blue); }

    .nav-right { display: flex; align-items: center; gap: 8px; }

    .btn {
      display: inline-flex; align-items: center; justify-content: center;
      height: 32px; padding: 0 12px;
      font-size: var(--fs-sm); font-weight: var(--fw-medium);
      border-radius: 6px; text-decoration: none; border: none; cursor: pointer;
      transition: background 0.15s, color 0.15s;
      white-space: nowrap;
    }
    .btn-ghost { background: transparent; color: var(--gray-600); }
    .btn-ghost:hover { background: var(--gray-100); color: var(--gray-900); }
    .btn-solid { background: var(--black); color: var(--white); }
    .btn-solid:hover { background: var(--gray-900); }
    .btn-outline { background: var(--white); color: var(--gray-900); border: 1px solid var(--gray-200); }
    .btn-outline:hover { background: var(--gray-50); border-color: var(--gray-400); }

    /* ── HERO ── */
    .hero {
      padding: 120px 24px 72px;
      text-align: center;
      max-width: 640px;
      margin: 0 auto;
    }

    .tag {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 4px 10px;
      background: var(--gray-100); border-radius: 100px;
      font-size: var(--fs-xs); font-weight: var(--fw-medium);
      color: var(--gray-600); letter-spacing: 0.01em;
      margin-bottom: 20px;
    }
    .tag-dot { width: 5px; height: 5px; background: #22c55e; border-radius: 50%; }

    h1 {
      font-size: 2rem; font-weight: var(--fw-semibold);
      line-height: 1.15; letter-spacing: -0.03em;
      color: var(--black); margin-bottom: 14px;
    }

    .hero-desc {
      font-size: var(--fs-base); color: var(--gray-600); font-weight: var(--fw-normal);
      line-height: 1.6; margin-bottom: 28px;
    }

    .hero-actions {
      display: flex; gap: 8px; justify-content: center; flex-wrap: wrap;
      margin-bottom: 48px;
    }

    .btn-hero { height: 38px; padding: 0 16px; font-size: var(--fs-sm); border-radius: 7px; }

    /* ── NFC CARDS ── */
    .cards {
      display: flex; justify-content: center; align-items: flex-end;
      padding: 0 16px;
    }

    .nfc-card {
      width: 196px; height: 124px; border-radius: 11px;
      flex-shrink: 0; position: relative; overflow: hidden;
      box-shadow: 0 8px 32px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.06);
    }
    .nfc-card:nth-child(1) { transform: rotate(-4deg) translateY(8px); z-index: 1; }
    .nfc-card:nth-child(2) { transform: rotate(0deg); z-index: 3; width: 216px; height: 136px; box-shadow: 0 16px 48px rgba(0,0,0,0.16); margin: 0 -10px; }
    .nfc-card:nth-child(3) { transform: rotate(4deg) translateY(8px); z-index: 1; }

    .card-black { background: linear-gradient(140deg, #1a1a1a, #2e2e2e); }
    .card-white { background: linear-gradient(140deg, #f0f0f0, #e2e2e2); }
    .card-gold  { background: linear-gradient(140deg, #c8a84b, #e5c060, #b5903a); }

    .card-chip {
      position: absolute; top: 11px; left: 13px;
      width: 28px; height: 20px; border-radius: 4px;
    }
    .card-black .card-chip { background: linear-gradient(135deg, #d4af37, #f0c040); }
    .card-white .card-chip { background: linear-gradient(135deg, #a8a8a8, #d0d0d0); }
    .card-gold  .card-chip { background: rgba(255,255,255,0.3); border: 1px solid rgba(255,255,255,0.45); }

    .card-nfc {
      position: absolute; top: 11px; right: 11px;
      width: 18px; height: 18px; opacity: 0.45;
    }
    .card-black .card-nfc { color: #fff; }
    .card-white .card-nfc { color: #222; }
    .card-gold  .card-nfc { color: #fff; }

    .card-footer {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 7px 13px;
    }
    .card-name { font-size: 0.52rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; }
    .card-role { font-size: 0.45rem; margin-top: 1px; letter-spacing: 0.04em; }
    .card-black .card-name { color: rgba(255,255,255,0.88); }
    .card-black .card-role { color: rgba(255,255,255,0.38); }
    .card-white .card-name { color: rgba(0,0,0,0.7); }
    .card-white .card-role { color: rgba(0,0,0,0.35); }
    .card-gold  .card-name { color: rgba(255,255,255,0.95); }
    .card-gold  .card-role { color: rgba(255,255,255,0.55); }

    /* ── DIVIDER ── */
    .divider { border: none; border-top: 1px solid var(--gray-200); }

    /* ── STATS ── */
    .stats {
      display: flex; justify-content: center;
      border-bottom: 1px solid var(--gray-200);
    }
    .stat {
      flex: 1; max-width: 200px;
      padding: 24px 16px; text-align: center;
      border-right: 1px solid var(--gray-200);
    }
    .stat:last-child { border-right: none; }
    .stat-n { font-size: 1.375rem; font-weight: var(--fw-semibold); color: var(--black); letter-spacing: -0.03em; }
    .stat-l { font-size: var(--fs-xs); color: var(--gray-400); margin-top: 2px; }

    /* ── FEATURES ── */
    .features {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-bottom: 1px solid var(--gray-200);
    }
    .feat {
      padding: 24px;
      border-right: 1px solid var(--gray-200);
      border-bottom: 1px solid var(--gray-200);
    }
    .feat:nth-child(3n) { border-right: none; }
    .feat:nth-child(n+4) { border-bottom: none; }
    .feat-icon { font-size: 0.9rem; margin-bottom: 8px; display: block; }
    .feat-title { font-size: var(--fs-sm); font-weight: var(--fw-semibold); color: var(--black); margin-bottom: 4px; }
    .feat-desc { font-size: var(--fs-xs); color: var(--gray-400); line-height: 1.55; }

    /* ── PRICING ── */
    .pricing-wrap {
      padding: 56px 24px;
      max-width: 860px; margin: 0 auto;
    }
    .section-header { text-align: center; margin-bottom: 32px; }
    .section-header h2 {
      font-size: 1.375rem; font-weight: var(--fw-semibold);
      color: var(--black); letter-spacing: -0.02em; margin-bottom: 4px;
    }
    .section-header p { font-size: var(--fs-sm); color: var(--gray-400); }

    .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
    .plan {
      border: 1px solid var(--gray-200); border-radius: 10px;
      padding: 20px; background: var(--white);
    }
    .plan.featured { border-color: var(--black); }
    .plan-name { font-size: var(--fs-xs); font-weight: var(--fw-medium); color: var(--gray-400); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 10px; }
    .plan-price { font-size: 1.5rem; font-weight: var(--fw-semibold); letter-spacing: -0.03em; color: var(--black); margin-bottom: 3px; }
    .plan-price sub { font-size: var(--fs-xs); font-weight: var(--fw-normal); color: var(--gray-400); vertical-align: baseline; }
    .plan-desc { font-size: var(--fs-xs); color: var(--gray-400); margin-bottom: 16px; padding-bottom: 16px; border-bottom: 1px solid var(--gray-200); }
    .plan-feats { list-style: none; margin-bottom: 16px; display: flex; flex-direction: column; gap: 7px; }
    .plan-feats li { font-size: var(--fs-xs); color: var(--gray-600); display: flex; gap: 8px; align-items: flex-start; }
    .plan-feats li::before { content: '—'; color: var(--gray-400); flex-shrink: 0; }
    .plan-btn {
      display: block; text-align: center; padding: 7px 0;
      border-radius: 6px; font-size: var(--fs-xs); font-weight: var(--fw-medium);
      text-decoration: none; transition: background 0.15s;
    }
    .btn-black { background: var(--black); color: var(--white); }
    .btn-black:hover { background: var(--gray-900); }
    .btn-border { background: transparent; color: var(--gray-900); border: 1px solid var(--gray-200); }
    .btn-border:hover { background: var(--gray-100); }

    /* ── CTA ── */
    .cta {
      background: var(--black); padding: 56px 24px;
      text-align: center;
    }
    .cta h2 { font-size: 1.375rem; font-weight: var(--fw-semibold); color: var(--white); letter-spacing: -0.02em; margin-bottom: 6px; }
    .cta p { font-size: var(--fs-sm); color: rgba(255,255,255,0.4); margin-bottom: 20px; }
    .cta-btns { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }
    .btn-cta-w { height: 38px; padding: 0 16px; background: var(--white); color: var(--black); border-radius: 7px; font-size: var(--fs-sm); font-weight: var(--fw-medium); text-decoration: none; display: inline-flex; align-items: center; transition: background 0.15s; }
    .btn-cta-w:hover { background: #f3f4f6; }
    .btn-cta-o { height: 38px; padding: 0 16px; background: transparent; color: rgba(255,255,255,0.5); border: 1px solid rgba(255,255,255,0.12); border-radius: 7px; font-size: var(--fs-sm); font-weight: var(--fw-normal); text-decoration: none; display: inline-flex; align-items: center; transition: all 0.15s; }
    .btn-cta-o:hover { color: white; border-color: rgba(255,255,255,0.25); }

    /* ── FOOTER ── */
    footer {
      padding: 16px 24px;
      display: flex; align-items: center; justify-content: space-between;
      border-top: 1px solid var(--gray-200); flex-wrap: wrap; gap: 10px;
    }
    .footer-logo { font-size: var(--fs-sm); font-weight: var(--fw-semibold); color: var(--black); text-decoration: none; }
    .footer-logo em { font-style: normal; color: var(--blue); }
    .footer-links { display: flex; gap: 16px; }
    .footer-links a { font-size: var(--fs-xs); color: var(--gray-400); text-decoration: none; transition: color 0.15s; }
    .footer-links a:hover { color: var(--gray-600); }
    .footer-copy { font-size: var(--fs-xs); color: var(--gray-400); }

    /* ── RESPONSIVE ── */
    @media (max-width: 640px) {
      h1 { font-size: 1.625rem; }
      .nfc-card:nth-child(1), .nfc-card:nth-child(3) { display: none; }
      .nfc-card:nth-child(2) { transform: none; margin: 0; }
      .stats { flex-wrap: wrap; }
      .stat { border-right: none !important; border-bottom: 1px solid var(--gray-200); }
      .features { grid-template-columns: 1fr; }
      .feat { border-right: none !important; }
      .pricing-grid { grid-template-columns: 1fr; }
      footer { flex-direction: column; text-align: center; }
    }
    @media (max-width: 900px) and (min-width: 641px) {
      .features { grid-template-columns: 1fr 1fr; }
      .feat:nth-child(3n) { border-right: 1px solid var(--gray-200); }
      .feat:nth-child(2n) { border-right: none; }
      .pricing-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="/" class="logo">NFC<em>Kartify</em></a>
  <div class="nav-right">
    <a href="/firma/giris" class="btn btn-ghost">Giriş</a>
