<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NFCKartify — Kurumsal Dijital Kartvizit</title>
  <meta name="description" content="Kurumsal NFC dijital kartvizit platformu. Çalışanlarınıza saniyeler içinde dijital kimlik verin.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0d0d0f;
      --bg2: #131316;
      --bg3: #18181c;
      --border: rgba(255,255,255,0.07);
      --border-gold: rgba(200,168,75,0.3);
      --gold: #c8a84b;
      --gold-light: #e5c46a;
      --gold-dim: rgba(200,168,75,0.12);
      --white: #ffffff;
      --text: #f1f0ee;
      --text-muted: #888880;
      --text-faint: #444440;
      --fs-xs: 0.72rem;
      --fs-sm: 0.8rem;
      --fs-base: 0.875rem;
      --fw-normal: 400;
      --fw-medium: 500;
      --fw-semibold: 600;
      --fw-bold: 700;
    }

    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
      font-size: var(--fs-base);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      height: 56px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 32px;
      background: rgba(13,13,15,0.85);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }
    .logo { font-size: var(--fs-base); font-weight: var(--fw-bold); color: var(--text); text-decoration: none; letter-spacing: -0.02em; }
    .logo em { font-style: normal; color: var(--gold); }
    .nav-right { display: flex; align-items: center; gap: 8px; }

    .btn {
      display: inline-flex; align-items: center; justify-content: center;
      height: 32px; padding: 0 14px;
      font-size: var(--fs-sm); font-weight: var(--fw-medium);
      border-radius: 6px; text-decoration: none; border: none; cursor: pointer;
      transition: all 0.15s; white-space: nowrap; font-family: inherit;
    }
    .btn-ghost { background: transparent; color: var(--text-muted); }
    .btn-ghost:hover { background: var(--bg3); color: var(--text); }
    .btn-gold {
      background: var(--gold); color: #000;
      font-weight: var(--fw-semibold);
      box-shadow: 0 0 20px rgba(200,168,75,0.25);
    }
    .btn-gold:hover { background: var(--gold-light); box-shadow: 0 0 28px rgba(200,168,75,0.4); }

    /* ── HERO ── */
    .hero {
      padding: 112px 32px 72px;
      text-align: center;
      max-width: 680px;
      margin: 0 auto;
      position: relative;
    }

    /* Radial glow behind hero */
    .hero::before {
      content: '';
      position: fixed; top: 0; left: 50%; transform: translateX(-50%);
      width: 600px; height: 400px;
      background: radial-gradient(ellipse at 50% 0%, rgba(200,168,75,0.08) 0%, transparent 70%);
      pointer-events: none; z-index: 0;
    }
    .hero > * { position: relative; z-index: 1; }

    /* Live badge */
    .live-badge {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 5px 12px;
      background: var(--bg3); border: 1px solid var(--border);
      border-radius: 100px;
      font-size: var(--fs-xs); font-weight: var(--fw-medium);
      color: var(--text-muted); margin-bottom: 24px;
      animation: badgePop 0.6s cubic-bezier(0.34,1.56,0.64,1) both;
    }
    @keyframes badgePop { from{opacity:0;transform:scale(0.8) translateY(8px);} to{opacity:1;transform:scale(1) translateY(0);} }
    .live-dot {
      width: 6px; height: 6px; background: #22c55e; border-radius: 50%;
      box-shadow: 0 0 6px rgba(34,197,94,0.6);
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100%{box-shadow:0 0 6px rgba(34,197,94,0.6);} 50%{box-shadow:0 0 12px rgba(34,197,94,0.9);} }

    /* Social proof counter */
    .ticker {
      color: var(--gold); font-weight: var(--fw-semibold); font-variant-numeric: tabular-nums;
    }

    h1 {
      font-size: clamp(1.875rem, 4.5vw, 3rem);
      font-weight: var(--fw-bold);
      line-height: 1.1; letter-spacing: -0.04em;
      color: var(--white); margin-bottom: 16px;
      animation: fadeUp 0.7s 0.1s cubic-bezier(0.16,1,0.3,1) both;
    }
    .gold-text {
      background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 50%, var(--gold) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text; background-size: 200% 100%;
      animation: shimmer 4s linear infinite;
    }
    @keyframes shimmer { from{background-position:200% 0;} to{background-position:-200% 0;} }
    @keyframes fadeUp { from{opacity:0;transform:translateY(20px);} to{opacity:1;transform:translateY(0);} }

    .hero-desc {
      font-size: var(--fs-base); color: var(--text-muted); font-weight: var(--fw-normal);
      line-height: 1.65; margin-bottom: 28px; max-width: 480px; margin-left: auto; margin-right: auto;
      animation: fadeUp 0.7s 0.2s cubic-bezier(0.16,1,0.3,1) both;
    }

    .hero-actions {
      display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;
      margin-bottom: 52px;
      animation: fadeUp 0.7s 0.3s cubic-bezier(0.16,1,0.3,1) both;
    }
    .btn-hero { height: 40px; padding: 0 18px; font-size: var(--fs-sm); border-radius: 8px; }
    .btn-outline-hero {
      height: 40px; padding: 0 18px; font-size: var(--fs-sm); border-radius: 8px;
      background: transparent; border: 1px solid var(--border); color: var(--text-muted);
      text-decoration: none; display: inline-flex; align-items: center;
      transition: all 0.15s; font-weight: var(--fw-medium); font-family: inherit;
    }
    .btn-outline-hero:hover { border-color: var(--border-gold); color: var(--text); }

    /* ── NFC CARDS — 3D ── */
    .cards-scene {
      display: flex; justify-content: center; align-items: flex-end;
      animation: fadeUp 0.7s 0.4s cubic-bezier(0.16,1,0.3,1) both;
      perspective: 1000px;
    }

    .card-wrap {
      cursor: pointer;
      transition: transform 0.1s ease-out;
    }
    .card-wrap:nth-child(1) { --base-r: -5deg; --base-ty: 10px; transform: rotate(-5deg) translateY(10px); z-index: 1; }
    .card-wrap:nth-child(2) { --base-r: 0deg; --base-ty: 0px; z-index: 3; margin: 0 -12px; }
    .card-wrap:nth-child(3) { --base-r: 5deg; --base-ty: 10px; transform: rotate(5deg) translateY(10px); z-index: 1; }

    .nfc-card {
      width: 200px; height: 126px; border-radius: 12px;
      position: relative; overflow: hidden;
      transform-style: preserve-3d;
      transition: box-shadow 0.3s;
    }
    .card-wrap:nth-child(2) .nfc-card { width: 224px; height: 142px; }

    .card-black {
      background: linear-gradient(145deg, #1c1c1c 0%, #2a2a2a 50%, #111 100%);
      box-shadow: 0 12px 40px rgba(0,0,0,0.5), 0 4px 12px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.06);
    }
    .card-gold-card {
      background: linear-gradient(145deg, #8a6820 0%, #c8a84b 30%, #e8c860 55%, #c0952a 80%, #a07818 100%);
      box-shadow: 0 12px 40px rgba(200,168,75,0.35), 0 4px 12px rgba(200,168,75,0.2), inset 0 1px 0 rgba(255,255,255,0.3);
    }
    .card-white-card {
      background: linear-gradient(145deg, #e8e8e8 0%, #f2f2f2 40%, #e0e0e0 100%);
      box-shadow: 0 12px 40px rgba(0,0,0,0.3), 0 4px 12px rgba(0,0,0,0.15), inset 0 1px 0 rgba(255,255,255,0.9);
    }

    /* Sheen on hover */
    .card-sheen {
      position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
      background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.15) 50%, transparent 60%);
      transform: skewX(-8deg); pointer-events: none; transition: none;
    }

    .card-chip {
      position: absolute; top: 13px; left: 14px;
      width: 30px; height: 22px; border-radius: 4px;
    }
    .card-black .card-chip { background: linear-gradient(135deg, #c8a84b, #f0d060, #a88030); }
    .card-gold-card .card-chip { background: rgba(255,255,255,0.25); border: 1px solid rgba(255,255,255,0.4); }
    .card-white-card .card-chip { background: linear-gradient(135deg, #a8a8a8, #d0d0d0, #909090); }

    /* Chip lines */
    .card-chip::before, .card-chip::after {
      content: ''; position: absolute; background: rgba(0,0,0,0.15);
    }
    .card-chip::before { top: 7px; left: 3px; right: 3px; height: 1px; }
    .card-chip::after { top: 3px; left: 50%; transform: translateX(-50%); width: 1px; height: calc(100% - 6px); }

    .card-nfc {
      position: absolute; top: 12px; right: 13px;
      width: 20px; height: 20px;
    }
    .card-black .card-nfc { color: rgba(255,255,255,0.4); }
    .card-gold-card .card-nfc { color: rgba(255,255,255,0.6); }
    .card-white-card .card-nfc { color: rgba(0,0,0,0.3); }

    /* NFC pulse ring */
    .card-nfc-ring {
      position: absolute; top: 8px; right: 8px;
      width: 28px; height: 28px; border-radius: 50%;
      border: 1px solid currentColor; opacity: 0;
      animation: nfcRing 2.5s ease-out infinite;
    }
    .card-black .card-nfc-ring { color: rgba(200,168,75,0.5); animation-delay: 0s; }
    .card-gold-card .card-nfc-ring { color: rgba(255,255,255,0.4); animation-delay: 0.8s; }
    .card-white-card .card-nfc-ring { color: rgba(0,0,0,0.2); animation-delay: 1.6s; }
    @keyframes nfcRing {
      0% { opacity: 0.8; transform: scale(0.6); }
      100% { opacity: 0; transform: scale(1.8); }
    }

    .card-footer {
      position: absolute; bottom: 0; left: 0; right: 0; padding: 8px 14px;
    }
    .card-name { font-size: 0.53rem; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; }
    .card-role { font-size: 0.44rem; margin-top: 1px; letter-spacing: 0.03em; }
    .card-black .card-name { color: rgba(255,255,255,0.88); }
    .card-black .card-role { color: rgba(255,255,255,0.35); }
    .card-gold-card .card-name { color: rgba(255,255,255,0.95); }
    .card-gold-card .card-role { color: rgba(255,255,255,0.6); }
    .card-white-card .card-name { color: rgba(0,0,0,0.72); }
    .card-white-card .card-role { color: rgba(0,0,0,0.35); }

    /* Hologram bottom-right */
    .card-holo {
      position: absolute; bottom: 10px; right: 12px;
      width: 22px; height: 22px; border-radius: 50%;
      background: conic-gradient(rgba(255,255,255,0.3), rgba(200,168,75,0.4), rgba(255,255,255,0.1), rgba(200,168,75,0.3));
      opacity: 0.5;
    }

    /* ── SECTION DIVIDER ── */
    .divider { border: none; border-top: 1px solid var(--border); }

    /* ── STATS ── */
    .stats { display: flex; border-bottom: 1px solid var(--border); }
    .stat {
      flex: 1; padding: 28px 24px; text-align: center;
      border-right: 1px solid var(--border);
    }
    .stat:last-child { border-right: none; }
    .stat-n {
      font-size: 1.625rem; font-weight: var(--fw-bold);
      color: var(--gold); letter-spacing: -0.04em;
    }
    .stat-l { font-size: var(--fs-xs); color: var(--text-faint); margin-top: 3px; }

    /* ── FEATURES ── */
    .features {
      display: grid; grid-template-columns: repeat(3, 1fr);
      border-bottom: 1px solid var(--border);
    }
    .feat {
      padding: 28px 24px;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      transition: background 0.2s;
      opacity: 0; transform: translateY(16px);
      transition: background 0.2s, opacity 0.5s, transform 0.5s;
    }
    .feat.visible { opacity: 1; transform: translateY(0); }
    .feat:nth-child(3n) { border-right: none; }
    .feat:nth-child(n+4) { border-bottom: none; }
    .feat:hover { background: var(--bg2); }
    .feat-icon {
      width: 32px; height: 32px; border-radius: 8px;
      background: var(--gold-dim); border: 1px solid var(--border-gold);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.875rem; margin-bottom: 14px;
    }
    .feat-title { font-size: var(--fs-sm); font-weight: var(--fw-semibold); color: var(--text); margin-bottom: 5px; }
    .feat-desc { font-size: var(--fs-xs); color: var(--text-faint); line-height: 1.6; }

    /* ── PRICING ── */
    .pricing-wrap { padding: 64px 32px; max-width: 900px; margin: 0 auto; }
    .section-header { text-align: center; margin-bottom: 36px; }
    .section-header h2 {
      font-size: 1.5rem; font-weight: var(--fw-bold);
      color: var(--white); letter-spacing: -0.03em; margin-bottom: 6px;
    }
    .section-header p { font-size: var(--fs-sm); color: var(--text-faint); }

    .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }

    .plan {
      border: 1px solid var(--border); border-radius: 12px;
      padding: 24px; background: var(--bg2);
      position: relative; overflow: hidden;
      transition: border-color 0.3s, box-shadow 0.3s, transform 0.2s;
    }
    .plan:hover {
      border-color: var(--border-gold);
      box-shadow: 0 0 32px rgba(200,168,75,0.08);
      transform: translateY(-2px);
    }
    .plan.featured {
      border-color: var(--gold);
      box-shadow: 0 0 40px rgba(200,168,75,0.15), inset 0 0 40px rgba(200,168,75,0.03);
    }
    .plan.featured:hover {
      box-shadow: 0 0 56px rgba(200,168,75,0.25), inset 0 0 40px rgba(200,168,75,0.05);
    }

    /* Featured top glow bar */
    .plan.featured::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
    }

    /* Popular badge */
    .plan-badge {
      position: absolute; top: -1px; right: 20px;
      background: var(--gold); color: #000;
      font-size: 0.6rem; font-weight: var(--fw-bold);
      padding: 3px 8px; border-radius: 0 0 6px 6px;
      letter-spacing: 0.05em; text-transform: uppercase;
      animation: badgeGlow 2s ease-in-out infinite;
    }
    @keyframes badgeGlow {
      0%,100% { box-shadow: 0 2px 8px rgba(200,168,75,0.3); }
      50% { box-shadow: 0 4px 16px rgba(200,168,75,0.6); }
    }

    .plan-name { font-size: var(--fs-xs); font-weight: var(--fw-medium); color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px; }
    .plan-price { font-size: 1.625rem; font-weight: var(--fw-bold); letter-spacing: -0.04em; color: var(--white); margin-bottom: 3px; }
    .plan.featured .plan-price { color: var(--gold); }
    .plan-price sub { font-size: var(--fs-xs); font-weight: var(--fw-normal); color: var(--text-muted); vertical-align: baseline; }
    .plan-desc { font-size: var(--fs-xs); color: var(--text-faint); margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--border); }
    .plan-feats { list-style: none; margin-bottom: 20px; display: flex; flex-direction: column; gap: 9px; }
    .plan-feats li { font-size: var(--fs-xs); color: var(--text-muted); display: flex; gap: 8px; align-items: flex-start; }
    .plan-feats li::before { content: '–'; color: var(--text-faint); flex-shrink: 0; }
    .plan.featured .plan-feats li { color: var(--text); }

    .plan-btn {
      display: block; text-align: center; padding: 9px 0;
      border-radius: 7px; font-size: var(--fs-xs); font-weight: var(--fw-semibold);
      text-decoration: none; transition: all 0.15s; font-family: inherit; border: none; cursor: pointer;
    }
    .btn-plan-gold { background: var(--gold); color: #000; box-shadow: 0 4px 16px rgba(200,168,75,0.3); }
    .btn-plan-gold:hover { background: var(--gold-light); box-shadow: 0 4px 24px rgba(200,168,75,0.5); }
    .btn-plan-border { background: transparent; color: var(--text-muted); border: 1px solid var(--border); }
    .btn-plan-border:hover { border-color: var(--border-gold); color: var(--text); }

    /* ── CTA ── */
    .cta {
      margin: 0 32px 32px; border-radius: 16px;
      background: linear-gradient(135deg, var(--bg2) 0%, #1a1508 50%, var(--bg2) 100%);
      border: 1px solid var(--border-gold);
      padding: 56px 32px; text-align: center;
      position: relative; overflow: hidden;
    }
    .cta::before {
      content: '';
      position: absolute; top: -60%; left: 50%; transform: translateX(-50%);
      width: 400px; height: 300px;
      background: radial-gradient(ellipse, rgba(200,168,75,0.1) 0%, transparent 70%);
      pointer-events: none;
    }
    .cta > * { position: relative; z-index: 1; }
    .cta h2 { font-size: 1.625rem; font-weight: var(--fw-bold); color: var(--white); letter-spacing: -0.03em; margin-bottom: 8px; }
    .cta p { font-size: var(--fs-sm); color: var(--text-faint); margin-bottom: 24px; }
    .cta-btns { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }

    /* ── TRUST BADGES ── */
    .trust {
      display: flex; align-items: center; justify-content: center;
      gap: 24px; padding: 16px 32px;
      border-top: 1px solid var(--border);
      flex-wrap: wrap;
    }
    .trust-item { display: flex; align-items: center; gap: 6px; font-size: var(--fs-xs); color: var(--text-faint); }
    .trust-icon { font-size: 0.875rem; }

    /* ── FOOTER ── */
    footer {
      padding: 20px 32px;
      display: flex; align-items: center; justify-content: space-between;
      border-top: 1px solid var(--border); flex-wrap: wrap; gap: 12px;
    }
    .footer-logo { font-size: var(--fs-sm); font-weight: var(--fw-bold); color: var(--text); text-decoration: none; }
    .footer-logo em { font-style: normal; color: var(--gold); }
    .footer-links { display: flex; gap: 20px; }
    .footer-links a { font-size: var(--fs-xs); color: var(--text-faint); text-decoration: none; transition: color 0.15s; }
    .footer-links a:hover { color: var(--text-muted); }
    .footer-copy { font-size: var(--fs-xs); color: var(--text-faint); }

    /* ── RESPONSIVE ── */
    @media (max-width: 640px) {
      nav { padding: 0 16px; }
      h1 { font-size: 1.75rem; }
      .hero { padding: 100px 16px 56px; }
      .card-wrap:nth-child(1), .card-wrap:nth-child(3) { display: none; }
      .card-wrap:nth-child(2) { margin: 0; }
      .stats { flex-wrap: wrap; }
      .stat { border-right: none !important; border-bottom: 1px solid var(--border); }
      .features { grid-template-columns: 1fr; }
      .feat { border-right: none !important; }
      .pricing-grid { grid-template-columns: 1fr; }
      .cta { margin: 0 16px 16px; }
      footer { flex-direction: column; text-align: center; }
    }
    @media (max-width: 900px) and (min-width: 641px) {
      .features { grid-template-columns: 1fr 1fr; }
      .feat:nth-child(3n) { border-right: 1px solid var(--border); }
      .feat:nth-child(2n) { border-right: none; }
      .pricing-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="/" class="logo">NFC<em>Kartify</em></a>
  <div class="nav-right">
    <a href="/firma/giris" class="btn btn-ghost">Giriş</a>
    <a href="/firma/kayit" class="btn btn-gold">Başla →</a>
  </div>
</nav>

<!-- HERO -->
<div class="hero">
  <div class="live-badge">
    <span class="live-dot"></span>
    Şu an <span class="ticker" id="ticker">142</span> kişi profil görüntülüyor
  </div>
  <h1>Çalışanlarınıza<br><span class="gold-text">dijital kimlik</span> verin</h1>
  <p class="hero-desc">Tek panelden tüm ekibi yönetin. NFC kart, QR kod ve link ile anında paylaşım. Her tıklamayı takip edin.</p>
  <div class="hero-actions">
    <a href="/firma/kayit" class="btn btn-gold btn-hero">Ücretsiz Başla</a>
    <a href="/firma/giris" class="btn-outline-hero">Giriş Yap</a>
  </div>

  <!-- NFC CARDS -->
  <div class="cards-scene" id="cardsScene">
    <!-- Siyah Kart -->
    <div class="card-wrap" id="card0">
      <div class="nfc-card card-black">
        <div class="card-chip"></div>
        <svg class="card-nfc" viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 12c0 4.69-3.81 8.5-8.5 8.5S3.5 16.69 3.5 12 7.31 3.5 12 3.5s8.5 3.81 8.5 8.5zM22 12C22 6.48 17.52 2 12 2S2 6.48 2 12s4.48 10 10 10 10-4.48 10-10zm-8 0c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm3 0c0 2.76-2.24 5-5 5s-5-2.24-5-5 2.24-5 5-5 5 2.24 5 5z"/></svg>
