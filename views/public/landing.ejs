<script>
  /* ── 3D CARD TILT ── */
  const cardWraps = document.querySelectorAll('.card-wrap');
  const baseTransforms = [
    'rotate(-5deg) translateY(10px)',
    'rotate(0deg) translateY(0)',
    'rotate(5deg) translateY(10px)'
  ];

  cardWraps.forEach((wrap, i) => {
    const card = wrap.querySelector('.nfc-card');
    const sheen = wrap.querySelector('.card-sheen');

    wrap.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      const rotX = -y * 18;
      const rotY = x * 18;
      card.style.transform = `perspective(600px) rotateX(${rotX}deg) rotateY(${rotY}deg) scale(1.04)`;
      if (sheen) {
        sheen.style.left = `${(x + 0.5) * 150 - 20}%`;
        sheen.style.opacity = '1';
      }
    });

    wrap.addEventListener('mouseleave', () => {
      card.style.transform = '';
      if (sheen) { sheen.style.left = '-100%'; sheen.style.opacity = '0'; }
    });
  });

  /* ── TICKER (social proof) ── */
  const ticker = document.getElementById('ticker');
  if (ticker) {
    let base = 138;
    setInterval(() => {
      const delta = Math.floor(Math.random() * 5) - 2;
      base = Math.max(120, Math.min(180, base + delta));
      ticker.textContent = base;
    }, 3000);
  }

  /* ── COUNT-UP STATS ── */
  const statEls = document.querySelectorAll('.stat-n[data-target]');
  const countObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target;
      const target = parseInt(el.dataset.target);
      const suffix = target >= 10000 ? 'k+' : target >= 500 ? '+' : '%';
      const display = target >= 10000 ? 10 : target;
      let start = 0;
      const step = display / 40;
      const timer = setInterval(() => {
        start += step;
        if (start >= display) {
          el.textContent = display + suffix;
          clearInterval(timer);
        } else {
          el.textContent = Math.floor(start) + suffix;
        }
      }, 30);
      countObserver.unobserve(el);
    });
  }, { threshold: 0.5 });
  statEls.forEach(el => countObserver.observe(el));

  /* ── FEATURE SCROLL REVEAL ── */
  const feats = document.querySelectorAll('.feat');
  const featObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry, idx) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), idx * 60);
        featObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  feats.forEach(f => featObserver.observe(f));
</script>
