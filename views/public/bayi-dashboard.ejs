<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NFCKartify — <%= bayi.ad %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #1c1c20;
      --bg2: #222227;
      --bg3: #28282e;
      --bg4: #2e2e35;
      --border: rgba(255,255,255,0.07);
      --border-gold: rgba(200,168,75,0.3);
      --gold: #c8a84b;
      --gold-light: #e5c46a;
      --gold-dim: rgba(200,168,75,0.1);
      --text: #f1f0ee;
      --text-muted: #888880;
      --text-faint: #444440;
      --danger: #ef4444;
      --danger-dim: rgba(239,68,68,0.1);
      --success: #22c55e;
      --success-dim: rgba(34,197,94,0.1);
      --fs-xs: 0.72rem;
      --fs-sm: 0.8rem;
      --fs-base: 0.875rem;
      --fw-normal: 400;
      --fw-medium: 500;
      --fw-semibold: 600;
      --fw-bold: 700;
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); font-size: var(--fs-base); line-height: 1.5; -webkit-font-smoothing: antialiased; overflow-x: hidden; }

    .dash-nav {
      position: sticky; top: 0; z-index: 50;
      height: 52px; display: flex; align-items: center; justify-content: space-between;
      padding: 0 24px;
      background: rgba(13,13,15,0.95); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo { font-size: var(--fs-base); font-weight: var(--fw-bold); color: var(--text); text-decoration: none; letter-spacing: -0.02em; }
    .nav-logo em { font-style: normal; color: var(--gold); }
    .nav-center { font-size: var(--fs-sm); color: var(--text-muted); font-weight: var(--fw-medium); }
    .nav-right { display: flex; align-items: center; gap: 8px; }

    .btn { display: inline-flex; align-items: center; gap: 6px; height: 32px; padding: 0 14px; border-radius: 6px; font-size: var(--fs-sm); font-weight: var(--fw-medium); cursor: pointer; border: none; font-family: inherit; text-decoration: none; transition: all 0.15s; white-space: nowrap; }
    .btn-ghost { background: transparent; color: var(--text-muted); }
    .btn-ghost:hover { background: var(--bg3); color: var(--text); }
    .btn-gold { background: var(--gold); color: #000; font-weight: var(--fw-semibold); box-shadow: 0 0 16px rgba(200,168,75,0.2); }
    .btn-gold:hover { background: var(--gold-light); }
    .btn-border { background: transparent; color: var(--text-muted); border: 1px solid var(--border); }
    .btn-border:hover { border-color: var(--border-gold); color: var(--text); }
    .btn-danger-sm { background: var(--danger-dim); color: var(--danger); border: 1px solid rgba(239,68,68,0.2); }
    .btn-danger-sm:hover { background: rgba(239,68,68,0.18); }
    .btn-sm { height: 28px; padding: 0 10px; font-size: var(--fs-xs); }

    .flash-bar { padding: 10px 24px; font-size: var(--fs-sm); font-weight: var(--fw-medium); display: flex; align-items: center; gap: 8px; }
    .flash-success { background: var(--success-dim); color: var(--success); border-bottom: 1px solid rgba(34,197,94,0.15); }
    .flash-error { background: var(--danger-dim); color: var(--danger); border-bottom: 1px solid rgba(239,68,68,0.15); }

    .dash-main { max-width: 1100px; margin: 0 auto; padding: 28px 24px 64px; }

    .dash-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; gap: 12px; flex-wrap: wrap; }
    .dash-title { font-size: 1.125rem; font-weight: var(--fw-bold); color: var(--text); letter-spacing: -0.02em; }
    .dash-subtitle { font-size: var(--fs-xs); color: var(--text-faint); margin-top: 2px; }

    .stat-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 24px; }
    .stat-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 16px 18px; }
    .stat-card-n { font-size: 1.5rem; font-weight: var(--fw-bold); color: var(--gold); letter-spacing: -0.04em; }
    .stat-card-l { font-size: var(--fs-xs); color: var(--text-faint); margin-top: 2px; }

    .table-wrap { border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    thead th { padding: 10px 16px; text-align: left; font-size: var(--fs-xs); font-weight: var(--fw-medium); color: var(--text-faint); background: var(--bg2); border-bottom: 1px solid var(--border); }
    tbody tr { border-bottom: 1px solid var(--border); transition: background 0.1s; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: var(--bg2); }
    tbody td { padding: 12px 16px; font-size: var(--fs-sm); vertical-align: middle; }
    .td-name { font-weight: var(--fw-semibold); color: var(--text); }
    .td-sub { font-size: var(--fs-xs); color: var(--text-faint); margin-top: 1px; }
    .td-url a { font-size: var(--fs-xs); color: var(--text-faint); text-decoration: none; font-family: monospace; }
    .td-url a:hover { color: var(--gold); }
    .td-actions { display: flex; gap: 6px; align-items: center; }

    .badge { display: inline-flex; align-items: center; height: 20px; padding: 0 8px; border-radius: 100px; font-size: 0.65rem; font-weight: var(--fw-semibold); letter-spacing: 0.03em; text-transform: uppercase; }
    .badge-aktif { background: var(--success-dim); color: var(--success); }
    .badge-pasif { background: var(--bg3); color: var(--text-faint); }

    .empty-state { text-align: center; padding: 48px 24px; }
    .empty-state-icon { font-size: 2rem; margin-bottom: 12px; }
    .empty-state-title { font-size: var(--fs-sm); font-weight: var(--fw-semibold); color: var(--text-muted); margin-bottom: 6px; }
    .empty-state-sub { font-size: var(--fs-xs); color: var(--text-faint); margin-bottom: 16px; }

    .panel-overlay { position: fixed; inset: 0; z-index: 200; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); opacity: 0; pointer-events: none; transition: opacity 0.2s; }
    .panel-overlay.open { opacity: 1; pointer-events: all; }
    .slide-panel { position: fixed; top: 0; right: 0; bottom: 0; z-index: 201; width: 440px; max-width: 100vw; background: var(--bg2); border-left: 1px solid var(--border); display: flex; flex-direction: column; transform: translateX(100%); transition: transform 0.3s cubic-bezier(0.16,1,0.3,1); overflow: hidden; }
    .panel-overlay.open .slide-panel { transform: translateX(0); }
    .slide-header { padding: 20px 24px 16px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
    .slide-title { font-size: var(--fs-base); font-weight: var(--fw-semibold); color: var(--text); }
    .slide-close { width: 28px; height: 28px; border-radius: 6px; background: var(--bg3); border: 1px solid var(--border); color: var(--text-muted); cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center; transition: all 0.15s; }
    .slide-close:hover { background: var(--border); color: var(--text); }
    .slide-body { flex: 1; overflow-y: auto; padding: 20px 24px; }
    .slide-footer { padding: 16px 24px; border-top: 1px solid var(--border); display: flex; gap: 8px; flex-shrink: 0; }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
    .field { display: flex; flex-direction: column; gap: 5px; }
    .field label { font-size: var(--fs-xs); color: var(--text-muted); }
    .field input, .field textarea, .field select { background: var(--bg3); border: 1px solid var(--border); color: var(--text); border-radius: 7px; padding: 8px 12px; font-size: var(--fs-sm); font-family: inherit; transition: border-color 0.15s, box-shadow 0.15s; outline: none; }
    .field input:focus, .field textarea:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(200,168,75,0.1); }
    .field input::placeholder, .field textarea::placeholder { color: var(--text-faint); }
    .field textarea { resize: vertical; min-height: 72px; }
    .field-full { grid-column: 1 / -1; }
    .field-sep { grid-column: 1 / -1; border: none; border-top: 1px solid var(--border); margin: 4px 0; }
    .field-section { grid-column: 1 / -1; font-size: var(--fs-xs); font-weight: var(--fw-semibold); color: var(--text-faint); text-transform: uppercase; letter-spacing: 0.08em; padding-top: 4px; }

    .btn-submit { flex: 1; height: 40px; background: var(--gold); border: none; border-radius: 8px; font-size: var(--fs-sm); font-weight: var(--fw-semibold); color: #000; cursor: pointer; font-family: inherit; transition: background 0.15s; }
    .btn-submit:hover { background: var(--gold-light); }
    .btn-cancel { height: 40px; padding: 0 16px; background: transparent; border: 1px solid var(--border); border-radius: 8px; font-size: var(--fs-sm); color: var(--text-muted); cursor: pointer; font-family: inherit; transition: all 0.15s; }
    .btn-cancel:hover { border-color: var(--border-gold); color: var(--text); }

    /* ── FOTOĞRAF KIRPICI ── */
    .cropper-wrap { display: flex; flex-direction: column; align-items: center; gap: 8px; }
    .cropper-box { width: 220px; height: 220px; border-radius: 50%; overflow: hidden; position: relative; background: var(--bg3); border: 1px solid var(--border); cursor: grab; touch-action: none; user-select: none; }
    .cropper-box:active { cursor: grabbing; }
    .cropper-box img { position: absolute; top: 0; left: 0; transform-origin: top left; pointer-events: none; }
    .cropper-empty { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; color: var(--text-faint); font-size: var(--fs-xs); text-align: center; line-height: 1.8; }
    .cropper-controls { display: flex; align-items: center; gap: 10px; }
    .cropper-zoom { display: flex; align-items: center; gap: 8px; background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 4px 6px; }
    .cropper-zoom button { width: 24px; height: 24px; border-radius: 6px; background: var(--bg4); border: 1px solid var(--border); color: var(--text); cursor: pointer; font-size: 0.9rem; line-height: 1; }
    .cropper-zoom button:hover { border-color: var(--border-gold); }
    .cropper-zoom span { font-size: var(--fs-xs); color: var(--text-muted); min-width: 26px; text-align: center; }
    .cropper-hint { font-size: var(--fs-xs); color: var(--text-faint); }

    /* ── BİYOGRAFİ TOOLBAR ── */
    .bio-toolbar { display: flex; gap: 4px; margin-bottom: 6px; }
    .bio-toolbar button { width: 28px; height: 28px; border-radius: 6px; background: var(--bg3); border: 1px solid var(--border); color: var(--text-muted); cursor: pointer; font-size: 0.8rem; font-family: inherit; }
    .bio-toolbar button:hover { color: var(--text); border-color: var(--border-gold); }

    /* ── ÖNİZLEME ── */
    .preview-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 12px; padding: 24px; text-align: center; }
    .preview-photo-wrap { display: flex; justify-content: center; margin-bottom: 14px; }
    .preview-photo-wrap canvas { border-radius: 50%; background: var(--bg4); }
    .preview-ad { font-size: 1.1rem; font-weight: var(--fw-bold); color: var(--text); }
    .preview-unvan { font-size: var(--fs-sm); color: var(--text-muted); margin-top: 2px; }
    .preview-info { font-size: var(--fs-sm); color: var(--text-muted); margin-top: 14px; display: flex; flex-direction: column; gap: 4px; }
    .preview-bio { font-size: var(--fs-sm); color: var(--text); margin-top: 14px; line-height: 1.6; }
    .preview-sosyal { display: flex; flex-wrap: wrap; gap: 6px; justify-content: center; margin-top: 14px; }
    .preview-chip { background: var(--gold-dim); color: var(--gold); font-size: var(--fs-xs); font-weight: var(--fw-medium); padding: 4px 10px; border-radius: 100px; }
    .preview-note { font-size: var(--fs-xs); color: var(--text-faint); text-align: center; margin-top: 14px; line-height: 1.6; }

    @media (max-width: 640px) {
      .stat-row { grid-template-columns: 1fr 1fr; }
      .slide-panel { width: 100vw; }
      .form-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav class="dash-nav">
  <a href="/" class="nav-logo">NFC<em>Kartify</em></a>
  <span class="nav-center"><%= bayi.ad %></span>
  <div class="nav-right">
    <form method="POST" action="/bayi/cikis" style="margin:0">
      <button type="submit" class="btn btn-ghost">Çıkış</button>
    </form>
  </div>
</nav>

<!-- FLASH -->
<% if (success && success.length) { %>
  <div class="flash-bar flash-success">✓ <%= success[0] %></div>
<% } %>
<% if (error && error.length) { %>
  <div class="flash-bar flash-error">✕ <%= error[0] %></div>
<% } %>

<div class="dash-main">

<% if (view === 'musteriler') { %>

  <div class="dash-header">
    <div>
      <div class="dash-title">Hoş geldiniz</div>
      <div class="dash-subtitle"><%= bayi.email %></div>
    </div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-gold" onclick="openMusteriSlide()">+ Profil Oluştur</button>
    </div>
  </div>

  <div class="stat-row" style="grid-template-columns:repeat(2,1fr)">
    <div class="stat-card">
      <div class="stat-card-n"><%= firmalar.length %></div>
      <div class="stat-card-l">Müşteri</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-n"><%= firmalar.reduce((s,f)=>s+parseInt(f.calisan_sayisi||0),0) %></div>
      <div class="stat-card-l">Toplam Kart</div>
    </div>
  </div>

  <% if (firmalar.length) { %>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Müşteri</th><th>Sektör</th><th>Kart Sayısı</th><th>İşlem</th></tr></thead>
      <tbody>
        <% firmalar.forEach(f => { %>
        <tr>
          <td><div class="td-name"><%= f.ad %></div></td>
          <td><div class="td-sub"><%= f.sektor %></div></td>
          <td><%= f.calisan_sayisi %></td>
          <td>
            <div class="td-actions">
              <a href="/?firma=<%= f.id %>" class="btn btn-border btn-sm">Kartlar</a>
              <form method="POST" action="/bayi/panel/firma-sil/<%= f.id %>" style="margin:0"
                    onsubmit="return confirm('<%= f.ad %> ve tüm kartları silinecek. Emin misin?')">
                <button type="submit" class="btn btn-danger-sm btn-sm">Sil</button>
              </form>
            </div>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } else { %>
  <div class="table-wrap">
    <div class="empty-state">
      <div class="empty-state-icon">🏢</div>
      <div class="empty-state-title">Henüz müşteri yok</div>
      <div class="empty-state-sub">İlk müşterini ekleyerek başla</div>
      <button class="btn btn-gold" onclick="openMusteriSlide()">+ Profil Oluştur</button>
    </div>
  </div>
  <% } %>

  <!-- SLIDE: YENİ MÜŞTERİ -->
  <div class="panel-overlay" id="musteriOverlay">
    <div class="slide-panel">
      <div class="slide-header">
        <span class="slide-title">Yeni Profil</span>
        <button class="slide-close" onclick="closeMusteriSlide()">✕</button>
      </div>
      <div class="slide-body">
        <!-- FORM ADIMI -->
        <div id="musteriFormView">
        <form id="musteriForm" method="POST" action="/bayi/panel/firma-ekle" enctype="multipart/form-data" onsubmit="return false">
          <div class="form-row">
            <div class="field field-full">
              <label>Fotoğraf</label>
              <div class="cropper-wrap">
                <div class="cropper-box" id="m_cropper_box">
                  <img id="m_foto_img" alt="" style="display:none">
                  <div class="cropper-empty" id="m_cropper_empty">📷<br>Fotoğraf Seç</div>
                </div>
                <div class="cropper-controls">
                  <button type="button" class="btn-cancel btn-sm" onclick="document.getElementById('m_foto_input').click()">Fotoğraf Seç</button>
                  <div class="cropper-zoom" id="m_zoom_controls" style="display:none">
                    <button type="button" onclick="fotoZoom(-1)">−</button>
                    <span id="m_zoom_label">1x</span>
                    <button type="button" onclick="fotoZoom(1)">+</button>
                  </div>
                </div>
                <div class="cropper-hint" id="m_cropper_hint" style="display:none">Sürükleyerek konumlandırın</div>
              </div>
              <input type="file" id="m_foto_input" accept="image/jpeg,image/png,image/webp" style="display:none">
            </div>

            <div class="field field-full"><label>Ad Soyad *</label><input type="text" name="ad_soyad" id="m_ad_soyad" placeholder="Örn: Ahmet Yılmaz" required></div>
            <div class="field"><label>Unvan</label><input type="text" name="unvan" id="m_unvan" placeholder="Örn: Satış Müdürü"></div>
            <div class="field"><label>Departman</label><input type="text" name="departman" id="m_departman"></div>
            <div class="field"><label>Telefon</label><input type="tel" name="telefon" id="m_telefon" placeholder="+905001112233"></div>
            <div class="field"><label>E-posta</label><input type="email" name="email" id="m_email"></div>
            <div class="field field-full"><label>Adres</label><input type="text" name="adres" id="m_adres" placeholder="Adres aramaya başlayın..." autocomplete="off"></div>

            <hr class="field-sep">
            <div class="field-section">İşletme (isteğe bağlı)</div>
            <div class="field field-full">
              <label>İşletme / Müşteri Adı <span style="color:var(--text-faint);font-weight:400">(boş bırakılırsa ad soyad kullanılır)</span></label>
              <input type="text" name="isletme_adi" id="m_isletme_adi" placeholder="Örn: Yılmaz Berber Salonu">
            </div>
            <div class="field">
              <label>Sektör</label>
              <select name="sektor" id="m_sektor">
                <option value="diger">Diğer</option>
                <option value="teknoloji">Teknoloji</option>
                <option value="saglik">Sağlık</option>
                <option value="finans">Finans</option>
                <option value="egitim">Eğitim</option>
                <option value="insaat">İnşaat</option>
              </select>
            </div>
            <div class="field">
              <label>Kart Rengi</label>
              <input type="color" name="marka_rengi" id="m_marka_rengi" value="#1a73e8" style="height:36px;padding:2px">
            </div>

            <hr class="field-sep">
            <div class="field-section">Sosyal Medya</div>
            <div class="field"><label>LinkedIn URL</label><input type="url" name="linkedin" id="m_linkedin"></div>
            <div class="field"><label>Instagram URL</label><input type="url" name="instagram" id="m_instagram"></div>
            <div class="field"><label>Twitter / X URL</label><input type="url" name="twitter" id="m_twitter"></div>
            <div class="field"><label>YouTube URL</label><input type="url" name="youtube" id="m_youtube"></div>
            <div class="field"><label>Web Sitesi</label><input type="url" name="website" id="m_website"></div>
            <div class="field"><label>WhatsApp</label><input type="tel" name="whatsapp" id="m_whatsapp" placeholder="+905001112233"></div>
            <div class="field"><label>TikTok URL</label><input type="url" name="tiktok" id="m_tiktok"></div>
            <div class="field"><label>Sahibinden URL</label><input type="url" name="sahibinden" id="m_sahibinden"></div>
            <div class="field"><label>Hürriyet Emlak URL</label><input type="url" name="hurriyet_emlak" id="m_hurriyet_emlak"></div>
            <div class="field"><label>Google Yorum Linki</label><input type="url" name="google_yorum_link" id="m_google_yorum_link"></div>

            <hr class="field-sep">
            <div class="field field-full">
              <label>Biyografi</label>
              <div class="bio-toolbar">
                <button type="button" title="Kalın" onclick="bioFormat('bold')"><b>K</b></button>
                <button type="button" title="İtalik" onclick="bioFormat('italic')"><i>İ</i></button>
                <button type="button" title="Ortala" onclick="bioFormat('center')">≡</button>
              </div>
              <textarea name="biyografi" id="m_biyografi"></textarea>
            </div>

            <hr class="field-sep">
            <div class="field field-full" style="flex-direction:row;gap:8px;align-items:flex-start">
              <input type="checkbox" name="kvkk" id="m_kvkk" required style="margin-top:3px">
              <label style="font-weight:400" for="m_kvkk">Bu kişinin verilerinin (ad, telefon, e-posta, fotoğraf) dijital kartvizit oluşturulması amacıyla işlenmesi için onayı alınmıştır.</label>
            </div>
          </div>
        </form>
        </div>

        <!-- ÖNİZLEME ADIMI -->
        <div id="musteriPreviewView" style="display:none">
          <div class="preview-card">
            <div class="preview-photo-wrap"><canvas id="m_preview_canvas" width="120" height="120"></canvas></div>
            <div class="preview-ad" id="pv_ad_soyad"></div>
            <div class="preview-unvan" id="pv_unvan"></div>
            <div class="preview-info" id="pv_bilgiler"></div>
            <div class="preview-bio" id="pv_biyografi"></div>
            <div class="preview-sosyal" id="pv_sosyal"></div>
          </div>
          <div class="preview-note">Bu bir önizlemedir — henüz kaydedilmedi. URL, "Onayla ve Oluştur"a bastıktan sonra oluşturulur.</div>
        </div>
      </div>
      <div class="slide-footer" id="musteriFooterForm">
        <button class="btn-cancel" onclick="closeMusteriSlide()">İptal</button>
        <button class="btn-submit" onclick="musteriOnizle()">Devam Et → Önizle</button>
      </div>
      <div class="slide-footer" id="musteriFooterPreview" style="display:none">
        <button class="btn-cancel" onclick="musteriDuzenleyeDon()">← Düzenle</button>
        <button class="btn-submit" onclick="musteriOnaylaVeOlustur()">Onayla ve Oluştur</button>
      </div>
    </div>
  </div>
  <script>
    function openMusteriSlide(){
      document.getElementById('musteriOverlay').classList.add('open');
      document.body.style.overflow='hidden';
      musteriFormaDon();
    }
    function closeMusteriSlide(){document.getElementById('musteriOverlay').classList.remove('open');document.body.style.overflow='';}

    function musteriFormaDon(){
      document.getElementById('musteriFormView').style.display='block';
      document.getElementById('musteriPreviewView').style.display='none';
      document.getElementById('musteriFooterForm').style.display='flex';
      document.getElementById('musteriFooterPreview').style.display='none';
    }
    const musteriDuzenleyeDon = musteriFormaDon;

    // Basit ve güvenli önizleme render'ı — innerHTML kullanmadan, sadece
    // izin verilen b/i/p(center) etiketlerini tanıyıp gerçek DOM node'u üretir.
    function metniTemizEkle(container, text){
      container.appendChild(document.createTextNode(text));
    }
    function biyografiOnizleOlustur(container, kaynak){
      container.textContent = '';
      const merkezEslesme = kaynak.match(/^<p style="text-align:center">([\s\S]*)<\/p>$/);
      const govdeHedef = merkezEslesme ? document.createElement('div') : container;
      if (merkezEslesme) govdeHedef.style.textAlign = 'center';
      const govdeMetin = merkezEslesme ? merkezEslesme[1] : kaynak;

      const parcaDeseni = /<(\/?)(b|i)>/g;
      let sonIndex = 0, acikEtiketler = [], hedef = govdeHedef;
      for (const eslesme of govdeMetin.matchAll(parcaDeseni)) {
        if (eslesme.index > sonIndex) metniTemizEkle(hedef, govdeMetin.slice(sonIndex, eslesme.index));
        const kapaniyorMu = eslesme[1] === '/';
        const etiketAdi = eslesme[2];
        if (!kapaniyorMu) {
          const yeniEl = document.createElement(etiketAdi);
          hedef.appendChild(yeniEl);
          acikEtiketler.push(hedef);
          hedef = yeniEl;
        } else if (acikEtiketler.length) {
          hedef = acikEtiketler.pop();
        }
        sonIndex = eslesme.index + eslesme[0].length;
      }
      if (sonIndex < govdeMetin.length) metniTemizEkle(hedef, govdeMetin.slice(sonIndex));
      if (merkezEslesme) container.appendChild(govdeHedef);
    }

    function musteriOnizle(){
      const form = document.getElementById('musteriForm');
      if (!form.reportValidity()) return;

      document.getElementById('pv_ad_soyad').textContent = document.getElementById('m_ad_soyad').value;
      document.getElementById('pv_unvan').textContent = document.getElementById('m_unvan').value || '';

      const bilgilerEl = document.getElementById('pv_bilgiler');
      bilgilerEl.textContent = '';
      [
        ['📞 ', 'm_telefon'], ['✉️ ', 'm_email'], ['📍 ', 'm_adres'],
      ].forEach(([onEk, id]) => {
        const deger = document.getElementById(id).value;
        if (!deger) return;
        const satir = document.createElement('div');
        satir.textContent = onEk + deger;
        bilgilerEl.appendChild(satir);
      });

      biyografiOnizleOlustur(document.getElementById('pv_biyografi'), document.getElementById('m_biyografi').value);

      const sosyalEl = document.getElementById('pv_sosyal');
      sosyalEl.textContent = '';
      [
        ['m_linkedin','LinkedIn'], ['m_instagram','Instagram'], ['m_twitter','X/Twitter'],
        ['m_youtube','YouTube'], ['m_website','Web'], ['m_whatsapp','WhatsApp'],
        ['m_tiktok','TikTok'], ['m_sahibinden','Sahibinden'], ['m_hurriyet_emlak','Hürriyet Emlak'],
        ['m_google_yorum_link','Google Yorum'],
      ].forEach(([id, etiket]) => {
        if (!document.getElementById(id).value) return;
        const chip = document.createElement('span');
        chip.className = 'preview-chip';
        chip.textContent = etiket;
        sosyalEl.appendChild(chip);
      });

      const previewCanvas = document.getElementById('m_preview_canvas');
      const pctx = previewCanvas.getContext('2d');
      pctx.clearRect(0,0,120,120);
      if (fotoState.img) {
        fotoCiz(pctx, 120);
      } else {
        pctx.fillStyle = '#28282e';
        pctx.fillRect(0,0,120,120);
      }

      document.getElementById('musteriFormView').style.display='none';
      document.getElementById('musteriPreviewView').style.display='block';
      document.getElementById('musteriFooterForm').style.display='none';
      document.getElementById('musteriFooterPreview').style.display='flex';
    }

    function musteriOnaylaVeOlustur(){
      if (fotoState.img) {
        const canvas = document.createElement('canvas');
        canvas.width = 600; canvas.height = 600;
        fotoCiz(canvas.getContext('2d'), 600);
        canvas.toBlob(blob => {
          const dosya = new File([blob], 'foto.jpg', { type: 'image/jpeg' });
          const dt = new DataTransfer();
          dt.items.add(dosya);
          document.getElementById('m_foto_input').files = dt.files;
          document.getElementById('m_foto_input').name = 'foto';
          document.getElementById('musteriForm').submit();
        }, 'image/jpeg', 0.9);
      } else {
        document.getElementById('musteriForm').submit();
      }
    }

    // ── BİYOGRAFİ BİÇİMLENDİRME ──
    function bioFormat(tip){
      const el = document.getElementById('m_biyografi');
      if (tip === 'center') {
        const merkezliMi = /^<p style="text-align:center">[\s\S]*<\/p>$/.test(el.value.trim());
        if (merkezliMi) {
          el.value = el.value.trim().replace(/^<p style="text-align:center">/, '').replace(/<\/p>$/, '');
        } else {
          el.value = `<p style="text-align:center">${el.value}</p>`;
        }
        el.focus();
        return;
      }
      const etiket = tip === 'bold' ? 'b' : 'i';
      const start = el.selectionStart, end = el.selectionEnd;
      const secili = el.value.slice(start, end) || 'metin';
      el.value = el.value.slice(0, start) + '<' + etiket + '>' + secili + '</' + etiket + '>' + el.value.slice(end);
      el.focus();
    }

    // ── FOTOĞRAF KIRPICI (sürükle + yakınlaştır) ──
    const ZOOM_KADEMELERI = [1, 1.33, 1.66, 2];
    const KUTU_BOYUTU = 220;
    const fotoState = { img: null, baseScale: 1, zoomIndex: 0, offsetX: 0, offsetY: 0, dragging: false, startX: 0, startY: 0, startOffsetX: 0, startOffsetY: 0 };

    document.getElementById('m_foto_input').addEventListener('change', function(e){
      const dosya = e.target.files[0];
      if (!dosya) return;
      const okuyucu = new FileReader();
      okuyucu.onload = function(ev){
        const img = new Image();
        img.onload = function(){
          fotoState.img = img;
          fotoState.baseScale = Math.max(KUTU_BOYUTU / img.naturalWidth, KUTU_BOYUTU / img.naturalHeight);
          fotoState.zoomIndex = 0;
          const olcek = fotoState.baseScale;
          fotoState.offsetX = (KUTU_BOYUTU - img.naturalWidth * olcek) / 2;
          // Varsayılan olarak üste yasla (ortalamak yerine) — portre fotoğraflarda
          // yüz genelde üst bölgede olur, ortalanmış kırpma kafayı kesiyordu.
          fotoState.offsetY = 0;
          document.getElementById('m_foto_img').src = ev.target.result;
          document.getElementById('m_foto_img').style.display = 'block';
          document.getElementById('m_cropper_empty').style.display = 'none';
          document.getElementById('m_zoom_controls').style.display = 'flex';
          document.getElementById('m_cropper_hint').style.display = 'block';
          fotoGuncelle();
        };
        img.src = ev.target.result;
      };
      okuyucu.readAsDataURL(dosya);
    });

    function fotoOlcek(){ return fotoState.baseScale * ZOOM_KADEMELERI[fotoState.zoomIndex]; }

    function fotoSinirla(){
      const olcek = fotoOlcek();
      const genislik = fotoState.img.naturalWidth * olcek;
      const yukseklik = fotoState.img.naturalHeight * olcek;
      const minX = Math.min(0, KUTU_BOYUTU - genislik), maxX = 0;
      const minY = Math.min(0, KUTU_BOYUTU - yukseklik), maxY = 0;
      fotoState.offsetX = Math.max(minX, Math.min(maxX, fotoState.offsetX));
      fotoState.offsetY = Math.max(minY, Math.min(maxY, fotoState.offsetY));
    }

    function fotoGuncelle(){
      if (!fotoState.img) return;
      fotoSinirla();
      const olcek = fotoOlcek();
      const imgEl = document.getElementById('m_foto_img');
      imgEl.style.width = (fotoState.img.naturalWidth * olcek) + 'px';
      imgEl.style.height = (fotoState.img.naturalHeight * olcek) + 'px';
      imgEl.style.transform = `translate(${fotoState.offsetX}px, ${fotoState.offsetY}px)`;
      document.getElementById('m_zoom_label').textContent = ZOOM_KADEMELERI[fotoState.zoomIndex] + 'x';
    }

    function fotoZoom(yon){
      if (!fotoState.img) return;
      const yeniIndex = Math.max(0, Math.min(ZOOM_KADEMELERI.length - 1, fotoState.zoomIndex + yon));
      if (yeniIndex === fotoState.zoomIndex) return;
      const eskiOlcek = fotoOlcek();
      fotoState.zoomIndex = yeniIndex;
      const yeniOlcek = fotoOlcek();
      const merkezX = KUTU_BOYUTU / 2, merkezY = KUTU_BOYUTU / 2;
      fotoState.offsetX = merkezX - (merkezX - fotoState.offsetX) * (yeniOlcek / eskiOlcek);
      fotoState.offsetY = merkezY - (merkezY - fotoState.offsetY) * (yeniOlcek / eskiOlcek);
      fotoGuncelle();
    }

    function fotoCiz(ctx, hedefBoyut){
      const olcek = fotoOlcek();
      const sx = -fotoState.offsetX / olcek;
      const sy = -fotoState.offsetY / olcek;
      const sBoyut = KUTU_BOYUTU / olcek;
      ctx.drawImage(fotoState.img, sx, sy, sBoyut, sBoyut, 0, 0, hedefBoyut, hedefBoyut);
    }

    function surukleBasla(x, y){
      if (!fotoState.img) return;
      fotoState.dragging = true;
      fotoState.startX = x; fotoState.startY = y;
      fotoState.startOffsetX = fotoState.offsetX; fotoState.startOffsetY = fotoState.offsetY;
    }
    function surukleDevam(x, y){
      if (!fotoState.dragging) return;
      fotoState.offsetX = fotoState.startOffsetX + (x - fotoState.startX);
      fotoState.offsetY = fotoState.startOffsetY + (y - fotoState.startY);
      fotoGuncelle();
    }
    function surukleBitir(){ fotoState.dragging = false; }

    const cropperKutu = document.getElementById('m_cropper_box');
    cropperKutu.addEventListener('mousedown', e => surukleBasla(e.clientX, e.clientY));
    document.addEventListener('mousemove', e => surukleDevam(e.clientX, e.clientY));
    document.addEventListener('mouseup', surukleBitir);
    cropperKutu.addEventListener('touchstart', e => { const t = e.touches[0]; surukleBasla(t.clientX, t.clientY); }, { passive: true });
    cropperKutu.addEventListener('touchmove', e => { const t = e.touches[0]; surukleDevam(t.clientX, t.clientY); }, { passive: true });
    cropperKutu.addEventListener('touchend', surukleBitir);
    cropperKutu.addEventListener('click', () => { if (!fotoState.img) document.getElementById('m_foto_input').click(); });
  </script>

