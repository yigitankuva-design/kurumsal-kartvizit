<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kart Başvurusu — NFCKartify</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #1c1c20; --bg2: #222227; --bg3: #28282e;
      --border: rgba(255,255,255,0.07); --border-gold: rgba(200,168,75,0.3);
      --gold: #c8a84b; --gold-light: #e5c46a;
      --text: #f1f0ee; --text-muted: #888880; --text-faint: #444440;
      --danger: #ef4444; --danger-dim: rgba(239,68,68,0.1);
      --fs-xs: 0.72rem; --fs-sm: 0.8rem; --fs-base: 0.875rem;
      --fw-medium: 500; --fw-semibold: 600; --fw-bold: 700;
    }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); font-size: var(--fs-base); line-height: 1.5; -webkit-font-smoothing: antialiased; }
    .wrap { max-width: 560px; margin: 0 auto; padding: 40px 20px 80px; }
    .logo { font-size: 1.1rem; font-weight: var(--fw-bold); margin-bottom: 4px; }
    .logo em { font-style: normal; color: var(--gold); }
    h1 { font-size: 1.4rem; font-weight: var(--fw-bold); margin: 4px 0 6px; letter-spacing: -0.02em; }
    .sub { color: var(--text-muted); font-size: var(--fs-sm); margin-bottom: 28px; }
    .section-title { font-size: var(--fs-xs); font-weight: var(--fw-semibold); color: var(--gold); text-transform: uppercase; letter-spacing: 0.08em; margin: 28px 0 12px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
    .field { display: flex; flex-direction: column; gap: 5px; }
    .field-full { grid-column: 1 / -1; }
    .field label { font-size: var(--fs-xs); color: var(--text-muted); }
    .field label .opt { color: var(--text-faint); font-weight: 400; }
    .field input, .field textarea {
      background: var(--bg2); border: 1px solid var(--border); color: var(--text);
      border-radius: 8px; padding: 10px 12px; font-size: var(--fs-sm); font-family: inherit;
      outline: none; transition: border-color 0.15s;
    }
    .field input:focus, .field textarea:focus { border-color: var(--gold); }
    .field textarea { resize: vertical; min-height: 90px; }
    .bio-toolbar { display: flex; gap: 4px; margin-bottom: 6px; }
    .bio-toolbar button {
      width: 28px; height: 28px; border-radius: 6px; background: var(--bg2); border: 1px solid var(--border);
      color: var(--text-muted); cursor: pointer; font-size: 13px; font-family: inherit;
    }
    .bio-toolbar button:hover { color: var(--text); border-color: var(--border-gold); }
    .foto-box {
      border: 1.5px dashed var(--border); border-radius: 10px; padding: 24px; text-align: center;
      cursor: pointer; background: var(--bg2);
    }
    .foto-box:hover { border-color: var(--border-gold); }
    .foto-box input { display: none; }
    .foto-icon { font-size: 1.6rem; margin-bottom: 6px; }
    .foto-label { font-size: var(--fs-sm); color: var(--text-muted); }
    .foto-hint { font-size: var(--fs-xs); color: var(--text-faint); margin-top: 4px; }
    .kvkk { display: flex; gap: 10px; align-items: flex-start; margin: 24px 0; font-size: var(--fs-xs); color: var(--text-muted); }
    .kvkk input { margin-top: 3px; }
    .btn-submit { width: 100%; height: 46px; background: var(--gold); border: none; border-radius: 10px; font-size: var(--fs-base); font-weight: var(--fw-semibold); color: #000; cursor: pointer; font-family: inherit; }
    .btn-submit:hover { background: var(--gold-light); }
    .flash-error { background: var(--danger-dim); color: var(--danger); border: 1px solid rgba(239,68,68,0.2); border-radius: 8px; padding: 10px 14px; font-size: var(--fs-sm); margin-bottom: 20px; }
    @media (max-width: 480px) { .form-row { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <div class="wrap">
    <a href="/" class="logo">NFC<em>Kartify</em></a>
    <h1>Dijital Kart Başvurusu</h1>
    <p class="sub">Bilgilerinizi doldurun, kartınız hemen hazır olsun.</p>

    <% if (error && error.length) { %>
      <div class="flash-error"><%= error[0] %></div>
    <% } %>

    <form method="POST" action="/basvuru" enctype="multipart/form-data">
      <div class="section-title">İletişim Bilgileri</div>
      <div class="form-row">
        <div class="field field-full"><label>Ad Soyad *</label><input type="text" name="ad_soyad" placeholder="Berber Ahmet" required></div>
        <div class="field"><label>Telefon *</label><input type="tel" name="telefon" placeholder="05XX XXX XX XX" required></div>
        <div class="field"><label>E-posta <span class="opt">(isteğe bağlı)</span></label><input type="email" name="eposta" placeholder="ahmet@mail.com"></div>
        <div class="field"><label>Meslek / Unvan <span class="opt">(isteğe bağlı)</span></label><input type="text" name="meslek_unvan" placeholder="Berber, Eczacı, Market Sahibi..."></div>
        <div class="field"><label>İşletme adı <span class="opt">(isteğe bağlı)</span></label><input type="text" name="isletme_adi" placeholder="Yılmaz Berber Salonu"></div>
        <div class="field"><label>WhatsApp <span class="opt">(isteğe bağlı)</span></label><input type="tel" name="whatsapp" placeholder="05XX XXX XX XX"></div>
        <div class="field field-full"><label>Adres <span class="opt">(isteğe bağlı)</span></label><input type="text" name="adres" id="adres-input" placeholder="İşyeri veya adres ara..." autocomplete="off"></div>
      </div>

      <div class="section-title">Sosyal Medya & Linkler</div>
      <div class="form-row">
        <div class="field"><label>Instagram <span class="opt">(isteğe bağlı)</span></label><input type="text" name="instagram" placeholder="@kullanici_adi"></div>
        <div class="field"><label>LinkedIn <span class="opt">(isteğe bağlı)</span></label><input type="text" name="linkedin" placeholder="linkedin.com/in/adiniz veya tam link"></div>
        <div class="field"><label>TikTok <span class="opt">(isteğe bağlı)</span></label><input type="text" name="tiktok" placeholder="@kullanici_adi"></div>
        <div class="field"><label>X (Twitter) <span class="opt">(isteğe bağlı)</span></label><input type="text" name="twitter" placeholder="@kullanici_adi"></div>
        <div class="field"><label>Sahibinden <span class="opt">(isteğe bağlı)</span></label><input type="text" name="sahibinden" placeholder="İlan veya mağaza linki"></div>
        <div class="field"><label>Hürriyet Emlak <span class="opt">(isteğe bağlı)</span></label><input type="text" name="hurriyet_emlak" placeholder="İlan linki"></div>
        <div class="field"><label>Web sitesi <span class="opt">(isteğe bağlı)</span></label><input type="text" name="website" placeholder="www.siteniz.com"></div>
        <div class="field"><label>Google yorum linki <span class="opt">(isteğe bağlı)</span></label><input type="text" name="google_yorum_link" placeholder="İşletme adını ara..."></div>
      </div>

      <div class="section-title">Tanıtım</div>
      <div class="field field-full">
        <label>Tanıtım yazısı <span class="opt">(isteğe bağlı)</span></label>
        <div class="bio-toolbar">
          <button type="button" title="Kalın" onclick="bioFormat('b')"><b>K</b></button>
          <button type="button" title="İtalik" onclick="bioFormat('i')"><i>İ</i></button>
        </div>
        <textarea name="tanitim" id="tanitim" rows="4" placeholder="İşletmeniz veya kendiniz hakkında kısa bir yazı..."></textarea>
      </div>

      <div class="section-title">Fotoğraf</div>
      <label class="foto-box" for="fotograf-input">
        <div class="foto-icon">📷</div>
        <div class="foto-label" id="foto-label-text">Fotoğraf seç veya çek</div>
        <div class="foto-hint">JPG, PNG veya WebP · Maks. 15 MB</div>
        <input type="file" name="fotograf" id="fotograf-input" accept="image/jpeg,image/png,image/webp"
               onchange="document.getElementById('foto-label-text').textContent = this.files[0] ? this.files[0].name : 'Fotoğraf seç veya çek'">
      </label>

      <label class="kvkk">
        <input type="checkbox" name="kvkk" required>
        <span>Kişisel verilerimin (ad, telefon, e-posta, fotoğraf) dijital kartvizit oluşturulması amacıyla işlenmesini ve KVKK kapsamında saklanmasını kabul ediyorum.</span>
      </label>

      <button type="submit" class="btn-submit">Başvuruyu Gönder →</button>
    </form>
  </div>

  <% if (process.env.GOOGLE_MAPS_API_KEY) { %>
  <script src="https://maps.googleapis.com/maps/api/js?key=<%= process.env.GOOGLE_MAPS_API_KEY %>&libraries=places&callback=adresAutocompleteBaslat" async defer></script>
  <script>
    function adresAutocompleteBaslat() {
      const input = document.getElementById('adres-input');
      if (!input || !window.google) return;
      new google.maps.places.Autocomplete(input, { types: ['address'], componentRestrictions: { country: 'tr' } });
    }
  </script>
  <% } %>

  <script>
    function bioFormat(tag) {
      const el = document.getElementById('tanitim');
      const start = el.selectionStart, end = el.selectionEnd;
      const secili = el.value.slice(start, end) || 'metin';
      el.value = el.value.slice(0, start) + '<' + tag + '>' + secili + '</' + tag + '>' + el.value.slice(end);
      el.focus();
    }
  </script>
</body>
</html>
