<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NFCKartify — Yönetici</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #1c1c20;
      --bg2: #222227;
      --bg3: #28282e;
      --bg4: #2e2e35;
      --border: rgba(255,255,255,0.07);
      --border-gold: rgba(200,168,75,0.3);
      --gold: #c8a84b;
      --gold-light: #e5c46a;
      --gold-dim: rgba(200,168,75,0.1);
      --text: #f1f0ee;
      --text-muted: #888880;
      --text-faint: #444440;
      --danger: #ef4444;
      --danger-dim: rgba(239,68,68,0.1);
      --success: #22c55e;
      --success-dim: rgba(34,197,94,0.1);
      --fs-xs: 0.72rem;
      --fs-sm: 0.8rem;
      --fs-base: 0.875rem;
      --fw-normal: 400;
      --fw-medium: 500;
      --fw-semibold: 600;
      --fw-bold: 700;
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); font-size: var(--fs-base); line-height: 1.5; -webkit-font-smoothing: antialiased; overflow-x: hidden; }

    .dash-nav {
      position: sticky; top: 0; z-index: 50;
      height: 52px; display: flex; align-items: center; justify-content: space-between;
      padding: 0 24px;
      background: rgba(13,13,15,0.95); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo { font-size: var(--fs-base); font-weight: var(--fw-bold); color: var(--text); text-decoration: none; letter-spacing: -0.02em; }
    .nav-logo em { font-style: normal; color: var(--gold); }
    .nav-center { font-size: var(--fs-sm); color: var(--text-muted); font-weight: var(--fw-medium); }
    .nav-right { display: flex; align-items: center; gap: 8px; }

    .btn { display: inline-flex; align-items: center; gap: 6px; height: 32px; padding: 0 14px; border-radius: 6px; font-size: var(--fs-sm); font-weight: var(--fw-medium); cursor: pointer; border: none; font-family: inherit; text-decoration: none; transition: all 0.15s; white-space: nowrap; }
    .btn-ghost { background: transparent; color: var(--text-muted); }
    .btn-ghost:hover { background: var(--bg3); color: var(--text); }
    .btn-gold { background: var(--gold); color: #000; font-weight: var(--fw-semibold); box-shadow: 0 0 16px rgba(200,168,75,0.2); }
    .btn-gold:hover { background: var(--gold-light); }
    .btn-danger-sm { background: var(--danger-dim); color: var(--danger); border: 1px solid rgba(239,68,68,0.2); }
    .btn-danger-sm:hover { background: rgba(239,68,68,0.18); }
    .btn-sm { height: 28px; padding: 0 10px; font-size: var(--fs-xs); }

    .flash-bar { padding: 10px 24px; font-size: var(--fs-sm); font-weight: var(--fw-medium); display: flex; align-items: center; gap: 8px; }
    .flash-success { background: var(--success-dim); color: var(--success); border-bottom: 1px solid rgba(34,197,94,0.15); }
    .flash-error { background: var(--danger-dim); color: var(--danger); border-bottom: 1px solid rgba(239,68,68,0.15); }

    .dash-main { max-width: 1100px; margin: 0 auto; padding: 28px 24px 64px; }
    .dash-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
    .dash-title { font-size: 1.125rem; font-weight: var(--fw-bold); color: var(--text); letter-spacing: -0.02em; }
    .dash-subtitle { font-size: var(--fs-xs); color: var(--text-faint); margin-top: 2px; }

    .stat-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 24px; }
    .stat-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 16px 18px; }
    .stat-card-n { font-size: 1.5rem; font-weight: var(--fw-bold); color: var(--gold); letter-spacing: -0.04em; }
    .stat-card-l { font-size: var(--fs-xs); color: var(--text-faint); margin-top: 2px; }

    .dash-tabs { display: flex; gap: 2px; background: var(--bg2); border: 1px solid var(--border); border-radius: 8px; padding: 3px; width: fit-content; margin-bottom: 20px; }
    .dash-tab { padding: 6px 16px; border-radius: 6px; font-size: var(--fs-xs); font-weight: var(--fw-medium); color: var(--text-muted); text-decoration: none; border: none; background: transparent; cursor: pointer; font-family: inherit; transition: all 0.15s; white-space: nowrap; }
    .dash-tab.active, .dash-tab:hover { color: var(--text); background: var(--bg3); }
    .dash-tab.active { color: var(--gold); }

    .table-wrap { border: 1px solid var(--border); border-radius: 10px; overflow: hidden; margin-bottom: 24px; }
    table { width: 100%; border-collapse: collapse; }
    thead th { padding: 10px 16px; text-align: left; font-size: var(--fs-xs); font-weight: var(--fw-medium); color: var(--text-faint); background: var(--bg2); border-bottom: 1px solid var(--border); }
    tbody tr { border-bottom: 1px solid var(--border); transition: background 0.1s; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: var(--bg2); }
    tbody td { padding: 12px 16px; font-size: var(--fs-sm); vertical-align: middle; }
    .td-name { font-weight: var(--fw-semibold); color: var(--text); }
    .td-sub { font-size: var(--fs-xs); color: var(--text-faint); font-family: monospace; }

    .badge { display: inline-flex; align-items: center; height: 20px; padding: 0 8px; border-radius: 100px; font-size: 0.65rem; font-weight: var(--fw-semibold); letter-spacing: 0.03em; text-transform: uppercase; }
    .badge-aktif { background: var(--success-dim); color: var(--success); }
    .badge-pasif { background: var(--bg3); color: var(--text-faint); }

    .empty-state { text-align: center; padding: 48px 24px; }
    .empty-state-title { font-size: var(--fs-sm); font-weight: var(--fw-semibold); color: var(--text-muted); }

    .excel-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 24px; max-width: 560px; margin-bottom: 24px; }
    .excel-card h3 { font-size: var(--fs-base); font-weight: var(--fw-semibold); margin-bottom: 16px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
    .field { display: flex; flex-direction: column; gap: 5px; }
    .field label { font-size: var(--fs-xs); color: var(--text-muted); }
    .field input {
      background: var(--bg3); border: 1px solid var(--border); color: var(--text);
      border-radius: 7px; padding: 8px 12px; font-size: var(--fs-sm); font-family: inherit;
      transition: border-color 0.15s, box-shadow 0.15s; outline: none;
    }
    .field input:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(200,168,75,0.1); }
    .field-full { grid-column: 1 / -1; }
    .btn-submit { height: 36px; padding: 0 18px; background: var(--gold); border: none; border-radius: 8px; font-size: var(--fs-sm); font-weight: var(--fw-semibold); color: #000; cursor: pointer; font-family: inherit; transition: background 0.15s; margin-top: 4px; }
    .btn-submit:hover { background: var(--gold-light); }

    @media (max-width: 640px) {
      .stat-row { grid-template-columns: 1fr; }
      .form-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<nav class="dash-nav">
  <a href="/" class="nav-logo">NFC<em>Kartify</em></a>
  <span class="nav-center">Yönetici Paneli</span>
  <div class="nav-right">
    <form method="POST" action="/superadmin/cikis" style="margin:0">
      <button type="submit" class="btn btn-ghost">Çıkış</button>
    </form>
  </div>
</nav>

<% if (success && success.length) { %>
  <div class="flash-bar flash-success">✓ <%= success[0] %></div>
<% } %>
<% if (error && error.length) { %>
  <div class="flash-bar flash-error">✕ <%= error[0] %></div>
<% } %>

<div class="dash-main">

  <div class="dash-header">
    <div>
      <div class="dash-title">Yönetici Paneli</div>
      <div class="dash-subtitle">Tüm firmalar ve matbaa bayileri</div>
    </div>
  </div>

  <div class="stat-row">
    <div class="stat-card">
      <div class="stat-card-n"><%= firmalar.length %></div>
      <div class="stat-card-l">Toplam firma</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-n"><%= bayiler.length %></div>
      <div class="stat-card-l">Toplam bayi</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-n"><%= firmalar.reduce((s,f)=>s+parseInt(f.calisan_sayisi||0),0) %></div>
      <div class="stat-card-l">Toplam kart</div>
    </div>
  </div>

  <div class="dash-tabs">
    <a href="/?tab=firmalar" class="dash-tab <%= tab === 'firmalar' ? 'active' : '' %>">Firmalar</a>
    <a href="/?tab=bayiler" class="dash-tab <%= tab === 'bayiler' ? 'active' : '' %>">Bayiler</a>
  </div>

  <% if (tab === 'firmalar') { %>
    <% if (firmalar.length) { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Firma</th><th>Bayi</th><th>Sektör</th><th>Çalışan</th><th>Kayıt</th><th></th></tr>
        </thead>
        <tbody>
          <% firmalar.forEach(f => { %>
          <tr>
            <td><div class="td-name"><%= f.ad %></div><div class="td-sub"><%= f.slug %></div></td>
            <td><%= f.bayi_ad || '—' %></td>
            <td><%= f.sektor %></td>
            <td><%= f.calisan_sayisi %></td>
            <td class="td-sub"><%= new Date(f.created_at).toLocaleDateString('tr-TR') %></td>
            <td>
              <form method="POST" action="/superadmin/firma-sil/<%= f.id %>"
                    onsubmit="return confirm('Firma ve tüm çalışanları silinecek. Emin misin?')">
                <button type="submit" class="btn btn-danger-sm btn-sm">Sil</button>
              </form>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
      <div class="empty-state"><div class="empty-state-title">Henüz firma yok.</div></div>
    <% } %>
  <% } %>

  <% if (tab === 'bayiler') { %>
    <div class="excel-card">
      <h3>Yeni Matbaa Bayisi Ekle</h3>
      <form method="POST" action="/superadmin/bayi-ekle">
        <div class="form-row">
          <div class="field"><label>Bayi Adı</label><input type="text" name="ad" required></div>
          <div class="field"><label>Email</label><input type="email" name="email" required></div>
          <div class="field"><label>Şifre</label><input type="password" name="sifre" required></div>
          <div class="field"><label>Marka Rengi</label><input type="color" name="marka_rengi" value="#c8a84b" style="height:36px;padding:2px"></div>
        </div>
        <button type="submit" class="btn-submit">Bayi Ekle</button>
      </form>
    </div>

    <% if (bayiler.length) { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Bayi</th><th>Email</th><th>Durum</th><th>Kayıt</th><th></th></tr>
        </thead>
        <tbody>
          <% bayiler.forEach(b => { %>
          <tr>
            <td><div class="td-name"><%= b.ad %></div><div class="td-sub"><%= b.slug %></div></td>
            <td><%= b.email %></td>
            <td><span class="badge <%= b.aktif ? 'badge-aktif' : 'badge-pasif' %>"><%= b.aktif ? 'Aktif' : 'Pasif' %></span></td>
            <td class="td-sub"><%= new Date(b.created_at).toLocaleDateString('tr-TR') %></td>
            <td>
              <form method="POST" action="/superadmin/bayi-sil/<%= b.id %>"
                    onsubmit="return confirm('Bayi silinecek (firmalar etkilenmez). Emin misin?')">
                <button type="submit" class="btn btn-danger-sm btn-sm">Sil</button>
              </form>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
      <div class="empty-state"><div class="empty-state-title">Henüz bayi yok.</div></div>
    <% } %>
  <% } %>

</div>

</body>
</html>
