<div class="panel-container">
  <header class="panel-header">
    <h2>Yeni Müşteri Ekle</h2>
    <a href="/bayi/panel" class="btn-link">← Geri</a>
  </header>
  <form method="POST" action="/bayi/panel/firma-ekle" class="form-grup">
    <label>Müşteri / Firma Adı *</label>
    <input type="text" name="ad" required placeholder="Örn: Ahmet Demir">

    <label>Sektör</label>
    <select name="sektor">
      <option value="diger">Diğer</option>
      <option value="teknoloji">Teknoloji</option>
      <option value="saglik">Sağlık</option>
      <option value="finans">Finans</option>
      <option value="egitim">Eğitim</option>
      <option value="insaat">İnşaat</option>
    </select>

    <label>Kart Rengi</label>
    <input type="color" name="marka_rengi" value="#1a73e8">

    <button type="submit" class="btn" style="margin-top:8px">Müşteri Oluştur</button>
  </form>
</div>
