<div class="auth-container">
  <h1>Bayi Girişi</h1>
  <form method="POST" action="/bayi/giris">
    <label>Email</label>
    <input type="email" name="email" required>
    <label>Şifre</label>
    <input type="password" name="sifre" required>
    <button type="submit" class="btn">Giriş Yap</button>
  </form>
</div>
