<div class="panel-container">
  <header class="panel-header">
    <div>
      <% if (bayi.logo_url) { %>
        <img src="<%= bayi.logo_url %>" style="height:32px;vertical-align:middle;margin-right:8px" alt="<%= bayi.ad %>">
      <% } %>
      <h2 style="display:inline"><%= bayi.ad %></h2>
    </div>
    <form method="POST" action="/bayi/cikis">
      <button type="submit" class="btn-link">Çıkış</button>
    </form>
  </header>

  <div style="display:flex;gap:16px;margin-bottom:24px">
    <div class="stat-kart"><div class="stat-sayi"><%= firmalar.length %></div><div class="stat-label">Müşteri</div></div>
    <div class="stat-kart"><div class="stat-sayi"><%= firmalar.reduce((s,f)=>s+parseInt(f.calisan_sayisi||0),0) %></div><div class="stat-label">Toplam Kart</div></div>
  </div>

  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
    <h3>Müşteriler</h3>
    <a href="/bayi/panel/firma-ekle" class="btn">+ Müşteri Ekle</a>
  </div>

  <% if (!firmalar.length) { %>
    <p style="color:#888">Henüz müşteri yok.</p>
  <% } else { %>
  <div class="musteri-listesi">
    <% firmalar.forEach(f => { %>
    <div class="musteri-kart">
      <div class="musteri-kart-icerik">
        <div class="musteri-renk-bant" style="background:<%= f.marka_rengi %>"></div>
        <div class="musteri-bilgi">
          <strong><%= f.ad %></strong>
          <span class="musteri-meta"><%= f.calisan_sayisi %> kart · <%= f.sektor %></span>
        </div>
      </div>
      <div class="musteri-kart-aksiyonlar">
        <a href="/bayi/panel/<%= f.id %>/calisanlar" class="btn-sm">Kartlar</a>
        <form method="POST" action="/bayi/panel/firma-sil/<%= f.id %>"
              onsubmit="return confirm('<%= f.ad %> ve tüm kartları silinecek. Emin misin?')" style="display:inline">
          <button type="submit" class="btn-sm btn-danger">Sil</button>
        </form>
      </div>
    </div>
    <% }); %>
  </div>
  <% } %>
</div>
