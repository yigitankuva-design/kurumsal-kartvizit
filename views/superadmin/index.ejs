<div class="panel-container">
  <header class="panel-header">
    <h2>Süper Admin Paneli</h2>
    <form method="POST" action="/superadmin/cikis">
      <button type="submit" class="btn-link">Çıkış</button>
    </form>
  </header>

  <div class="tab-bar">
    <a href="?tab=firmalar" class="tab-btn <%= tab === 'firmalar' ? 'aktif' : '' %>">Firmalar (<%= firmalar.length %>)</a>
    <a href="?tab=bayiler" class="tab-btn <%= tab === 'bayiler' ? 'aktif' : '' %>">Bayiler (<%= bayiler.length %>)</a>
  </div>

  <% if (tab === 'firmalar') { %>
  <table class="tablo">
    <thead>
      <tr><th>Firma Adı</th><th>Slug</th><th>Bayi</th><th>Sektör</th><th>Çalışan</th><th>Kayıt</th><th>İşlem</th></tr>
    </thead>
    <tbody>
      <% firmalar.forEach(f => { %>
      <tr>
        <td><%= f.ad %></td>
        <td><code><%= f.slug %></code></td>
        <td><%= f.bayi_ad || '—' %></td>
        <td><%= f.sektor %></td>
        <td><%= f.calisan_sayisi %></td>
        <td><%= new Date(f.created_at).toLocaleDateString('tr-TR') %></td>
        <td>
          <form method="POST" action="/superadmin/firma-sil/<%= f.id %>"
                onsubmit="return confirm('Firma ve tüm çalışanları silinecek. Emin misin?')">
            <button type="submit" class="btn-sm btn-danger">Sil</button>
          </form>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } %>

  <% if (tab === 'bayiler') { %>
  <div style="margin-bottom:24px;padding:16px;background:#f5f5f5;border-radius:8px">
    <h3 style="margin-bottom:12px">Yeni Bayi Ekle</h3>
    <form method="POST" action="/superadmin/bayi-ekle" style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end">
      <div>
        <label>Ad</label><br>
        <input type="text" name="ad" required style="padding:6px 8px;border:1px solid #ccc;border-radius:4px">
      </div>
      <div>
        <label>Email</label><br>
        <input type="email" name="email" required style="padding:6px 8px;border:1px solid #ccc;border-radius:4px">
      </div>
      <div>
        <label>Şifre</label><br>
        <input type="password" name="sifre" required style="padding:6px 8px;border:1px solid #ccc;border-radius:4px">
      </div>
      <div>
        <label>Marka Rengi</label><br>
        <input type="color" name="marka_rengi" value="#1a73e8" style="height:34px;padding:2px">
      </div>
      <button type="submit" class="btn">Ekle</button>
    </form>
  </div>

  <table class="tablo">
    <thead>
      <tr><th>Bayi Adı</th><th>Slug</th><th>Email</th><th>Durum</th><th>Kayıt</th><th>İşlem</th></tr>
    </thead>
    <tbody>
      <% bayiler.forEach(b => { %>
      <tr>
        <td><%= b.ad %></td>
        <td><code><%= b.slug %></code></td>
        <td><%= b.email %></td>
        <td><%= b.aktif ? '✅ Aktif' : '❌ Pasif' %></td>
        <td><%= new Date(b.created_at).toLocaleDateString('tr-TR') %></td>
        <td>
          <form method="POST" action="/superadmin/bayi-sil/<%= b.id %>"
                onsubmit="return confirm('Bayi silinecek (firmalar etkilenmez). Emin misin?')">
            <button type="submit" class="btn-sm btn-danger">Sil</button>
          </form>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } %>
</div>
