<div class="panel-wrapper">
  <header class="panel-nav">
    <div class="panel-nav-brand">NFCKart</div>
    <div style="display:flex;align-items:center;gap:20px">
      <span class="panel-nav-firma"><%= firma.ad %></span>
      <form method="POST" action="/firma/cikis" style="margin:0">
        <button type="submit" class="btn-link">Çıkış</button>
      </form>
    </div>
  </header>

  <div class="panel-container">
    <nav class="panel-tabs">
      <a href="/firma/panel?tab=calisanlar" class="<%= tab === 'calisanlar' ? 'active' : '' %>">Çalışanlar</a>
      <a href="/firma/panel?tab=istatistik" class="<%= tab === 'istatistik' ? 'active' : '' %>">İstatistik</a>
      <a href="/firma/panel?tab=analytics" class="<%= tab === 'analytics' ? 'active' : '' %>">Link Analytics</a>
      <a href="/firma/panel?tab=excel" class="<%= tab === 'excel' ? 'active' : '' %>">Excel Yükle</a>
    </nav>

    <% if (tab === 'calisanlar') { %>
      <div class="tab-content">
        <div class="panel-actions">
          <div class="sayaclar">
            <span class="chip aktif">Aktif: <%= aktifSayisi %></span>
            <span class="chip pasif">Pasif: <%= pasifSayisi %></span>
          </div>
          <div style="display:flex;gap:8px">
            <a href="/firma/panel/ekle" class="btn">+ Yeni Çalışan</a>
          </div>
        </div>
        <% if (calisanlar.length) { %>
        <table class="tablo">
          <thead>
            <tr>
              <th>Ad Soyad</th>
              <th>Unvan</th>
              <th>Durum</th>
              <th>Profil URL</th>
              <th>İşlemler</th>
            </tr>
          </thead>
          <tbody>
            <% calisanlar.forEach(c => { %>
            <tr class="<%= c.durum === 'pasif' ? 'row-pasif' : '' %>">
              <td style="font-weight:600"><%= c.ad %> <%= c.soyad %></td>
              <td style="color:#6b7280"><%= c.unvan || '—' %></td>
              <td><span class="durum-badge durum-<%= c.durum %>"><%= c.durum %></span></td>
              <td><a href="/<%= firma.slug %>/<%= c.slug %>" target="_blank" class="url-link">/<%= firma.slug %>/<%= c.slug %></a></td>
              <td>
                <div style="display:flex;gap:6px;align-items:center">
                  <a href="/firma/panel/<%= c.id %>/duzenle" class="btn-sm">Düzenle</a>
                  <form method="POST" action="/firma/panel/<%= c.id %>/durum" style="margin:0">
                    <input type="hidden" name="_method" value="PATCH">
                    <input type="hidden" name="durum" value="<%= c.durum === 'aktif' ? 'pasif' : 'aktif' %>">
                    <button type="submit" class="btn-sm btn-danger"><%= c.durum === 'aktif' ? 'Pasife Al' : 'Aktif Et' %></button>
                  </form>
                </div>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
        <% } else { %>
          <div class="bos-mesaj">
            <p style="font-size:32px;margin-bottom:12px">👤</p>
            <p style="font-weight:600;color:#374151;margin-bottom:6px">Henüz çalışan eklenmemiş</p>
            <p><a href="/firma/panel/ekle">İlk çalışanı ekleyin →</a></p>
          </div>
        <% } %>
      </div>

    <% } else if (tab === 'istatistik') { %>
      <div class="tab-content">
        <div class="stat-grid">
          <div class="stat-kart">
            <div class="stat-label">Toplam Çalışan</div>
            <div class="stat-sayi"><%= aktifSayisi + pasifSayisi %></div>
          </div>
          <div class="stat-kart">
            <div class="stat-label">Aktif</div>
            <div class="stat-sayi aktif-renk"><%= aktifSayisi %></div>
          </div>
          <div class="stat-kart">
            <div class="stat-label">Pasif</div>
            <div class="stat-sayi pasif-renk"><%= pasifSayisi %></div>
          </div>
          <div class="stat-kart">
            <div class="stat-label">Toplam Görüntülenme</div>
            <div class="stat-sayi"><%= toplamGoruntulenme %></div>
          </div>
        </div>
        <table class="tablo">
          <thead><tr><th>Ad Soyad</th><th>Görüntülenme</th><th>Durum</th></tr></thead>
          <tbody>
            <% [...calisanlar].sort((a,b) => b.goruntuleme_sayisi - a.goruntuleme_sayisi).forEach(c => { %>
            <tr>
              <td style="font-weight:600"><%= c.ad %> <%= c.soyad %></td>
              <td><%= c.goruntuleme_sayisi %></td>
              <td><span class="durum-badge durum-<%= c.durum %>"><%= c.durum %></span></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

    <% } else if (tab === 'analytics') { %>
      <div class="tab-content">
        <h3 style="font-size:15px;font-weight:700;margin-bottom:4px">Link Tıklama Analizi</h3>
        <p style="font-size:13px;color:#6b7280;margin-bottom:16px">Çalışan profillerindeki linklere kaç kez tıklandı</p>
        <% if (linkAnalytics.length) { %>
        <table class="analytics-tablo">
          <thead>
            <tr><th>Çalışan</th><th>Link Tipi</th><th>Tıklanma</th></tr>
          </thead>
          <tbody>
            <% linkAnalytics.forEach(row => { %>
            <tr>
              <td style="font-weight:600"><%= row.ad %> <%= row.soyad %></td>
              <td><span class="chip-tip"><%= row.tip %></span></td>
              <td style="font-weight:700;color:var(--accent)"><%= row.sayi %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
        <% } else { %>
          <div class="bos-mesaj">
            <p style="font-size:32px;margin-bottom:12px">📊</p>
            <p style="font-weight:600;color:#374151;margin-bottom:6px">Henüz tıklama verisi yok</p>
            <p style="color:#9ca3af">Profil linkleri tıklandıkça burada görünür</p>
          </div>
        <% } %>
      </div>

    <% } else if (tab === 'excel') { %>
      <div class="tab-content">
        <div class="excel-card">
          <h3>Excel ile toplu yükleme</h3>
          <p>Önce şablonu indirin, doldurun, sonra buradan yükleyin.</p>
          <a href="/firma/panel/excel-sablon" class="btn btn-secondary" style="margin-bottom:20px">⬇ Şablonu İndir (.xlsx)</a>
          <form method="POST" action="/firma/panel/toplu-yukle" enctype="multipart/form-data">
            <div class="form-group">
              <label>Excel dosyası (.xlsx)</label>
              <input type="file" name="excel" accept=".xlsx,.xls" required>
            </div>
            <button type="submit" class="btn">Yükle ve İçe Aktar</button>
          </form>
        </div>
      </div>
    <% } %>
  </div>
</div>
